---
import "../styles/global.css";
import HelpCenterTopBar from "../components/HelpCenter/HelpCenterTopBar.astro";
import HelpCenterFooter from "../components/HelpCenter/HelpCenterFooter.astro";
import HelpCenterFloating from "../components/HelpCenter/HelpCenterFloating.astro";
import AutoBreadcrumb from "../components/Common/AutoBreadcrumb.astro";

interface Props {
  title?: string;
  description?: string;
  showBreadcrumb?: boolean;
}

const {
  title = "Tebra Help Center",
  description = "Find answers, training, and resources for Tebra—EHR, billing, Engage, telehealth, and practice growth.",
  showBreadcrumb = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:wght@100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white font-sans text-gray-900 antialiased">
    <HelpCenterTopBar />
    {showBreadcrumb ? <AutoBreadcrumb /> : null}
    <slot />
    <HelpCenterFooter />
    <HelpCenterFloating />
  </body>
</html>
