---
export interface DemoPillarItem {
  badge?: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  items: readonly DemoPillarItem[];
}

const { title, items } = Astro.props as Props;
---

<section class="bg-white py-14 sm:py-16 md:py-20 lg:py-24">
  <div class="page-container">
    <h2 class="heading-md mx-auto max-w-4xl text-center text-tebra-teal-dark">{title}</h2>

    <div class="mt-12 grid gap-6 sm:gap-8 md:grid-cols-3">
      {
        items.map((item) => (
          <div class="flex h-full flex-col rounded-2xl border border-gray-100 bg-tebra-hero-bg/60 p-6 sm:p-8">
            {item.badge ? (
              <span class="inline-flex w-fit rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-tebra-teal shadow-sm">
                {item.badge}
              </span>
            ) : null}
            <h3 class="mt-4 text-xl font-semibold leading-snug text-tebra-teal-dark sm:text-2xl">
              {item.title}
            </h3>
            <p class="mt-4 text-sm leading-relaxed text-gray-600 sm:text-base">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
