---
interface TourCard {
  title: string;
  description: string;
  ctaLabel: string;
  href: string;
}

interface Props {
  cards: readonly TourCard[];
}

const { cards } = Astro.props as Props;
---

<section class="bg-tebra-section-alt py-12 sm:py-14 md:py-16">
  <div class="page-container">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        cards.map((card) => (
          <article class="flex flex-col rounded-2xl border border-gray-200/80 bg-white p-6 shadow-sm transition hover:shadow-md sm:p-7">
            <h3 class="text-lg font-semibold text-tebra-teal-dark">{card.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-gray-600">{card.description}</p>
            <a
              href={card.href}
              class="mt-6 inline-flex items-center text-sm font-semibold text-tebra-teal hover:text-tebra-teal-dark"
            >
              {card.ctaLabel}
              <svg class="ml-1 h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path
                  d="M4 8h7M8 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
