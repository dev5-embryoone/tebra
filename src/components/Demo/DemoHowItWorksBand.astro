---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props as Props;
---

<section class="border-y border-gray-100 bg-white py-14 sm:py-16 md:py-20">
  <div class="page-container text-center">
    <p class="eyebrow text-tebra-teal">{eyebrow}</p>
    <h2 class="heading-md mx-auto mt-4 max-w-3xl text-tebra-teal-dark">{title}</h2>
    <p class="body-lg-muted mx-auto mt-5 max-w-2xl">{description}</p>
  </div>
</section>
