---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props as Props;
---

<article class="flex flex-col gap-3 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm hover:border-gray-200 transition-colors">
  <h3 class="text-lg font-semibold text-gray-900">
    {title}
  </h3>
  <p class="text-sm text-gray-600 leading-relaxed">
    {description}
  </p>
</article>
