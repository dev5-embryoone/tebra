---
interface Props {
  icon?: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props as Props;
---

<article class="flex flex-col gap-3 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm shadow-slate-100">
  {icon && (
    <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
      <span class="text-lg">{icon}</span>
    </div>
  )}
  <h3 class="text-lg font-semibold text-gray-900">
    {title}
  </h3>
  <p class="text-sm text-gray-600">
    {description}
  </p>
</article>

