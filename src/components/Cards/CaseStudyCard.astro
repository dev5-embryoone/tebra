---
import type { CaseStudy } from "../../data/caseStudies";

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props as Props;
const href = `/case-studies/${caseStudy.slug}`;
---

<article class="group flex flex-col rounded-2xl bg-white border border-gray-200 shadow-sm overflow-hidden hover:shadow-md hover:border-tebra-200 transition-all duration-200">
  <div class="p-6 flex flex-col flex-1">
    <span class="text-xs font-semibold uppercase tracking-wider text-tebra-600">
      {caseStudy.product}
    </span>
    <h3 class="mt-2 text-lg font-semibold text-gray-900 leading-snug">
      <a href={href} class="hover:text-tebra-700 focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-offset-2 rounded">
        {caseStudy.title}
      </a>
    </h3>
    <p class="mt-2 text-sm text-gray-600 line-clamp-2">
      "{caseStudy.quote}"
    </p>
    <div class="mt-4 pt-4 border-t border-gray-100 flex flex-wrap items-center gap-x-3 gap-y-1">
      <span class="text-sm font-medium text-gray-900">{caseStudy.company}</span>
      <span class="text-gray-400">·</span>
      <span class="text-sm text-gray-500">{caseStudy.author}</span>
    </div>
    <p class="mt-2 text-sm font-semibold text-tebra-600">
      {caseStudy.metric}
    </p>
    <a
      href={href}
      class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-tebra-600 hover:text-tebra-700 focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-offset-2 rounded"
    >
      Read the full story
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
