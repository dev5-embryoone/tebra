---
import type { CaseStudy } from "../../data/caseStudies";

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props as Props;
const href = `/case-studies/${caseStudy.slug}`;
---

<article class="group flex h-full flex-col rounded-2xl border border-gray-200 bg-[#f7f9f8] shadow-sm overflow-hidden hover:shadow-md hover:border-tebra-200 transition-all duration-200">
  {caseStudy.imageUrl && (
    <a href={href} class="block aspect-[16/9] overflow-hidden">
      <img
        src={caseStudy.imageUrl}
        alt={caseStudy.company}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
        loading="lazy"
      />
    </a>
  )}
  <div class="p-5 flex flex-col flex-1">
    <span class="w-fit rounded-full bg-white px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-tebra-600 border border-gray-200">
      {caseStudy.product}
    </span>
    <h3 class="mt-3 text-[30px] leading-8 font-semibold text-tebra-teal-dark">
      {caseStudy.metricValue ?? caseStudy.metric}
    </h3>
    <h4 class="mt-3 text-xl font-semibold text-gray-900 leading-snug">
      <a href={href} class="hover:text-tebra-700 focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-offset-2 rounded">
        {caseStudy.title}
      </a>
    </h4>
    <p class="mt-2 text-sm text-gray-600 line-clamp-3">{caseStudy.excerpt ?? `"${caseStudy.quote}"`}</p>
    <div class="mt-4 pt-4 border-t border-gray-100 flex flex-wrap items-center gap-x-3 gap-y-1">
      <span class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500">{caseStudy.company}</span>
    </div>
    <a
      href={href}
      class="mt-4 inline-flex items-center justify-between gap-2 text-sm font-semibold text-tebra-600 hover:text-tebra-700 focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-offset-2 rounded"
    >
      {caseStudy.ctaLabel ?? "Read the full story"}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
