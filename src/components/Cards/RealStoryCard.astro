---
import type { CaseStudy } from "../../data/caseStudies";

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props as Props;
const href = `/case-studies/${caseStudy.slug}`;
---

<article class="flex flex-col rounded-2xl bg-white border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-all">
  <div class="p-6 flex flex-col flex-1">
    <p class="text-lg font-semibold text-tebra-700">{caseStudy.metric}</p>
    <blockquote class="mt-3 text-sm text-gray-700 leading-relaxed">
      "{caseStudy.quote}"
    </blockquote>
    <footer class="mt-4 flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-tebra-500 text-sm font-semibold text-white">
        {caseStudy.author.split(' ').map(n => n[0]).join('').slice(0, 2)}
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900">{caseStudy.author}</p>
        <p class="text-xs text-gray-500">{caseStudy.company}</p>
      </div>
    </footer>
    <a
      href={href}
      class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-tebra-600 hover:text-tebra-700"
    >
      {caseStudy.hasVideo ? (
        <>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
          </svg>
          Watch the full story
        </>
      ) : (
        <>
          Read case study
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </>
      )}
    </a>
  </div>
</article>
