---
import type { CaseStudy } from "../../data/caseStudies";

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props as Props;
const href = `/case-studies/${caseStudy.slug}`;
---

<article
  class="group relative h-[420px] w-[300px] flex-shrink-0 overflow-hidden rounded-2xl border border-gray-200 shadow-sm md:h-[500px] md:w-[380px]"
>
  {caseStudy.imageUrl ? (
    <img src={caseStudy.imageUrl} alt={caseStudy.company} class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]" loading="lazy" />
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-gray-200 to-gray-300" />
  )}

  <!-- Darken more on hover so details pop -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent opacity-90 transition-opacity duration-300 group-hover:opacity-100" />

  <!-- Metric is always visible; quote + CTA appear on hover -->
  <div class="absolute inset-x-0 bottom-0 p-6 text-white">
    <p class="text-[34px] leading-tight font-semibold md:text-[40px]">
      {caseStudy.metricValue ?? caseStudy.metric}
    </p>
    {caseStudy.metricLabel && <p class="mt-1 text-sm leading-snug text-white/90 md:text-base">{caseStudy.metricLabel}</p>}

    <div
      class="mt-4 overflow-hidden transition-all duration-300 ease-out opacity-0 translate-y-2
             group-hover:opacity-100 group-hover:translate-y-0"
    >
      <p class="line-clamp-3 text-sm leading-relaxed text-white/95 md:text-base">"{caseStudy.quote}"</p>
      <p class="mt-3 text-xs font-semibold uppercase tracking-wider text-white/80 md:text-sm">{caseStudy.author}</p>
      <a
        href={href}
        class="mt-4 inline-flex items-center justify-center gap-2 rounded-full border border-white/80 px-4 py-2 text-xs font-semibold text-white hover:bg-white/15 transition-colors md:text-sm"
      >
        {(caseStudy.storyType === "video" || caseStudy.hasVideo) ? "Watch the full story" : "Read case study"}
      </a>
    </div>
  </div>
</article>
