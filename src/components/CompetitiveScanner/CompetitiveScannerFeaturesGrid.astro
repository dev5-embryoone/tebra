---
export type FeatureWithImage = {
  title: string;
  description: string;
  imageSrc: string;
  imageAlt: string;
};

interface Props {
  items: FeatureWithImage[];
  heading?: string;
  subheading?: string;
}

const {
  items,
  heading = "What we compare in your free report",
  subheading = "Benchmarks across the moments that influence whether patients choose you.",
} = Astro.props as Props;
---

<section class="bg-white py-14 sm:py-16 lg:py-24" aria-labelledby="scanner-features-heading">
  <div class="page-container">
    <div class="mx-auto max-w-2xl text-center">
      <h2
        id="scanner-features-heading"
        class="text-2xl font-bold tracking-tight text-tebra-teal-dark sm:text-3xl"
      >
        {heading}
      </h2>
      <p class="mt-3 text-gray-600">
        {subheading}
      </p>
    </div>

    <ul
      class="mx-auto mt-12 grid max-w-6xl gap-8 sm:grid-cols-2 lg:mt-16 lg:gap-10 xl:grid-cols-4"
    >
      {
        items.map((item) => (
          <li class="flex flex-col rounded-2xl border border-gray-100 bg-tebra-hero-bg/30 p-6 text-center shadow-sm transition hover:shadow-md">
            <div class="mx-auto flex h-28 w-full max-w-[9rem] items-center justify-center sm:h-32">
              <img
                src={item.imageSrc}
                alt={item.imageAlt}
                class="max-h-full max-w-full object-contain"
                loading="lazy"
                width="160"
                height="140"
              />
            </div>
            <h3 class="mt-4 text-lg font-bold text-tebra-teal-dark">
              {item.title}
            </h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">
              {item.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
