---
interface BarItem {
  id: string;
  label: string;
  heightPct: number;
  capColor: string;
  highlightBubble?: boolean;
}

interface Props {
  bars: readonly BarItem[];
  title: string;
  body: string;
  footnote: string;
}

const { bars, title, body, footnote } = Astro.props as Props;
---

<section
  class="border-t border-gray-100 bg-gray-50 py-14 sm:py-16 lg:py-24"
  aria-labelledby="scanner-bar-heading"
>
  <div class="page-container">
    <div
      class="mx-auto grid w-full max-w-4xl grid-cols-2 items-end justify-items-center gap-x-6 gap-y-6 px-2 sm:grid-cols-4 sm:gap-x-8 md:gap-x-10 lg:gap-x-12"
      role="presentation"
    >
      {
        bars.map((b) => (
          <div class="flex w-full max-w-[7rem] flex-col items-center gap-2">
            <span
              class:list={[
                "whitespace-nowrap rounded-lg px-2 py-1 text-center text-[9px] font-semibold shadow-sm sm:text-[10px] md:text-xs",
                b.highlightBubble
                  ? "bg-tebra-teal-dark text-white"
                  : "border border-gray-200 bg-white text-gray-700",
              ]}
            >
              {b.label}
            </span>
            <div class="relative flex h-40 w-full flex-col items-center justify-end sm:h-44">
              <div
                class="w-[70%] max-w-[4.5rem] rounded-t-md shadow-[0_8px_24px_rgba(0,0,0,0.12)]"
                style={`height: ${b.heightPct}%; background: linear-gradient(to bottom, #ffffff 0%, #ffffff 52%, ${b.capColor} 52%, ${b.capColor} 100%); min-height: 2.5rem;`}
              />
            </div>
          </div>
        ))
      }
    </div>

    <div class="mx-auto mt-12 max-w-3xl px-4 text-center sm:mt-16 sm:px-6">
      <h2
        id="scanner-bar-heading"
        class="font-display text-2xl font-semibold leading-tight tracking-tight text-gray-900 sm:text-3xl lg:text-4xl"
      >
        {title}
      </h2>
      <p class="mt-5 text-base leading-relaxed text-gray-600 sm:text-lg">
        {body}
      </p>
      <p class="mt-6 text-xs text-gray-400 sm:text-sm">
        {footnote}
      </p>
    </div>
  </div>
</section>
