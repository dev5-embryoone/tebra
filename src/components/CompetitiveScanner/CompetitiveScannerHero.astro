---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
}

const { eyebrow, title, subtitle } = Astro.props as Props;
---

<div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
  <p
    class="text-xs font-bold uppercase tracking-[0.2em] text-tebra-teal-dark sm:text-sm"
  >
    {eyebrow}
  </p>
  <h1
    class="mt-4 font-display text-3xl font-semibold leading-tight tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.65rem] lg:leading-[1.15]"
  >
    {title}
  </h1>
  <p
    class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg"
  >
    {subtitle}
  </p>
</div>
