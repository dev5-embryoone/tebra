---
interface Props {
  yourPractice: string;
  competitor2: string;
  competitor3: string;
}

const { yourPractice, competitor2, competitor3 } = Astro.props as Props;
---

<div
  class="relative mx-auto mt-8 max-w-3xl px-4 sm:mt-12 sm:px-6"
  aria-hidden="true"
>
  <div class="scanner-preview-wrap">
    <div class="scanner-preview-item">
      <span class="scanner-preview-label">{competitor2}</span>
      <div class="scanner-preview-meter">
        <span class="scanner-preview-fill scanner-preview-fill--purple" style="width: 52%;"></span>
      </div>
    </div>

    <div class="scanner-preview-item scanner-preview-item--highlight">
      <span class="scanner-preview-label scanner-preview-label--highlight">{yourPractice}</span>
      <div class="scanner-preview-meter">
        <span class="scanner-preview-fill scanner-preview-fill--gold" style="width: 68%;"></span>
      </div>
    </div>

    <div class="scanner-preview-item">
      <span class="scanner-preview-label">{competitor3}</span>
      <div class="scanner-preview-meter">
        <span class="scanner-preview-fill scanner-preview-fill--green" style="width: 81%;"></span>
      </div>
    </div>
  </div>
</div>
