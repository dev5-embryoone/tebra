---
interface Props {
  title: string;
  description: string;
  bullets: string[];
  tags: string[];
}

const { title, description, bullets, tags } = Astro.props as Props;
---

<article class="flex h-full flex-col rounded-2xl border border-gray-100 bg-white p-6 shadow-sm lg:p-8">
  <h3 class="text-xl font-semibold tracking-tight text-tebra-teal-dark">{title}</h3>
  <p class="mt-3 text-[15px] leading-relaxed text-gray-600">{description}</p>
  <ul class="mt-5 space-y-2.5 text-sm text-gray-700">
    {bullets.map((b) => (
      <li class="flex gap-2">
        <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-tebra-orange" aria-hidden="true" />
        <span>{b}</span>
      </li>
    ))}
  </ul>
  {
    tags.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2 border-t border-gray-100 pt-6">
        {tags.map((t) => (
          <span class="rounded-full bg-tebra-hero-bg px-3 py-1 text-xs font-medium text-tebra-teal-dark">
            {t}
          </span>
        ))}
      </div>
    )
  }
</article>
