---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Cta {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  steps: Step[];
  primaryCta: Cta;
  secondaryCta: Cta;
}

const { title, description, steps, primaryCta, secondaryCta } = Astro.props as Props;
---

<section class="bg-tebra-section-warm py-16 lg:py-24">
  <div class="page-container">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl">
        {title}
      </h2>
      <p class="mt-4 text-lg text-gray-600">{description}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href={primaryCta.href}
          class="inline-flex items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#ff5a49] transition-colors"
        >
          {primaryCta.label}
        </a>
        <a
          href={secondaryCta.href}
          class="inline-flex items-center justify-center rounded-full border border-tebra-teal bg-white px-6 py-3 text-sm font-semibold text-tebra-teal hover:bg-tebra-hero-bg transition-colors"
        >
          {secondaryCta.label}
        </a>
      </div>
    </div>

    <ol class="mx-auto mt-16 grid max-w-5xl gap-10 md:grid-cols-3 md:gap-8">
      {
        steps.map((s) => (
          <li class="relative flex flex-col rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
            <span class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-tebra-teal text-lg font-bold text-white">
              {s.number}
            </span>
            <h3 class="text-lg font-semibold text-tebra-teal-dark">{s.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-600">{s.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
