---
interface Props {
  quote: string;
  author: string;
  org: string;
}

const { quote, author, org } = Astro.props as Props;
---

<blockquote class="flex h-full flex-col rounded-2xl border border-gray-100 bg-white p-6 shadow-sm lg:p-8">
  <div class="mb-4 text-tebra-orange" aria-hidden="true">
    <svg class="h-8 w-8 opacity-80" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"
      />
    </svg>
  </div>
  <p class="flex-1 text-base font-medium leading-relaxed text-gray-800">&ldquo;{quote}&rdquo;</p>
  <footer class="mt-6 border-t border-gray-100 pt-4">
    <cite class="not-italic">
      <span class="block font-semibold text-tebra-teal-dark">{author}</span>
      <span class="mt-0.5 block text-sm text-gray-500">{org}</span>
    </cite>
  </footer>
</blockquote>
