---
import PlatformFeature from "./PlatformFeature.astro";
import SectionHeader from "../SectionHeader/SectionHeader.astro";
import { platformItems } from "../../data/platform";
import platformLabOperationsImage from "../../assets/platform-lab-operations.png";
import platformInventoryConsumptionImage from "../../assets/platform-inventory-consumption.png";
import platformCryoIntegratedImage from "../../assets/platform-cryo-integrated.png";

const platformImages = [
  platformLabOperationsImage,
  platformInventoryConsumptionImage,
  platformCryoIntegratedImage,
];
---

<section id="platform" class="page-section bg-white">
  <div class="page-container space-y-14 lg:space-y-20">
    <SectionHeader
      title="Software built for IVF lab and clinical workflows"
      description="One platform. Every workflow. Designed for IVF teams."
      class="max-w-2xl"
    />

    {platformItems.map((item, index) => (
      <PlatformFeature
        title={item.title}
        description={item.description}
        imageAlt={item.title}
        imageSrc={platformImages[index]?.src}
        reverse={index % 2 === 1}
      />
    ))}
  </div>
</section>

