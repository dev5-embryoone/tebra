---
import PlatformFeature from "./PlatformFeature.astro";
import { platformItems } from "../../data/platform";
---

<section id="platform" class="page-section bg-white">
  <div class="page-container space-y-14 lg:space-y-20">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight text-gray-900 lg:text-4xl">
        Software solutions powering your practice
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        One platform. Every workflow. Built for private practices.
      </p>
    </div>

    {platformItems.map((item, index) => (
      <PlatformFeature
        title={item.title}
        description={item.description}
        imageAlt={item.title}
        reverse={index % 2 === 1}
      />
    ))}
  </div>
</section>

