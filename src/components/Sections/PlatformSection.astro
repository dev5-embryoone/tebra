---
import PlatformFeature from "./PlatformFeature.astro";
import SectionHeader from "../SectionHeader/SectionHeader.astro";
import { platformItems } from "../../data/platform";
---

<section id="platform" class="page-section bg-white">
  <div class="page-container space-y-14 lg:space-y-20">
    <SectionHeader
      title="Software solutions powering your practice"
      description="One platform. Every workflow. Built for private practices."
      class="max-w-2xl"
    />

    {platformItems.map((item, index) => (
      <PlatformFeature
        title={item.title}
        description={item.description}
        imageAlt={item.title}
        reverse={index % 2 === 1}
      />
    ))}
  </div>
</section>

