---
interface Props {
  pillLabel: string;
  title: string;
  description: string;
  quote: string;
  quoteAuthor: string;
  quoteSubtitle?: string;
  imageSrc: string;
  imageAlt?: string;
  badgeImageSrc?: string;
  badgeImageAlt?: string;
}

const {
  pillLabel,
  title,
  description,
  quote,
  quoteAuthor,
  quoteSubtitle,
  imageSrc,
  imageAlt = title,
} = Astro.props as Props;
---

<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
  <div>
    <p class="inline-flex items-center rounded-full bg-[#EAF4F1] px-3 py-1 text-xs font-semibold text-tebra-teal-dark">
      {pillLabel}
    </p>
    <h2 class="mt-4 heading-lg text-tebra-teal-dark">
      {title}
    </h2>
    <p class="mt-3 body-base-muted">
      {description}
    </p>

    <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="max-w-xl">
          <p class="text-base font-medium text-tebra-teal-dark">
            {quote}
          </p>
          <p class="mt-3 text-sm font-semibold text-gray-900">
            {quoteAuthor}
          </p>
          {quoteSubtitle && (
            <p class="text-sm text-gray-500">
              {quoteSubtitle}
            </p>
          )}
        </div>
        {Astro.props.badgeImageSrc && (
          <div class="shrink-0 flex items-center justify-center">
            <img
              src={Astro.props.badgeImageSrc}
              alt={Astro.props.badgeImageAlt ?? `${title} badge`}
              loading="lazy"
              class="h-20 w-20 sm:h-24 sm:w-24 object-contain"
            />
          </div>
        )}
      </div>
    </div>
  </div>

  <div class="lg:pl-8 flex items-center justify-center">
    <img
      src={imageSrc}
      alt={imageAlt}
      loading="lazy"
      class="max-h-[620px] w-full max-w-full object-contain"
    />
  </div>
</div>

