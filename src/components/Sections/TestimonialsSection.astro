---
import TestimonialCard from "../Cards/TestimonialCard.astro";
import { testimonials } from "../../data/testimonials";
---

<section id="resources" class="page-section bg-gray-50">
  <div class="page-container">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500">
        What success looks like with Tebra
      </p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 lg:text-4xl">
        Our customers don&apos;t just work with us, they grow with us
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        See how practices use Tebra to save time, get paid faster, and deliver a modern experience patients love.
      </p>
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((testimonial) => (
        <TestimonialCard
          quote={testimonial.quote}
          author={testimonial.author}
          company={testimonial.company}
          avatarInitials={testimonial.avatarInitials}
        />
      ))}
    </div>
  </div>
</section>

