---
import TestimonialCard from "../Cards/TestimonialCard.astro";
import SectionHeader from "../SectionHeader/SectionHeader.astro";
import { testimonials } from "../../data/testimonials";
---

<section id="resources" class="page-section bg-gray-50">
  <div class="page-container">
    <SectionHeader
      eyebrow="What success looks like with Tebra"
      title="Our customers don't just work with us, they grow with us"
      description="See how practices use Tebra to save time, get paid faster, and deliver a modern experience patients love."
      centered
    />

    <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((testimonial) => (
        <TestimonialCard
          quote={testimonial.quote}
          author={testimonial.author}
          company={testimonial.company}
          avatarInitials={testimonial.avatarInitials}
        />
      ))}
    </div>
  </div>
</section>

