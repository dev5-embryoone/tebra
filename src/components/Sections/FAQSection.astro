---
import FAQItem from '../FAQ/FAQItem.astro';
import SectionHeader from '../SectionHeader/SectionHeader.astro';
import Button from '../Button/Button.astro';
import { faqItems } from '../../data/faq';
---

<section id="faq" class="bg-tebra-section-alt py-16 lg:py-24">
  <div class="page-container">
    <SectionHeader
      eyebrow="FAQs"
      title="Frequently asked questions"
      titleClass="text-tebra-teal-dark"
    />

    <div class="mt-8 overflow-hidden rounded-xl border border-gray-200 bg-white p-1 shadow-sm">
      {faqItems.map((item, index) => (
        <FAQItem
          itemId={item.id}
          question={item.question}
          answer={item.answer}
          isOpen={index === 0}
        />
      ))}
    </div>

    <div class="mt-8 flex justify-center">
      <Button
        type="button"
        id="faq-show-more"
        label="Show more"
        variant="outline-dark"
        size="sm"
      />
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll<HTMLButtonElement>('[data-faq-trigger]');
    triggers.forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        if (!item) return;
        const isOpen = item.classList.contains('is-open');
        if (isOpen) {
          item.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');
        } else {
          item.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    const showMoreBtn = document.getElementById('faq-show-more');
    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', () => {
        const items = document.querySelectorAll('.faq-item');
        const allOpen = Array.from(items).every((el) => el.classList.contains('is-open'));
        items.forEach((item, i) => {
          const trigger = item.querySelector<HTMLButtonElement>('[data-faq-trigger]');
          if (allOpen) {
            item.classList.remove('is-open');
            trigger?.setAttribute('aria-expanded', 'false');
          } else {
            item.classList.add('is-open');
            trigger?.setAttribute('aria-expanded', 'true');
          }
        });
        showMoreBtn.textContent = allOpen ? 'Show more' : 'Show less';
      });
    }
  });
</script>
