---
import Button from "../Button/Button.astro";
---

<section class="bg-tebra-hero-bg py-16 md:py-20">
  <div class="page-container text-center">
    <h1 class="text-3xl font-semibold tracking-tight text-gray-900 md:text-4xl lg:text-5xl leading-tight">
      How practices and billing companies grow with Tebra
    </h1>
    <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-600">
      Discover real success stories from private practices and billing companies using Tebra to work smarter, grow faster, and deliver better patient care.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <Button href="#case-studies-grid" label="Browse All Case Studies" variant="primary" size="lg" class="rounded-full" />
      <Button href="#demo" label="See Tebra in action" variant="secondary" size="lg" class="rounded-full" />
    </div>
  </div>
</section>
