---
import Button from '../Button/Button.astro';

interface Props {
  title: string;
  description: string;
  primaryCtaLabel: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
}

const {
  title,
  description,
  primaryCtaLabel,
  primaryCtaHref = "#demo",
  secondaryCtaLabel,
  secondaryCtaHref = "#",
} = Astro.props as Props;
---

<!-- CTA above footer: uses global dark teal token, centered heading + two buttons -->
<section id="demo" class="bg-tebra-teal-dark text-white">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-16 md:py-20 text-center">
    <div class="mx-auto max-w-2xl space-y-4">
      <h2 class="heading-xl text-white">
        {title}
      </h2>
      <p class="body-base-muted text-white/90">
        {description}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
        <Button href={primaryCtaHref} label={primaryCtaLabel} variant="primary" size="lg" class="rounded-full" />
        {secondaryCtaLabel && (
          <Button href={secondaryCtaHref} label={secondaryCtaLabel} variant="outline-light" size="lg" class="rounded-full" />
        )}
      </div>
    </div>
  </div>
</section>
