---
import Button from '../Button/Button.astro';

interface Props {
  title: string;
  description: string;
  primaryCtaLabel: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
}

const {
  title,
  description,
  primaryCtaLabel,
  primaryCtaHref = "#demo",
  secondaryCtaLabel,
  secondaryCtaHref = "#",
} = Astro.props as Props;

const resolvedPrimaryCtaHref =
  primaryCtaLabel.trim().toLowerCase() === "book a demo" ? "/demo" : primaryCtaHref;

const resolvedSecondaryCtaHref =
  secondaryCtaLabel?.trim().toLowerCase() === "explore for free" ? "/product-tour" : secondaryCtaHref;
---

<!-- CTA above footer: uses global dark teal token, centered heading + two buttons -->
<section id="demo" class="bg-tebra-teal-dark text-white">
  <div class="max-w-content mx-auto px-4 py-14 text-center sm:px-6 md:py-20 lg:px-12">
    <div class="mx-auto max-w-2xl space-y-4">
      <h2 class="heading-xl text-white">
        {title}
      </h2>
      <p class="text-base leading-relaxed text-white">
        {description}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
        <Button href={resolvedPrimaryCtaHref} label={primaryCtaLabel} variant="primary" size="lg" class="rounded-full" />
        {secondaryCtaLabel && (
          <Button href={resolvedSecondaryCtaHref} label={secondaryCtaLabel} variant="outline-light" size="lg" class="rounded-full" />
        )}
      </div>
    </div>
  </div>
</section>
