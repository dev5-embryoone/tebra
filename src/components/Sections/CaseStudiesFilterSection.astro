---
import type { CaseStudy } from "../../data/caseStudies";
import CaseStudyCard from "../Cards/CaseStudyCard.astro";
import {
  caseStudyChallenges,
  caseStudyRoles,
  caseStudyProducts,
} from "../../data/caseStudies";

interface Props {
  caseStudies: CaseStudy[];
}

const { caseStudies } = Astro.props as Props;
---

<section id="case-studies-grid" class="page-section bg-white">
  <div class="page-container">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <h2 class="text-5xl font-semibold tracking-tight text-tebra-teal-dark">
        Find stories like yours
      </h2>
      <p class="mt-4 text-base leading-7 text-gray-600">
        Whether you're a solo provider, part of a growing practice, or running a billing company, discover how others are achieving measurable results with Tebra.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[290px_1fr]">
      <aside class="rounded-2xl border border-gray-200 bg-white p-5 lg:sticky lg:top-28 lg:h-[75vh] lg:overflow-y-auto">
        <p class="mb-5 text-xs text-gray-500">
          Showing <span id="case-studies-count">{caseStudies.length}</span> of {caseStudies.length} case studies
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="mb-3 text-lg font-semibold text-gray-900">Challenges</h3>
            <div class="space-y-2">
              {caseStudyChallenges.map((ch) => (
                <label class="flex cursor-pointer items-center justify-between gap-3 text-sm text-gray-700">
                  <span>{ch}</span>
                  <input type="checkbox" class="case-study-filter h-4 w-4 rounded border-gray-300 text-tebra-600" data-filter="challenge" data-value={ch} />
                </label>
              ))}
            </div>
          </div>

          <div>
            <h3 class="mb-3 text-lg font-semibold text-gray-900">Roles</h3>
            <div class="space-y-2">
              {caseStudyRoles.map((role) => (
                <label class="flex cursor-pointer items-center justify-between gap-3 text-sm text-gray-700">
                  <span>{role}</span>
                  <input type="checkbox" class="case-study-filter h-4 w-4 rounded border-gray-300 text-tebra-600" data-filter="role" data-value={role} />
                </label>
              ))}
            </div>
          </div>

          <div>
            <h3 class="mb-3 text-lg font-semibold text-gray-900">Products</h3>
            <div class="space-y-2">
              {caseStudyProducts.map((product) => (
                <label class="flex cursor-pointer items-center justify-between gap-3 text-sm text-gray-700">
                  <span>{product}</span>
                  <input type="checkbox" class="case-study-filter h-4 w-4 rounded border-gray-300 text-tebra-600" data-filter="product" data-value={product} />
                </label>
              ))}
            </div>
          </div>
        </div>

        <button
          type="button"
          id="clear-filters"
          class="mt-6 text-sm font-semibold text-tebra-600 hover:text-tebra-700"
        >
          Clear all
        </button>
      </aside>

      <div class="grid gap-6 md:grid-cols-2" id="case-studies-list">
        {caseStudies.map((cs) => (
          <div
            class="case-study-item"
            data-challenges={cs.challenges.join(",")}
            data-roles={cs.roles.join(",")}
            data-product={cs.product}
          >
            <CaseStudyCard caseStudy={cs} />
          </div>
        ))}

        <article class="rounded-2xl bg-gradient-to-br from-tebra-teal to-tebra-teal-dark p-8 text-white shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/80">Product Tour</p>
          <h3 class="mt-3 text-4xl font-semibold leading-tight">Explore our all-in-one platform</h3>
          <p class="mt-3 text-sm leading-6 text-white/90">
            Tebra's products come together to form the complete operating system for practice success.
          </p>
          <a href="/product-tour" class="mt-6 inline-flex rounded-full bg-white px-5 py-2 text-sm font-semibold text-tebra-teal hover:bg-white/90">
            Take a product tour
          </a>
        </article>
      </div>
    </div>
  </div>
</section>

<script>
  function runFilters() {
    const items = document.querySelectorAll<HTMLDivElement>(".case-study-item");
    const countEl = document.getElementById("case-studies-count");
    const activeFilters: Record<string, Set<string>> = {
      challenge: new Set(),
      role: new Set(),
      product: new Set(),
    };

    function updateCount() {
      const visible = Array.from(items).filter((el) => el.style.display !== "none");
      if (countEl) countEl.textContent = String(visible.length);
    }

    function applyFilters() {
      items.forEach((el) => {
        const challenges = (el.dataset.challenges ?? "").split(",").filter(Boolean);
        const roles = (el.dataset.roles ?? "").split(",").filter(Boolean);
        const product = (el.dataset.product ?? "").trim();

        const matchChallenge =
          activeFilters.challenge.size === 0 ||
          challenges.some((c) => activeFilters.challenge.has(c));
        const matchRole =
          activeFilters.role.size === 0 || roles.some((r) => activeFilters.role.has(r));
        const matchProduct =
          activeFilters.product.size === 0 || activeFilters.product.has(product);

        const show = matchChallenge && matchRole && matchProduct;
        (el as HTMLElement).style.display = show ? "" : "none";
      });
      updateCount();
    }

    document.querySelectorAll<HTMLInputElement>(".case-study-filter").forEach((check) => {
      check.addEventListener("change", () => {
        const filter = check.dataset.filter as keyof typeof activeFilters;
        const value = check.dataset.value ?? "";
        if (!filter || !value) return;
        if (check.checked) activeFilters[filter].add(value);
        else activeFilters[filter].delete(value);
        applyFilters();
      });
    });

    document.getElementById("clear-filters")?.addEventListener("click", () => {
      activeFilters.challenge.clear();
      activeFilters.role.clear();
      activeFilters.product.clear();
      document.querySelectorAll<HTMLInputElement>(".case-study-filter").forEach((check) => {
        check.checked = false;
      });
      applyFilters();
    });

    updateCount();
  }

  runFilters();
</script>
