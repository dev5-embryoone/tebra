---
import FeatureCard from "../Cards/FeatureCard.astro";
import { features } from "../../data/features";
---

<section id="solutions" class="page-section bg-gray-50">
  <div class="page-container">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-gray-900 lg:text-4xl">
        Everything you need, finally connected
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Tebra brings your EHR, billing, scheduling, and reputation tools together in one EHR+ platform, so every workflow talks to the next.
      </p>
    </div>

    <div class="mt-10 grid gap-10 md:grid-cols-2 lg:mt-12 lg:grid-cols-3">
      {features.map((feature) => (
        <FeatureCard
          icon={feature.icon}
          title={feature.title}
          description={feature.description}
        />
      ))}
    </div>
  </div>
</section>

