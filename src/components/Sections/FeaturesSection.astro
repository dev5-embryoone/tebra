---
import FeatureCard from "../Cards/FeatureCard.astro";
import SectionHeader from "../SectionHeader/SectionHeader.astro";
import { features } from "../../data/features";
---

<section id="solutions" class="page-section bg-gray-50">
  <div class="page-container">
    <SectionHeader
      title="Everything you need, finally connected"
      description="Tebra brings your EHR, billing, scheduling, and reputation tools together in one EHR+ platform, so every workflow talks to the next."
      centered
    />

    <div class="mt-10 grid gap-10 md:grid-cols-2 lg:mt-12 lg:grid-cols-3">
      {features.map((feature) => (
        <FeatureCard
          icon={feature.icon}
          title={feature.title}
          description={feature.description}
        />
      ))}
    </div>
  </div>
</section>

