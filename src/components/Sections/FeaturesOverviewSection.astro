---
import SectionHeader from "../SectionHeader/SectionHeader.astro";
---

<section class="bg-white py-6 lg:py-8">
  <div class="page-container space-y-4">
    <SectionHeader
      title="Every part of your practice, connected"
      description="Whether you're delivering care, managing the front office, or handling billing, Tebra has you covered."
      centered
    />

    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="#ehr"
        class="inline-flex items-center rounded-full bg-[#F2F5F6] px-5 py-2 text-sm font-semibold text-tebra-teal-dark hover:bg-[#E6ECEE] transition"
      >
        EHR
      </a>
      <a
        href="#billing-payments"
        class="inline-flex items-center rounded-full bg-[#F2F5F6] px-5 py-2 text-sm font-semibold text-tebra-teal-dark hover:bg-[#E6ECEE] transition"
      >
        Billing and Payments
      </a>
      <a
        href="#patient-experience"
        class="inline-flex items-center rounded-full bg-[#F2F5F6] px-5 py-2 text-sm font-semibold text-tebra-teal-dark hover:bg-[#E6ECEE] transition"
      >
        Patient Experience
      </a>
      <a
        href="#practice-marketing"
        class="inline-flex items-center rounded-full bg-[#F2F5F6] px-5 py-2 text-sm font-semibold text-tebra-teal-dark hover:bg-[#E6ECEE] transition"
      >
        Practice Marketing
      </a>
    </div>
  </div>
</section>

