---
import { getStartedSteps } from '../../data/steps';
import Button from '../Button/Button.astro';
---

<section id="get-started" class="bg-[#F5F7F8] py-16 lg:py-24">
  <div class="page-container">
    <div class="grid gap-10 lg:grid-cols-[1fr,1fr] lg:items-center lg:gap-12">
      <!-- Left column: centered text -->
      <div class="text-center lg:text-left">
        <p class="text-xs font-semibold uppercase tracking-widest text-[#777777]">
          Step-by-step process
        </p>
        <h2 class="mt-2 text-3xl font-bold leading-tight text-[#00566C] lg:text-4xl">
          Get started with Tebra in 3 easy steps
        </h2>
        <p class="mt-4 mx-auto max-w-lg text-base leading-relaxed text-[#777777] lg:mx-0">
          Simple, supported, and designed to fit the way you work. From setup to go-live, we'll guide you every step so your practice sees value from day one.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3 lg:justify-start">
          <Button href="#demo" label="Get started today" variant="primary" size="md" />
          <Button href="#get-started" label="See how it works" variant="secondary" size="md" />
        </div>
      </div>

      <!-- Right column: steps card -->
      <div class="card-radius bg-card mx-auto w-full max-w-xl overflow-hidden border border-gray-200/80 p-8 shadow-sm lg:p-10">
        <ul class="flex flex-col gap-0">
          {getStartedSteps.map((step, index) => (
            <li class="relative flex gap-6 pb-8 last:pb-0">
              <!-- Vertical connecting line: orange -->
              {index < getStartedSteps.length - 1 && (
                <span
                  class="absolute left-[27px] top-16 bottom-0 w-0.5 bg-btn-primary lg:left-[31px] lg:top-[4.5rem]"
                  aria-hidden="true"
                />
              )}
              <!-- Large number - bigger text -->
              <span
                class="relative z-10 flex h-14 w-14 flex-shrink-0 items-center justify-center text-3xl font-bold text-[#00566C] lg:h-16 lg:w-16 lg:text-4xl"
                aria-hidden="true"
              >
                {step.number}
              </span>
              <div class="min-w-0 flex-1 pt-1">
                <h3 class="text-lg font-bold text-[#333333] lg:text-xl">
                  {step.title}
                </h3>
                <p class="mt-1.5 text-base leading-relaxed text-[#777777]">
                  {step.description}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
