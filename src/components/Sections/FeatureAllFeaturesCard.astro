---
interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref?: string;
}

const {
  title,
  description,
  ctaLabel,
  ctaHref = "#",
} = Astro.props as Props;
---

<section class="mt-8 lg:mt-10">
  <div
    class="rounded-[24px] border border-border-subtle bg-[#FDF7F2] px-6 py-8 shadow-sm lg:px-10 lg:py-10"
    data-feature-carousel-root
  >
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <h3 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark lg:text-[26px]">
          {title}
        </h3>
        <p class="mt-2 text-sm md:text-base text-gray-600 max-w-xl">
          {description}
        </p>
      </div>
      <a
        href={ctaHref}
        class="inline-flex items-center justify-center rounded-full border border-tebra-teal bg-white px-5 py-2 text-sm font-semibold text-tebra-teal hover:bg-tebra-hero-bg transition"
      >
        {ctaLabel}
      </a>
    </div>

    <div class="mt-6">
      <div
        class="flex gap-6 overflow-x-auto pb-2 md:pb-0 md:overflow-hidden"
        data-feature-carousel-track
      >
        <slot />
      </div>

      <div class="mt-6 flex items-center gap-3">
        <div class="inline-flex rounded-full border border-gray-300 bg-white shadow-sm">
          <button
            type="button"
            class="flex h-9 w-9 items-center justify-center rounded-full text-gray-500 hover:bg-gray-100 disabled:opacity-40"
            aria-label="Previous features"
            data-feature-carousel-prev
          >
            <span class="sr-only">Previous</span>
            <svg viewBox="0 0 16 16" class="h-4 w-4" aria-hidden="true">
              <path
                d="M10 3.5 6 8l4 4.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
          <button
            type="button"
            class="flex h-9 w-9 items-center justify-center rounded-full text-gray-700 hover:bg-gray-100 disabled:opacity-40"
            aria-label="Next features"
            data-feature-carousel-next
          >
            <span class="sr-only">Next</span>
            <svg viewBox="0 0 16 16" class="h-4 w-4" aria-hidden="true">
              <path
                d="M6 3.5 10 8 6 12.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const roots = document.querySelectorAll<HTMLElement>("[data-feature-carousel-root]");

    roots.forEach((root) => {
      const track = root.querySelector<HTMLElement>("[data-feature-carousel-track]");
      const prev = root.querySelector<HTMLButtonElement>("[data-feature-carousel-prev]");
      const next = root.querySelector<HTMLButtonElement>("[data-feature-carousel-next]");

      if (!track || !prev || !next) return;

      const updateDisabled = () => {
        const maxScroll = track.scrollWidth - track.clientWidth - 1;
        prev.disabled = track.scrollLeft <= 0;
        next.disabled = track.scrollLeft >= maxScroll;
      };

      const scrollByPage = (direction: "left" | "right") => {
        const amount = track.clientWidth * 0.9 * (direction === "left" ? -1 : 1);
        track.scrollBy({ left: amount, behavior: "smooth" });
      };

      prev.addEventListener("click", () => scrollByPage("left"));
      next.addEventListener("click", () => scrollByPage("right"));

      track.addEventListener("scroll", () => {
        window.requestAnimationFrame(updateDisabled);
      });

      updateDisabled();
    });
  });
</script>

