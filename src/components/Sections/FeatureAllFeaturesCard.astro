---
interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref?: string;
}

const {
  title,
  description,
  ctaLabel,
  ctaHref = "#",
} = Astro.props as Props;
---

<section class="mt-12">
  <div class="rounded-[24px] border border-border-subtle bg-[#FDF7F2] px-6 py-8 shadow-sm lg:px-10 lg:py-10">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <h3 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark lg:text-[26px]">
          {title}
        </h3>
        <p class="mt-2 text-sm md:text-base text-gray-600 max-w-xl">
          {description}
        </p>
      </div>
      <a
        href={ctaHref}
        class="inline-flex items-center justify-center rounded-full border border-tebra-teal bg-white px-5 py-2 text-sm font-semibold text-tebra-teal hover:bg-tebra-hero-bg transition"
      >
        {ctaLabel}
      </a>
    </div>

    <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      <slot />
    </div>
  </div>
</section>

