---
import { practiceTools, intakeArticles } from '../../data/practiceTools';
import labToolImage from '../../assets/clinic.png';
import embryoToolImage from '../../assets/embryo1.png';
import cryoToolImage from '../../assets/Product-Graphic-1@2x-768x768.webp';
import SectionHeader from '../SectionHeader/SectionHeader.astro';

const toolImages: Record<string, ImageMetadata> = {
  'lab-efficiency-calculator': labToolImage,
  'cryo-utilization-insights': cryoToolImage,
  'embryo-data-insights': embryoToolImage,
};
---
<section id="practice-tools" class="bg-white py-16 lg:py-24">
  <div class="page-container space-y-10 lg:space-y-14">
    <SectionHeader title="Tools to improve IVF operations" centered class="max-w-4xl" />

    <!-- Tools accordion (replaces card-style tiles) -->
    <div class="space-y-0">
      {practiceTools.map((tool, i) => (
        <details
          class={`border-t border-gray-200 ${i === 0 ? 'border-t-0' : ''} group`}
          open={i === 0}
        >
          <summary class="cursor-pointer list-none py-6 pr-6">
            <div class="flex items-start justify-between gap-6">
              <div class="min-w-0">
                <h3 class="text-lg font-semibold tracking-tight text-gray-900 lg:text-xl">
                  {tool.title}
                </h3>
                <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-gray-600">
                  {tool.description}
                </p>
              </div>
              <div class="shrink-0 pt-1">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="h-5 w-5 text-tebra-teal-dark transition-transform duration-200"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M8.22 6.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L11.94 11H4.75A.75.75 0 0 1 4 10.25v-4.5a.75.75 0 0 1 1.5 0v5.69l2.22-2.22Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
            </div>
          </summary>

          <div class="pb-6">
            <div class="mt-2 flex flex-wrap items-center justify-between gap-4">
              <a
                href={tool.ctaHref}
                class={`inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold transition ${
                  tool.variant === 'white'
                    ? 'bg-white text-gray-900 border border-gray-200 hover:border-gray-300 hover:bg-gray-50'
                    : tool.variant === 'coral'
                      ? 'bg-btn-primary text-white border border-btn-primary hover:bg-btn-primary-hover'
                      : 'bg-tebra-700 text-white border border-tebra-700 hover:bg-tebra-600'
                }`}
              >
                {tool.ctaLabel}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path d="M6 12l4-4-4-4" />
                </svg>
              </a>

              <img
                src={toolImages[tool.id].src}
                alt=""
                width={96}
                height={96}
                class="h-16 w-16 object-contain"
                loading="lazy"
              />
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- The Intake Insights -->
    <div>
      <!-- Header: THE pill + intake + subtitle on left, "The Intake" link on right -->
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap items-baseline gap-2">
          <span class="rounded-full bg-tebra-700 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider text-white">The</span>
          <h3 class="text-2xl font-semibold tracking-tight text-tebra-700 lg:text-3xl">intake</h3>
          <span class="text-base text-gray-500">Insights for independent healthcare practices</span>
        </div>
        <a
          href="/theintake"
          class="inline-flex items-center gap-1.5 text-base font-semibold text-tebra-700 hover:text-tebra-600 focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-offset-2 rounded"
        >
          The Intake
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path d="M8.22 6.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L11.94 11H4.75A.75.75 0 0 1 4 10.25v-4.5a.75.75 0 0 1 1.5 0v5.69l2.22-2.22a.75.75 0 0 1 1.06 0Z" />
            <path d="M2.5 3.25a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5H4.09l6.22 6.22a.75.75 0 1 1-1.06 1.06L3 4.56v2.69a.75.75 0 0 1-1.5 0v-4.5Z" />
          </svg>
        </a>
      </div>

      <!-- Article cards: ~230px width, 20–25px gap, 12px 16px padding, rounded corners -->
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
        {intakeArticles.map((article) => (
          <a
            href={article.href}
            class="group flex min-h-[72px] min-w-0 items-start gap-2 rounded-xl border border-gray-200 bg-white px-4 py-3 transition-all duration-200 hover:border-tebra-200 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-offset-2 sm:min-w-[220px]"
          >
            <span class="min-w-0 flex-1 text-[15px] font-medium leading-snug text-tebra-700 group-hover:text-tebra-600">
              {article.title}
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="mt-0.5 w-4 h-4 flex-shrink-0 text-gray-400 group-hover:text-tebra-600" aria-hidden="true">
              <path d="M8.22 6.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L11.94 11H4.75A.75.75 0 0 1 4 10.25v-4.5a.75.75 0 0 1 1.5 0v5.69l2.22-2.22a.75.75 0 0 1 1.06 0Z" />
              <path d="M2.5 3.25a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5H4.09l6.22 6.22a.75.75 0 1 1-1.06 1.06L3 4.56v2.69a.75.75 0 0 1-1.5 0v-4.5Z" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
