---
import { practiceTools, intakeArticles } from '../../data/practiceTools';
import ehrImage from '../../assets/ehr.webp';
import graderImage from '../../assets/grader.webp';
import competitiveImage from '../../assets/competitive.webp';

const toolImages: Record<string, ImageMetadata> = {
  'ehr-calculator': ehrImage,
  'billing-calculator': graderImage,
  'competitive-scanner': competitiveImage,
};
---
<section id="practice-tools" class="bg-white py-16 lg:py-24">
  <div class="page-container">
    <!-- Practice Management Tools heading -->
    <h2 class="text-3xl font-semibold tracking-tight text-gray-900 lg:text-4xl">
      Practice Management Tools
    </h2>

    <!-- Three cards -->
    <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {practiceTools.map((tool) => (
        <a
          href={tool.ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class={`
            group relative flex min-h-[320px] flex-col overflow-hidden rounded-2xl p-8 transition-all duration-300 ease-out lg:min-h-[360px] lg:p-10
            hover:shadow-xl hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-offset-2
            ${tool.variant === 'white'
              ? 'bg-white text-gray-900 shadow-md border border-gray-100 hover:border-gray-200 focus:ring-gray-900'
              : tool.variant === 'coral'
                ? 'bg-btn-primary text-white shadow-md border border-btn-primary hover:bg-btn-primary-hover focus:ring-btn-primary'
                : 'bg-tebra-700 text-white shadow-md border border-tebra-700 hover:bg-tebra-600 focus:ring-tebra-700'
            }
          `}
        >
          <h3 class="text-xl font-semibold tracking-tight lg:text-[22px]">
            {tool.title}
          </h3>
          <p class={`mt-4 flex-1 text-base leading-relaxed lg:text-[17px] ${tool.variant === 'white' ? 'text-gray-600' : 'text-white/95'}`}>
            {tool.description}
          </p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-base font-semibold">
            {tool.ctaLabel}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class={`w-4 h-4 flex-shrink-0 ${tool.variant === 'white' ? 'text-gray-700 group-hover:text-gray-900' : 'text-white'}`} aria-hidden="true">
              <path d="M8.22 6.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L11.94 11H4.75A.75.75 0 0 1 4 10.25v-4.5a.75.75 0 0 1 1.5 0v5.69l2.22-2.22a.75.75 0 0 1 1.06 0Z" />
              <path d="M2.5 3.25a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5H4.09l6.22 6.22a.75.75 0 1 1-1.06 1.06L3 4.56v2.69a.75.75 0 0 1-1.5 0v-4.5Z" />
            </svg>
          </span>
          <div class="absolute right-6 bottom-6 flex h-24 w-24 items-center justify-center overflow-hidden rounded-lg opacity-90 sm:h-28 sm:w-28 lg:right-8 lg:bottom-8 lg:h-32 lg:w-32" aria-hidden="true">
            <img
              src={toolImages[tool.id].src}
              alt=""
              width={128}
              height={128}
              class="h-24 w-24 object-contain sm:h-28 sm:w-28 lg:h-32 lg:w-32"
              loading="lazy"
            />
          </div>
        </a>
      ))}
    </div>

    <!-- The Intake Insights -->
    <div class="mt-16 lg:mt-20">
      <!-- Header: THE pill + intake + subtitle on left, "The Intake" link on right -->
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap items-baseline gap-2">
          <span class="rounded-full bg-tebra-700 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider text-white">The</span>
          <h3 class="text-2xl font-semibold tracking-tight text-tebra-700 lg:text-3xl">intake</h3>
          <span class="text-base text-gray-500">Insights for independent healthcare practices</span>
        </div>
        <a
          href="https://www.tebra.com/theintake"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-base font-semibold text-tebra-700 hover:text-tebra-600 focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-offset-2 rounded"
        >
          The Intake
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path d="M8.22 6.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L11.94 11H4.75A.75.75 0 0 1 4 10.25v-4.5a.75.75 0 0 1 1.5 0v5.69l2.22-2.22a.75.75 0 0 1 1.06 0Z" />
            <path d="M2.5 3.25a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5H4.09l6.22 6.22a.75.75 0 1 1-1.06 1.06L3 4.56v2.69a.75.75 0 0 1-1.5 0v-4.5Z" />
          </svg>
        </a>
      </div>

      <!-- Article cards: ~230px width, 20–25px gap, 12px 16px padding, rounded corners -->
      <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
        {intakeArticles.map((article) => (
          <a
            href={article.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex min-h-[72px] min-w-0 items-start gap-2 rounded-xl border border-gray-200 bg-white px-4 py-3 transition-all duration-200 hover:border-tebra-200 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-offset-2 sm:min-w-[220px]"
          >
            <span class="min-w-0 flex-1 text-[15px] font-medium leading-snug text-tebra-700 group-hover:text-tebra-600">
              {article.title}
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="mt-0.5 w-4 h-4 flex-shrink-0 text-gray-400 group-hover:text-tebra-600" aria-hidden="true">
              <path d="M8.22 6.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L11.94 11H4.75A.75.75 0 0 1 4 10.25v-4.5a.75.75 0 0 1 1.5 0v5.69l2.22-2.22a.75.75 0 0 1 1.06 0Z" />
              <path d="M2.5 3.25a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5H4.09l6.22 6.22a.75.75 0 1 1-1.06 1.06L3 4.56v2.69a.75.75 0 0 1-1.5 0v-4.5Z" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
