---
interface Props {
  title: string;
  subtitle: string;
  /** 0–100 approximate position of the dot on the inner progress bar */
  innerProgressPercent?: number;
}

const { title, subtitle, innerProgressPercent = 12 } = Astro.props as Props;
---

<div
  class="relative overflow-hidden rounded-3xl border border-gray-100 bg-white p-6 shadow-md sm:p-8 lg:p-10"
>
  <div class="space-y-2">
    <h1
      class="font-display text-2xl font-bold leading-tight tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-[1.75rem] lg:leading-snug"
      style="text-transform: lowercase;"
    >
      {title}
    </h1>
    <p class="text-sm leading-relaxed text-gray-600 sm:text-base">
      {subtitle}
    </p>
  </div>

  <div class="mt-8 space-y-8">
    <slot />
  </div>

  <div class="mt-10 border-t border-gray-100 pt-6">
    <div class="relative h-1 rounded-full bg-gray-100">
      <span
        class="absolute top-1/2 h-3 w-3 -translate-y-1/2 rounded-full bg-tebra-teal-dark shadow-sm ring-2 ring-white"
        style={`left: calc(${innerProgressPercent}% - 6px);`}
        aria-hidden="true"
      />
    </div>
  </div>
</div>
