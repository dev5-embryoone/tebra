---
import type { EhrCalculatorStep } from "../../data/ehrCalculator";

interface Props {
  steps: EhrCalculatorStep[];
  /** 1-based current step */
  currentStep: number;
}

const { steps, currentStep } = Astro.props as Props;
---

<nav
  class="w-full border-b border-gray-200/60 bg-white/80 backdrop-blur-sm"
  aria-label="Calculator progress"
>
  <div class="mx-auto max-w-[1200px] px-4 py-6 sm:px-6 lg:px-12">
    <ol
      class="flex snap-x snap-mandatory items-start gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] sm:items-center sm:gap-0 sm:overflow-visible sm:pb-0 [&::-webkit-scrollbar]:hidden"
    >
      {
        steps.map((s, index) => {
          const isActive = s.step === currentStep;
          const isPast = s.step < currentStep;
          const showConnector = index < steps.length - 1;
          return (
            <>
              <li class="flex w-[4.75rem] shrink-0 snap-center flex-col items-center gap-2 sm:w-auto sm:min-w-0 sm:flex-none">
                <a
                  href={s.href}
                  class:list={[
                    "flex h-9 w-9 items-center justify-center rounded-full text-sm font-bold transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-tebra-teal focus-visible:ring-offset-2",
                    isActive && "bg-tebra-teal-dark text-white",
                    !isActive &&
                      !isPast &&
                      "border border-gray-200 bg-gray-100 text-gray-400",
                    !isActive &&
                      isPast &&
                      "border border-tebra-teal/30 bg-tebra-hero-bg text-tebra-teal-dark",
                  ]}
                  aria-current={isActive ? "step" : undefined}
                >
                  {s.step}
                </a>
                <span
                  class:list={[
                    "text-center text-[10px] font-semibold leading-tight sm:max-w-[5rem] sm:text-xs",
                    isActive && "text-tebra-teal-dark",
                    !isActive && "text-gray-400",
                  ]}
                >
                  {s.label}
                </span>
              </li>
              {showConnector && (
                <li
                  class="hidden h-9 min-w-[0.75rem] flex-1 items-center self-start pt-0 sm:flex sm:min-w-[1rem] sm:px-1 lg:px-3"
                  aria-hidden="true"
                >
                  <span class="block h-px w-full bg-gray-200" />
                </li>
              )}
            </>
          );
        })
      }
    </ol>
  </div>
</nav>
