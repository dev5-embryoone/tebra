---
interface Props {
  label: string;
  name: string;
  id?: string;
  placeholder?: string;
  type?: "text" | "number";
  min?: number;
  required?: boolean;
  /** Extra classes on the input */
  inputClass?: string;
}

const {
  label,
  name,
  id = name,
  placeholder,
  type = "text",
  min,
  required = false,
  inputClass = "",
} = Astro.props as Props;
---

<div class="space-y-2">
  <label for={id} class="block text-sm font-semibold text-tebra-teal-dark">
    {label}
  </label>
  <input
    type={type}
    name={name}
    id={id}
    placeholder={placeholder}
    min={min}
    required={required}
    class:list={[
      "w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-tebra-teal focus:outline-none focus:ring-2 focus:ring-tebra-teal/20",
      inputClass,
    ]}
  />
</div>
