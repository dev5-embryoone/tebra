---
interface Props {
  variant: "notes" | "reviews" | "insights";
}

const { variant } = Astro.props as Props;
---

<div class="rounded-2xl border border-white/10 bg-white p-4 shadow-2xl ring-1 ring-black/5 sm:p-6">
  {
    variant === "notes" && (
      <>
        <div class="flex items-center gap-3 border-b border-gray-100 pb-4">
          <div class="h-12 w-12 shrink-0 overflow-hidden rounded-full bg-gray-200" />
          <div>
            <p class="text-sm font-semibold text-gray-900">Stephan Cur</p>
            <p class="text-xs text-gray-500">Visit today · AI Note Assist</p>
          </div>
        </div>
        <div class="mt-4 space-y-2">
          <div class="h-2 max-w-[280px] rounded bg-gray-100" style="width: 75%;" />
          <div class="h-2 w-full max-w-sm rounded bg-gray-100" />
          <div class="h-2 w-5/6 max-w-[300px] rounded bg-gray-100" />
          <div class="mt-4 rounded-lg bg-tebra-hero-bg p-3">
            <p class="text-xs font-semibold text-tebra-teal-dark">SOAP — draft</p>
            <p class="mt-2 text-xs leading-relaxed text-gray-600">
              Subjective: Patient reports… Objective: Vitals stable… Assessment: … Plan: …
            </p>
          </div>
        </div>
      </>
    )
  }

  {
    variant === "reviews" && (
      <>
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Review reply</p>
        <p class="mt-3 text-sm font-medium text-gray-900">Google review · 5 stars</p>
        <p class="mt-2 text-sm leading-relaxed text-gray-600">“Great experience from check-in to follow-up.”</p>
        <div class="mt-4 rounded-lg border border-gray-100 bg-gray-50 p-3">
          <p class="text-xs font-semibold text-tebra-teal-dark">Suggested reply (HIPAA-safe)</p>
          <p class="mt-2 text-xs leading-relaxed text-gray-700">
            Thank you for sharing your experience — we’re glad our team could make your visit smooth from start to finish.
          </p>
        </div>
      </>
    )
  }

  {
    variant === "insights" && (
      <>
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Themes · last 90 days</p>
        <div class="mt-4 space-y-3">
          <div class="flex items-center justify-between text-xs">
            <span class="font-medium text-gray-800">Scheduling</span>
            <span class="text-tebra-teal-dark">32%</span>
          </div>
          <div class="h-2 w-full overflow-hidden rounded-full bg-gray-100">
            <div class="h-full w-[32%] rounded-full bg-tebra-teal" />
          </div>
          <div class="flex items-center justify-between text-xs">
            <span class="font-medium text-gray-800">Wait times</span>
            <span class="text-tebra-teal-dark">18%</span>
          </div>
          <div class="h-2 w-full overflow-hidden rounded-full bg-gray-100">
            <div class="h-full w-[18%] rounded-full bg-tebra-orange" />
          </div>
          <div class="mt-2 flex gap-2">
            <span class="rounded-full bg-emerald-50 px-2 py-1 text-[10px] font-semibold text-emerald-800">Sentiment ↑</span>
            <span class="rounded-full bg-gray-100 px-2 py-1 text-[10px] font-semibold text-gray-600">12 new themes</span>
          </div>
        </div>
      </>
    )
  }
</div>
