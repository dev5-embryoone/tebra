---
/**
 * Decorative hero collage — layered shapes + UI cards (no external image required).
 * Scales down on small screens; matches EmbryoOne /ai feel.
 */
---

<div class="relative mx-auto w-full max-w-xl lg:max-w-none">
  <!-- Soft background blobs -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -right-4 top-4 h-72 w-72 rounded-[2.5rem] bg-[#E8F3F0] opacity-90 sm:h-80 sm:w-80"></div>
    <div class="absolute -left-6 bottom-8 h-64 w-64 rounded-[2rem] bg-gray-100 sm:h-72 sm:w-72"></div>
  </div>

  <!-- Floating badges -->
  <div class="absolute -left-2 top-0 z-20 sm:left-0">
    <span class="inline-block rounded-full bg-tebra-teal-dark px-3 py-1 text-xs font-semibold text-white shadow-md"> AI Reviews </span>
  </div>
  <div class="absolute right-0 top-12 z-20 sm:right-4">
    <span class="inline-block rounded-full bg-tebra-teal-dark px-3 py-1 text-xs font-semibold text-white shadow-md"> AI Note Assist </span>
  </div>
  <div class="absolute bottom-24 left-2 z-20 sm:bottom-28 sm:left-6">
    <span class="inline-block rounded-full bg-tebra-teal-dark px-3 py-1 text-xs font-semibold text-white shadow-md"> AI Insights </span>
  </div>

  <!-- Card stack -->
  <div class="relative pt-10 sm:pt-12">
    <!-- Back card: reviews summary -->
    <div
      class="relative z-10 mx-auto w-[92%] rounded-2xl border border-gray-200/80 bg-white p-4 shadow-lg sm:w-[88%] sm:p-5"
      style="transform: rotate(-2deg);"
    >
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Patient reviews summary</p>
      <div class="mt-3 flex items-start gap-3">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-tebra-hero-bg text-sm font-bold text-tebra-teal-dark">
          PS
        </div>
        <div class="min-w-0 flex-1">
          <p class="truncate text-sm font-semibold text-gray-900">Dr. Pravin Shak…</p>
          <p class="mt-0.5 text-xs text-amber-500">★★★★★ <span class="text-gray-600">4.9 average</span></p>
        </div>
      </div>
    </div>

    <!-- Front card: new activity / reply -->
    <div
      class="relative z-20 -mt-8 mx-auto w-full max-w-md rounded-2xl border border-gray-200 bg-white p-4 shadow-xl sm:-mt-10 sm:p-5"
      style="transform: rotate(1.5deg);"
    >
      <div class="flex items-center justify-between gap-2">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">New activity</p>
        <span class="rounded-full bg-tebra-hero-bg px-2 py-0.5 text-[10px] font-semibold text-tebra-teal-dark">EmbryoOne AI</span>
      </div>
      <p class="mt-3 text-sm font-medium text-gray-900">Tyler M.</p>
      <p class="mt-1 text-xs leading-relaxed text-gray-600">
        “Friendly staff and short wait time. Would recommend.”
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <button
          type="button"
          class="rounded-full border border-tebra-teal px-3 py-1.5 text-xs font-semibold text-tebra-teal"
        >
          Reply
        </button>
        <button
          type="button"
          class="rounded-full bg-tebra-orange px-3 py-1.5 text-xs font-semibold text-white"
        >
          Send
        </button>
      </div>
    </div>

    <!-- Small insights chip -->
    <div
      class="relative z-30 -mt-4 ml-auto mr-2 w-[min(100%,280px)] rounded-xl border border-gray-200 bg-white p-3 shadow-md sm:mr-6"
    >
      <p class="text-xs font-semibold text-tebra-teal-dark">AI Insights</p>
      <p class="mt-1 text-xs text-gray-600">“Thorough” — recurring theme this month</p>
      <div class="mt-2 flex gap-2">
        <span class="rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-medium text-emerald-800">Positive</span>
        <span class="rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-600">Watch</span>
      </div>
    </div>
  </div>
</div>
