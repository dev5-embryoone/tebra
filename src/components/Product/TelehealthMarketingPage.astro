---
import FeatureSplitHero from "../Layout/FeatureSplitHero.astro";
import PageSection from "../Layout/PageSection.astro";
import ProductPageBreadcrumb from "../PatientExperience/ProductPageBreadcrumb.astro";
import ProductTrustBand from "./ProductTrustBand.astro";
import ProductAlternatingFeature from "./ProductAlternatingFeature.astro";
import ProductEhrSavingsTeaser from "./ProductEhrSavingsTeaser.astro";
import ProductResourceCardGrid from "./ProductResourceCardGrid.astro";
import ProductDiscoverCtaBand from "./ProductDiscoverCtaBand.astro";
import CTASection from "../Sections/CTASection.astro";

import heroImg from "../../assets/Hero-2-scaled-v2.jpg";
import tourImg from "../../assets/ehrpage.webp";
import feat0 from "../../assets/patient-experience.webp";
import feat1 from "../../assets/ehrpage.webp";
import feat2 from "../../assets/Product-Graphic@2x-768x768.webp";
import feat3 from "../../assets/Payments-1-Hero-Image.webp";
import feat4 from "../../assets/Challenge-Solution-Results_1112x1112.webp";
import feat5 from "../../assets/BILLING-PAYMENTS-min.webp";
import feat6 from "../../assets/Build-trust.webp";
import feat7 from "../../assets/EHR-min.webp";
import g2Logo from "../../assets/G2-Easiest-to-Use-1.webp";
import capterraLogo from "../../assets/capterra-logo.webp";

import {
  thBreadcrumb,
  thHero,
  thHowItWorks,
  thTrust,
  thFeaturesIntro,
  thFeatures,
  thSavings,
  thResources,
  thFaq,
  thDiscoverCta,
  thBottomCta,
} from "../../data/telehealthPage";

const heroSrc = typeof heroImg === "string" ? heroImg : heroImg.src;
const tourSrc = typeof tourImg === "string" ? tourImg : tourImg.src;
const featureSrcs = [feat0, feat1, feat2, feat3, feat4, feat5, feat6, feat7].map((im) =>
  typeof im === "string" ? im : im.src
);
const g2Src = typeof g2Logo === "string" ? g2Logo : g2Logo.src;
const capterraSrc = typeof capterraLogo === "string" ? capterraLogo : capterraLogo.src;

const trustBadges = thTrust.badges.map((b, i) => ({
  title: b.title,
  subtitle: b.subtitle,
  logoSrc: i === 0 ? g2Src : i === 1 ? capterraSrc : undefined,
  logoAlt: i === 0 ? "G2" : i === 1 ? "Capterra" : undefined,
}));
---

<div>
  <div class="bg-tebra-hero-bg">
    <div class="page-container pb-2 pt-8">
      <ProductPageBreadcrumb items={[...thBreadcrumb]} />
    </div>
  </div>

  <FeatureSplitHero class="bg-tebra-hero-bg" align="center" pyClass="pb-16 pt-4 lg:pb-24 lg:pt-2">
    <div slot="left" class="space-y-5 lg:space-y-6">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">{thHero.eyebrow}</p>
      <h1 class="font-display text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.65rem] lg:leading-[1.12]">
        {thHero.title}
      </h1>
      <p class="max-w-xl text-base leading-relaxed text-gray-600 sm:text-lg">
        {thHero.subtitle}
      </p>
      <div class="flex flex-col gap-3 pt-1 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
        <a
          href={thHero.primaryCta.href}
          class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[#ff5a49]"
        >
          {thHero.primaryCta.label}
        </a>
        <a
          href={thHero.secondaryCta.href}
          class="inline-flex min-h-[44px] items-center justify-center gap-2 rounded-full border border-tebra-teal bg-white px-6 py-3 text-sm font-semibold text-tebra-teal transition-colors hover:bg-white/80"
        >
          {thHero.secondaryCta.variant === "play" && (
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-tebra-teal/10 text-tebra-teal-dark" aria-hidden="true">
              <svg class="ml-0.5 h-3.5 w-3.5" viewBox="0 0 12 14" fill="currentColor">
                <path d="M0 0v14l12-7L0 0z" />
              </svg>
            </span>
          )}
          {thHero.secondaryCta.label}
        </a>
      </div>
    </div>
    <div slot="right" class="flex justify-center lg:justify-end">
      <div class="w-full max-w-xl rounded-3xl border border-gray-200/80 bg-gray-100/80 p-4 shadow-inner sm:p-6">
        <img
          src={heroSrc}
          alt="Healthcare provider using Tebra telehealth and practice software"
          class="h-auto w-full rounded-2xl object-cover object-center shadow-md"
          loading="eager"
          width={720}
          height={540}
        />
      </div>
    </div>
  </FeatureSplitHero>

  <ProductTrustBand headline={thTrust.headline} badges={trustBadges} />

  <PageSection variant="muted" class="!py-14 lg:!py-20">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-tebra-teal-dark/85">{thHowItWorks.eyebrow}</p>
    <h2 class="mx-auto mt-3 max-w-3xl text-center text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-4xl">
      {thHowItWorks.title}
    </h2>
    <div class="mx-auto mt-10 max-w-5xl overflow-hidden rounded-2xl border border-gray-200 bg-white p-3 shadow-lg sm:p-4 lg:mt-12">
      <div class="relative aspect-[16/10] w-full overflow-hidden rounded-xl bg-gray-100">
        <img
          src={tourSrc}
          alt="Tebra dashboard — schedule and telehealth workflow"
          class="h-full w-full object-cover object-top"
          loading="lazy"
        />
        <div class="absolute inset-0 flex items-center justify-center bg-tebra-teal-dark/20 p-4">
          <a
            href={thHowItWorks.modalCta.href}
            class="inline-flex max-w-sm flex-col items-center gap-3 rounded-2xl bg-[#FDF8F3] px-6 py-6 text-center shadow-xl ring-1 ring-black/5 sm:px-8"
          >
            <span class="font-display text-base font-semibold text-tebra-teal-dark sm:text-lg">{thHowItWorks.modalTitle}</span>
            <span class="text-sm text-gray-600">{thHowItWorks.modalBody}</span>
            <span
              class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-tebra-teal px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-tebra-teal-dark"
            >
              {thHowItWorks.modalCta.label}
            </span>
          </a>
        </div>
      </div>
    </div>
    <p class="mx-auto mt-8 max-w-2xl text-center text-sm leading-relaxed text-gray-600 sm:text-base">{thHowItWorks.subcopy}</p>
    <div class="mt-8 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <a
        href={thHowItWorks.primaryCta.href}
        class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#ff5a49]"
      >
        {thHowItWorks.primaryCta.label}
      </a>
      <a
        href={thHowItWorks.secondaryCta.href}
        class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-tebra-teal bg-white px-6 py-3 text-sm font-semibold text-tebra-teal transition-colors hover:bg-gray-50"
      >
        {thHowItWorks.secondaryCta.label}
      </a>
    </div>
  </PageSection>

  <PageSection variant="default" class="!py-16 lg:!py-24" id="features">
    <h2 class="mx-auto max-w-4xl text-center font-display text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.25rem]">
      {thFeaturesIntro.title}
    </h2>
    <div class="mt-14 space-y-16 lg:mt-20 lg:space-y-24">
      {
        thFeatures.map((f, i) => (
          <ProductAlternatingFeature
            title={f.title}
            body={f.body}
            imageSrc={featureSrcs[i] ?? featureSrcs[0]}
            imageAlt={`${f.title} — Tebra telehealth`}
            reverse={i % 2 === 1}
            ctaLabel={f.ctaLabel}
            ctaHref={f.ctaHref}
          />
        ))
      }
    </div>
  </PageSection>

  <ProductEhrSavingsTeaser
    title={thSavings.title}
    subtitle={thSavings.subtitle}
    tickLabels={thSavings.tickLabels}
    ctaLabel={thSavings.ctaLabel}
    ctaHref={thSavings.ctaHref}
    id="telehealth-ehr-savings"
  />

  <ProductResourceCardGrid headline={thResources.headline} items={thResources.items} />

  <PageSection variant="default" class="!py-14 lg:!py-20">
    <div class="mx-auto w-full max-w-2xl">
      <h2 class="text-center text-xl font-semibold text-tebra-teal-dark sm:text-2xl">Frequently asked questions</h2>
      <div class="mt-8 space-y-3">
        {
          thFaq.map((item) => (
            <details class="group rounded-xl border border-gray-200 bg-white px-4 py-3 shadow-sm open:shadow-md sm:px-5 sm:py-4">
              <summary class="cursor-pointer list-none text-left text-sm font-semibold text-tebra-teal-dark sm:text-base [&::-webkit-details-marker]:hidden">
                <span class="flex items-center justify-between gap-2">
                  {item.q}
                  <span class="text-tebra-orange transition-transform group-open:rotate-45" aria-hidden="true">
                    +
                  </span>
                </span>
              </summary>
              <p class="mt-3 border-t border-gray-100 pt-3 text-sm leading-relaxed text-gray-600">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </PageSection>

  <ProductDiscoverCtaBand
    title={thDiscoverCta.title}
    description={thDiscoverCta.description}
    primaryCta={thDiscoverCta.primaryCta}
    secondaryCta={thDiscoverCta.secondaryCta}
  />

  <CTASection
    title={thBottomCta.title}
    description={thBottomCta.description}
    primaryCtaLabel={thBottomCta.primaryCtaLabel}
    primaryCtaHref={thBottomCta.primaryCtaHref}
    secondaryCtaLabel={thBottomCta.secondaryCtaLabel}
    secondaryCtaHref={thBottomCta.secondaryCtaHref}
  />
</div>
