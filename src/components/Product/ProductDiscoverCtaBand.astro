---
/**
 * Centered headline + subcopy + primary/secondary CTAs (e.g. before footer CTA strip).
 */
interface Props {
  title: string;
  description: string;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
}

const { title, description, primaryCta, secondaryCta } = Astro.props as Props;
---

<section class="border-t border-gray-100 bg-white py-14 lg:py-16" aria-labelledby="discover-cta-heading">
  <div class="page-container text-center">
    <h2 id="discover-cta-heading" class="mx-auto max-w-2xl text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl">
      {title}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-gray-600 sm:text-lg">
      {description}
    </p>
    <div class="mt-8 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <a
        href={primaryCta.href}
        class="inline-flex min-h-[48px] items-center justify-center rounded-full bg-tebra-orange px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#ff5a49]"
      >
        {primaryCta.label}
      </a>
      <a
        href={secondaryCta.href}
        class="inline-flex min-h-[48px] items-center justify-center rounded-full border border-tebra-teal bg-white px-8 py-3 text-sm font-semibold text-tebra-teal transition-colors hover:bg-gray-50"
      >
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>
