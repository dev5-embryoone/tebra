---
/**
 * Alternating image + title/subtitle + checkmark list — for Patient Portal-style feature bands.
 */
interface Props {
  title: string;
  subtitle: string;
  bullets: readonly string[] | string[];
  imageSrc: string;
  imageAlt: string;
  reverse?: boolean;
}

const { title, subtitle, bullets, imageSrc, imageAlt, reverse = false } = Astro.props as Props;

const imgOrder = reverse ? "lg:order-1" : "lg:order-2";
const textOrder = reverse ? "lg:order-2" : "lg:order-1";
---

<div class="grid gap-8 lg:grid-cols-2 lg:items-center lg:gap-12 lg:gap-x-16">
  <div class:list={["order-1", imgOrder]}>
    <img
      src={imageSrc}
      alt={imageAlt}
      class="w-full rounded-2xl border border-gray-200 bg-gray-50 shadow-lg object-cover"
      loading="lazy"
      width={800}
      height={560}
    />
  </div>
  <div class:list={["order-2 space-y-4", textOrder]}>
    <h3 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl">{title}</h3>
    <p class="text-base font-medium text-tebra-teal sm:text-lg">{subtitle}</p>
    <ul class="mt-2 space-y-3 text-base leading-relaxed text-gray-600">
      {
        bullets.map((b) => (
          <li class="flex gap-3">
            <span class="mt-0.5 shrink-0 text-tebra-teal" aria-hidden="true">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"
                />
              </svg>
            </span>
            <span>{b}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
