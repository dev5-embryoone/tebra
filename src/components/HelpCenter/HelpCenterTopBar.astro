---
import { helpCenterAnnouncement, helpCenterNav } from "../../data/helpCenterPage";
import logoPng from "../../assets/logo.png?url";
import logoSvg from "../../assets/logo.svg?url";
---

<div class="border-b border-gray-200 bg-gray-50 text-sm text-gray-800">
  <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="leading-snug">{helpCenterAnnouncement.text}</p>
    <a
      href={helpCenterAnnouncement.href}
      class="shrink-0 font-semibold text-tebra-teal-dark underline decoration-2 underline-offset-2 hover:text-tebra-teal"
    >
      {helpCenterAnnouncement.cta}
    </a>
  </div>
</div>

<header class="sticky top-0 z-30 border-b border-neutral-200 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-2" aria-label="EmbryoOne home">
      <picture>
        <source srcSet={logoSvg} type="image/svg+xml" />
        <img src={logoPng} alt="EmbryoOne" class="h-8 w-auto object-contain" />
      </picture>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Help center">
      {
        helpCenterNav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm font-medium transition-colors",
              item.current ? "text-tebra-teal-dark font-semibold" : "text-gray-700 hover:text-tebra-teal-dark",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/sign-in"
        class="rounded-full border-2 border-tebra-teal-dark px-4 py-1.5 text-sm font-semibold text-tebra-teal-dark transition-colors hover:bg-tebra-teal-dark hover:text-white"
      >
        Sign in
      </a>
    </nav>

    <details class="relative md:hidden">
      <summary class="cursor-pointer list-none rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-tebra-teal-dark">
        Menu
      </summary>
      <div class="absolute right-0 mt-2 w-52 rounded-lg border border-neutral-200 bg-white py-2 shadow-lg">
        {
          helpCenterNav.map((item) => (
            <a href={item.href} class="block px-4 py-2 text-sm text-gray-800 hover:bg-gray-50">
              {item.label}
            </a>
          ))
        }
        <a href="/sign-in" class="block px-4 py-2 text-sm font-semibold text-tebra-teal-dark hover:bg-gray-50">
          Sign in
        </a>
      </div>
    </details>
  </div>
</header>
