---
import {
  BarChart3,
  ClipboardPlus,
  HandHeart,
  HeartPulse,
  MonitorSmartphone,
  WalletCards,
} from "@lucide/astro";

interface Props {
  name: "platform" | "clinical" | "billing" | "engage" | "telehealth" | "growth";
}

const { name } = Astro.props;
const iconMap = {
  platform: MonitorSmartphone,
  clinical: ClipboardPlus,
  billing: WalletCards,
  engage: HandHeart,
  telehealth: HeartPulse,
  growth: BarChart3,
} as const;

const Icon = iconMap[name];
---

<span class="inline-flex h-20 w-20 items-center justify-center rounded-2xl bg-gray-50 text-tebra-teal-dark sm:h-24 sm:w-24" aria-hidden="true">
  <Icon class="h-10 w-10 sm:h-12 sm:w-12" />
</span>
