---
import HelpCategoryIcon from "./HelpCategoryIcon.astro";
import { helpCenterCategories } from "../../data/helpCenterPage";
---

<section class="bg-white px-4 py-14 sm:py-16" aria-labelledby="learn-more-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="learn-more-heading" class="text-center font-serif text-2xl font-bold text-[#004b50] sm:text-3xl">
      Learn More
    </h2>
    <ul class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        helpCenterCategories.map((cat) => (
          <li>
            <a
              href={cat.href}
              class="group flex h-full flex-col items-center rounded-2xl border border-neutral-200/80 bg-[#fafcfc] p-8 text-center shadow-sm transition hover:border-[#004b50]/30 hover:shadow-md"
            >
              <div class="mb-4 flex justify-center transition group-hover:scale-105">
                <HelpCategoryIcon name={cat.key} />
              </div>
              <span class="text-xs font-bold uppercase tracking-wide text-[#004b50]">{cat.title}</span>
              <p class="mt-3 text-sm leading-relaxed text-neutral-600">{cat.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
