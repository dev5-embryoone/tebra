---
import logoSrc from "../../assets/logo_tebra.ad466dee.svg?url";
import { helpCenterFooter } from "../../data/helpCenterPage";
---

<footer class="bg-[#003d42] text-white">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:py-14">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <a href="/" class="inline-block" aria-label="Tebra homepage">
          <img
            src={logoSrc}
            alt=""
            width="120"
            height="28"
            class="h-7 w-auto brightness-0 invert"
          />
        </a>
        <p class="mt-6 text-[11px] font-semibold uppercase tracking-[0.15em] text-white/85">
          {helpCenterFooter.tagline}
        </p>
        <div class="mt-3 flex flex-wrap items-center gap-2 text-lg font-bold tracking-tight text-white">
          <span>Kareo</span>
          <span class="text-white/60" aria-hidden="true">+</span>
          <span>PatientPop</span>
        </div>
      </div>

      <div>
        <h2 class="text-sm font-bold uppercase tracking-wide text-white">{helpCenterFooter.contactTitle}</h2>
        <address class="not-italic mt-3 text-sm leading-relaxed text-white/90">
          {helpCenterFooter.addressLines.map((line) => (
            <>
              {line}
              <br />
            </>
          ))}
        </address>
        <ul class="mt-6 flex flex-wrap gap-3" aria-label="Social">
          {
            helpCenterFooter.social.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex h-10 w-10 items-center justify-center rounded-full border border-white/30 text-white transition hover:bg-white/10"
                  aria-label={s.label}
                >
                  {s.icon === "facebook" && (
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M22 12a10 10 0 1 0-11.5 9.9v-7H7v-3h3.5V9.5c0-3.5 2-5.4 5.3-5.4 1.5 0 3.1.3 3.1.3v3.4h-1.8c-1.7 0-2.2 1.1-2.2 2.2V12h3.8l-.6 3h-3.2v7A10 10 0 0 0 22 12z" />
                    </svg>
                  )}
                  {s.icon === "instagram" && (
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7zm5 3.5A5.5 5.5 0 1 1 6.5 13 5.5 5.5 0 0 1 12 7.5zm0 2A3.5 3.5 0 1 0 15.5 13 3.5 3.5 0 0 0 12 9.5zM18 6.3a1.2 1.2 0 1 1-1.2 1.2 1.2 1.2 0 0 1 1.2-1.2z" />
                    </svg>
                  )}
                  {s.icon === "linkedin" && (
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V23h-4V8zm7.5 0h3.8v2h.1c.5-1 1.8-2.1 3.7-2.1 4 0 4.7 2.6 4.7 6v9h-4v-8c0-1.9 0-4.3-2.6-4.3-2.6 0-3 2-3 4.1V23h-4V8z" />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/15 pt-8">
      <p class="text-center text-xs text-white/75 sm:text-left">{helpCenterFooter.copyright}</p>
      <nav class="mt-4 flex flex-wrap justify-center gap-x-6 gap-y-2 text-xs sm:justify-start" aria-label="Legal">
        {
          helpCenterFooter.bottomLinks.map((link) => (
            <a href={link.href} class="text-white/90 underline-offset-2 hover:text-white hover:underline">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>
