---
const placeholder = "Enter a keyword, topic, or question to search";

interface Props {
  query?: string;
}

const { query = "" } = Astro.props as Props;
---

<section class="bg-tebra-teal-dark px-4 py-14 text-white sm:py-20" aria-labelledby="help-hero-heading">
  <div class="mx-auto max-w-3xl text-center">
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-white/90">EmbryoOne Help Center</p>
    <h1 id="help-hero-heading" class="font-sans text-3xl font-bold sm:text-4xl md:text-5xl">
      How can we help you?
    </h1>

    <form
      class="mx-auto mt-10 flex max-w-xl overflow-hidden rounded-full border-2 border-white/20 bg-white shadow-lg"
      role="search"
      action="/help"
      method="get"
    >
      <label for="help-search" class="sr-only">Search help center</label>
      <input
        id="help-search"
        type="search"
        name="q"
        value={query}
        placeholder={placeholder}
        class="min-w-0 flex-1 appearance-none border-0 bg-transparent px-5 py-3.5 text-sm text-neutral-900 placeholder:text-neutral-500 focus:outline-none focus:ring-0 focus:shadow-none"
      />
      <button
        type="submit"
        class="flex h-12 w-14 shrink-0 items-center justify-center bg-btn-primary text-white transition hover:bg-btn-primary-hover sm:h-auto sm:w-16"
        aria-label="Search"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="M20 20l-4-4" stroke-linecap="round" />
        </svg>
      </button>
    </form>
    <p class="mt-4 text-xs text-white/70">
      Search stays within this help center.
    </p>
  </div>
</section>

<style>
  #help-search::-webkit-search-decoration,
  #help-search::-webkit-search-cancel-button,
  #help-search::-webkit-search-results-button,
  #help-search::-webkit-search-results-decoration {
    -webkit-appearance: none;
    appearance: none;
  }
</style>

<script>
  (() => {
    const form = document.querySelector('form[role="search"][action="/help"]');
    const input = document.getElementById("help-search");
    if (!(input instanceof HTMLInputElement) || !(form instanceof HTMLFormElement)) return;

    const q = new URLSearchParams(window.location.search).get("q") ?? "";
    if (!input.value && q) input.value = q;

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const next = input.value.trim();
      const url = new URL("/help", window.location.origin);
      if (next) url.searchParams.set("q", next);
      window.location.assign(url.toString());
    });
  })();
</script>
