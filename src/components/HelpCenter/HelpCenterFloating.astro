---
const phone = "8669383272";
const phoneDisplay = "866-938-3272";
---

<div
  class="pointer-events-none fixed bottom-24 right-3 z-40 flex flex-col gap-2 sm:right-4 md:bottom-1/3"
  aria-label="Quick contact"
>
  <a
    href="/contact"
    class="pointer-events-auto flex h-11 w-11 items-center justify-center rounded border border-neutral-200 bg-white text-[#F07C65] shadow-md transition hover:bg-neutral-50"
    aria-label="Contact support"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="M3 7l9 6 9-6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
  <a
    href={`tel:+1${phone}`}
    class="pointer-events-auto flex h-11 w-11 items-center justify-center rounded border border-neutral-200 bg-white text-[#F07C65] shadow-md transition hover:bg-neutral-50"
    aria-label={`Call ${phoneDisplay}`}
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path
        d="M6.5 3h3l2 5-2.5 2.5a12 12 0 0 0 5.5 5.5L17 13l5 2v3a2 2 0 0 1-2.2 2A17 17 0 0 1 3 5.2 2 2 0 0 1 5 3z"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </a>
</div>
