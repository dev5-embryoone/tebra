---
/**
 * Tebra-style category row: large rounded #EFEEED tiles, label + external-link icon, dot pager (mobile scroll).
 */
export interface ResourceCarouselItem {
  id: string;
  label: string;
  href: string;
  illustration: "webinar" | "workbook" | "tools" | "reports" | "checklists";
}

interface Props {
  items: readonly ResourceCarouselItem[];
  webinarSrc: string;
  workbookSrc: string;
}

const { items, webinarSrc, workbookSrc } = Astro.props;

const extIcon =
  "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded border border-gray-300 text-gray-900";
---

<section class="border-b border-gray-200 bg-gray-50 py-10 lg:py-14" aria-label="Resource formats">
  <div class="page-container">
    <div class="relative">
      <div
        id="rl-cat-track"
        class="scrollbar-hide flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 md:snap-none md:justify-center md:gap-5 md:overflow-visible md:pb-0"
        style="-webkit-overflow-scrolling: touch;"
      >
        {
          items.map((item, i) => (
            <div
              class="w-[min(100%,280px)] shrink-0 snap-center first:pl-0 last:pr-0 sm:w-52 md:w-[18%] md:min-w-[160px] md:max-w-[220px]"
              data-rl-cat-slide={i}
            >
              <a href={item.href} class="group block rounded-[28px] focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-900 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-50">
                <div class="flex aspect-[5/4] items-center justify-center rounded-[28px] bg-gray-100 p-6 transition-transform duration-300 group-hover:scale-[1.02] md:aspect-[4/3]">
                  {item.illustration === "webinar" && (
                    <img src={webinarSrc} alt="" class="max-h-[7.5rem] w-auto max-w-full object-contain" width="140" height="140" loading="eager" />
                  )}
                  {item.illustration === "workbook" && (
                    <img src={workbookSrc} alt="" class="max-h-[7.5rem] w-auto max-w-full object-contain" width="140" height="140" loading="eager" />
                  )}
                  {item.illustration === "tools" && (
                    <svg class="h-28 w-28 text-tebra-teal" viewBox="0 0 120 120" fill="none" aria-hidden="true">
                      <path
                        d="M28 88h64M36 72l12-32 10 20 8-14 14 38"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <rect x="52" y="24" width="36" height="22" rx="3" stroke="#F08463" stroke-width="2.2" fill="none" />
                      <path d="M58 32h24M58 38h16" stroke="#F08463" stroke-width="2" stroke-linecap="round" />
                      <path
                        d="M24 52c8-18 28-28 48-22"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        opacity="0.5"
                      />
                    </svg>
                  )}
                  {item.illustration === "reports" && (
                    <svg class="h-28 w-28 text-tebra-teal" viewBox="0 0 120 120" fill="none" aria-hidden="true">
                      <rect x="28" y="36" width="56" height="56" rx="6" stroke="currentColor" stroke-width="2.2" fill="none" />
                      <path d="M40 52h32M40 64h24M40 76h28" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.45" />
                      <circle cx="78" cy="48" r="18" stroke="#F08463" stroke-width="2.2" fill="none" />
                      <path d="M72 48l4 4 10-10" stroke="#F08463" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  {item.illustration === "checklists" && (
                    <svg class="h-28 w-28 text-tebra-teal" viewBox="0 0 120 120" fill="none" aria-hidden="true">
                      <rect x="34" y="22" width="48" height="76" rx="6" stroke="currentColor" stroke-width="2.2" fill="none" />
                      <path d="M44 40h20M44 54h20M44 68h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.4" />
                      <path
                        d="M42 88l6 6 14-14"
                        stroke="#F08463"
                        stroke-width="2.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  )}
                </div>
                <div class="mt-4 flex items-center justify-center gap-2.5 px-1 text-center">
                  <span class="text-sm font-semibold leading-tight text-gray-900">{item.label}</span>
                  <span class={extIcon} aria-hidden="true">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none">
                      <path
                        d="M5 3h6v6M11 3L3 11"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </div>
              </a>
            </div>
          ))
        }
      </div>

      <!-- Dot indicators (mobile-first; hidden when all fit) -->
      <div
        id="rl-cat-dots"
        class="mt-6 flex justify-center gap-2 md:hidden"
        role="tablist"
        aria-label="Resource categories"
      >
        {
          items.map((_, i) => (
            <button
              type="button"
              class="rl-cat-dot h-2 rounded-full bg-gray-300 transition-all data-[active=true]:w-8 data-[active=true]:bg-gray-900"
              data-index={i}
              data-active={i === 0}
              aria-label={`Show category ${i + 1}`}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initRlCategoryCarousel() {
    const track = document.getElementById("rl-cat-track");
    const dotsWrap = document.getElementById("rl-cat-dots");
    if (!track || !dotsWrap) return;

    const dots = dotsWrap.querySelectorAll<HTMLButtonElement>(".rl-cat-dot");
    const slides = track.querySelectorAll<HTMLElement>("[data-rl-cat-slide]");

    const setActive = (index: number) => {
      const i = Math.max(0, Math.min(index, dots.length - 1));
      dots.forEach((d, j) => d.setAttribute("data-active", j === i ? "true" : "false"));
    };

    const nearestIndex = () => {
      const cx = track.getBoundingClientRect().left + track.clientWidth / 2;
      let best = 0;
      let bestDist = Infinity;
      slides.forEach((el, i) => {
        const r = el.getBoundingClientRect();
        const mid = r.left + r.width / 2;
        const d = Math.abs(mid - cx);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });
      return best;
    };

    const scrollToIndex = (i: number) => {
      const slide = slides[i];
      if (!slide) return;
      slide.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
    };

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => scrollToIndex(i));
    });

    let t: ReturnType<typeof setTimeout>;
    track.addEventListener("scroll", () => {
      clearTimeout(t);
      t = setTimeout(() => setActive(nearestIndex()), 60);
    });
    setActive(nearestIndex());
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initRlCategoryCarousel);
  } else {
    initRlCategoryCarousel();
  }
</script>
