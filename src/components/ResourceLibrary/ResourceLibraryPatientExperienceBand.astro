---
/**
 * Light gray rounded band: illustration | headline | Take a tour (Tebra resource library).
 */
interface Props {
  title: string;
  tourHref: string;
  tourLabel?: string;
}

const { title, tourHref, tourLabel = "Take a tour" } = Astro.props;
---

<section class="border-b border-[#E8E6E1] bg-white py-10 lg:py-12">
  <div class="page-container px-4 sm:px-6 lg:px-12">
    <div
      class="flex flex-col items-stretch gap-8 rounded-[24px] bg-[#EFEEED] px-6 py-10 shadow-sm sm:px-8 sm:py-12 lg:flex-row lg:items-center lg:justify-between lg:gap-10 lg:px-12 lg:py-14"
    >
      <!-- Line-art workflow -->
      <div class="flex shrink-0 justify-center lg:justify-start lg:w-[min(100%,200px)]">
        <svg class="h-36 w-44 text-[#005A57] sm:h-40 sm:w-48" viewBox="0 0 200 180" fill="none" aria-hidden="true">
          <rect x="12" y="24" width="52" height="36" rx="6" fill="#BFDBFE" stroke="currentColor" stroke-width="1.5" opacity="0.95" />
          <rect x="78" y="20" width="48" height="44" rx="6" fill="white" stroke="currentColor" stroke-width="1.5" />
          <rect x="138" y="28" width="50" height="32" rx="6" fill="#BFDBFE" stroke="currentColor" stroke-width="1.5" opacity="0.85" />
          <circle cx="102" cy="98" r="22" fill="#F08463" opacity="0.95" />
          <path d="M94 98l6 6 14-14" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M38 68h24M126 68h24M102 64v18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5" />
          <rect x="24" y="118" width="152" height="40" rx="8" fill="white" stroke="currentColor" stroke-width="1.5" />
          <path d="M40 138h40M40 146h28M120 138h48" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.35" />
        </svg>
      </div>

      <p
        class="max-w-xl flex-1 text-center font-display text-2xl font-bold leading-snug text-[#1D3533] sm:text-[1.65rem] lg:max-w-2xl lg:text-left lg:text-[1.85rem] lg:leading-tight"
      >
        {title}
      </p>

      <div class="flex shrink-0 justify-center lg:justify-end">
        <a
          href={tourHref}
          class="inline-flex items-center justify-center rounded-full border-2 border-[#1D3533] bg-white px-8 py-3 text-sm font-semibold text-[#1D3533] transition hover:bg-[#1D3533] hover:text-white"
        >
          {tourLabel}
        </a>
      </div>
    </div>
  </div>
</section>
