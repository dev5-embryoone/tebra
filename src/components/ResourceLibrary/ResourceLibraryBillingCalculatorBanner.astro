---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  cta: string;
  href: string;
}

const { eyebrow, title, description, cta, href } = Astro.props;

const extBox =
  "inline-flex h-8 w-8 shrink-0 items-center justify-center rounded border border-[#1D3533]/30 text-[#1D3533]";
---

<div
  class="overflow-hidden rounded-[24px] bg-[#F4B5A0] shadow-sm ring-1 ring-[#1D3533]/5 lg:rounded-[28px]"
  style="background: linear-gradient(135deg, #f8c4b0 0%, #f0a68c 45%, #eba082 100%);"
>
  <div class="grid items-stretch gap-8 p-8 lg:grid-cols-2 lg:gap-12 lg:p-12">
    <div class="flex flex-col justify-center">
      <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-[#1D3533]/85">{eyebrow}</p>
      <h3 class="mt-4 font-display text-3xl font-bold leading-tight text-[#1D3533] sm:text-4xl lg:text-[2.35rem] lg:leading-tight">
        {title}
      </h3>
      <p class="mt-5 max-w-lg text-base leading-relaxed text-[#1D3533]/80">{description}</p>
      <a
        href={href}
        class="mt-8 inline-flex w-fit items-center gap-3 text-base font-semibold text-[#1D3533] underline-offset-4 hover:underline"
      >
        {cta}
        <span class={extBox} aria-hidden="true">
          <svg class="h-4 w-4" viewBox="0 0 14 14" fill="none">
            <path
              d="M5 3h6v6M11 3L3 11"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </span>
      </a>
    </div>
    <div class="flex min-h-[200px] items-center justify-center lg:min-h-[260px]">
      <svg class="max-h-[220px] w-full max-w-[280px] text-[#1D3533]" viewBox="0 0 280 240" fill="none" aria-hidden="true">
        <rect x="48" y="32" width="184" height="176" rx="12" fill="white" fill-opacity="0.55" stroke="currentColor" stroke-width="1.5" />
        <rect x="72" y="56" width="136" height="20" rx="4" fill="currentColor" opacity="0.12" />
        <rect x="72" y="88" width="96" height="12" rx="3" fill="currentColor" opacity="0.1" />
        <rect x="72" y="108" width="120" height="12" rx="3" fill="currentColor" opacity="0.1" />
        <circle cx="190" cy="150" r="36" stroke="#F08463" stroke-width="2.5" fill="white" fill-opacity="0.4" />
        <circle cx="175" cy="140" r="6" fill="#005A57" />
        <circle cx="190" cy="132" r="6" fill="#005A57" />
        <circle cx="205" cy="142" r="6" fill="#005A57" />
        <path d="M175 152l10 8 20-18" stroke="#005A57" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M88 168h104" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.25" />
      </svg>
    </div>
  </div>
</div>
