---
export type ResourceLinkTile = {
  variant: "light" | "dark" | "sage";
  label: string;
  title: string;
  description: string;
  cta: string;
  href: string;
  icon: "blog" | "book" | "network";
};

interface Props {
  tiles: readonly ResourceLinkTile[];
}

const { tiles } = Astro.props;

const extBoxLight =
  "inline-flex h-8 w-8 shrink-0 items-center justify-center rounded border border-gray-300 text-gray-900";
const extBoxDark =
  "inline-flex h-8 w-8 shrink-0 items-center justify-center rounded border border-white/50 text-white";
const extBoxSage =
  "inline-flex h-8 w-8 shrink-0 items-center justify-center rounded border border-gray-400 text-gray-900";
---

<div class="mt-8 grid gap-6 md:grid-cols-3">
  {
    tiles.map((tile) => {
      const isDark = tile.variant === "dark";
      const isSage = tile.variant === "sage";
      const box = isDark ? extBoxDark : isSage ? extBoxSage : extBoxLight;
      const shell = isDark
        ? "bg-tebra-teal-dark text-white ring-1 ring-white/10"
        : isSage
          ? "bg-gray-100 text-gray-900 ring-1 ring-gray-300"
          : "bg-gray-50 text-gray-900 ring-1 ring-gray-200";
      const labelColor = isDark ? "text-[#F08463]" : "text-[#F08463]";
      const descColor = isDark ? "text-white/85" : "text-gray-600";
      const titleColor = isDark ? "text-white" : "text-gray-900";
      const linkColor = isDark ? "text-white" : "text-gray-900";

      return (
        <a
          href={tile.href}
          class:list={[
            "group flex flex-col rounded-[24px] p-8 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md lg:p-10",
            shell,
          ]}
        >
          <div class="flex items-center gap-3">
            {tile.icon === "blog" && (
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#F08463]/15 text-[#F08463]" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M6 5h9a3 3 0 013 3v11H9a3 3 0 00-3-3V5z" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M6 9h8M6 13h6" stroke-linecap="round" />
                </svg>
              </span>
            )}
            {tile.icon === "book" && (
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/15 text-white" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M4 6a2 2 0 012-2h11v16H6a2 2 0 00-2 2V6z" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M17 6h3v14h-3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            )}
            {tile.icon === "network" && (
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-900/10 text-gray-900" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <circle cx="8" cy="8" r="2.5" />
                  <circle cx="16" cy="16" r="2.5" />
                  <circle cx="17" cy="7" r="2.5" />
                  <path d="M10 9l4 5M10.5 15.5l5-6M14 8l2 5" stroke-linecap="round" />
                </svg>
              </span>
            )}
            <span class:list={["text-[11px] font-bold uppercase tracking-[0.2em]", labelColor]}>{tile.label}</span>
          </div>
          <h3 class:list={["mt-6 font-display text-2xl font-bold leading-tight sm:text-[1.65rem]", titleColor]}>{tile.title}</h3>
          <p class:list={["mt-4 flex-1 text-sm leading-relaxed", descColor]}>{tile.description}</p>
          <span class:list={["mt-8 inline-flex items-center gap-3 text-sm font-semibold", linkColor]}>
            {tile.cta}
            <span class={box} aria-hidden="true">
              <svg class="h-4 w-4" viewBox="0 0 14 14" fill="none">
                <path
                  d="M5 3h6v6M11 3L3 11"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </span>
        </a>
      );
    })
  }
</div>
