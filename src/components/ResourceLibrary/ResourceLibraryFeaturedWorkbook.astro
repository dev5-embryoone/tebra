---
/**
 * Split featured band: dark teal graphic left, light panel + Workbook pill right (Tebra practice favorites).
 */
interface Props {
  type: string;
  title: string;
  href: string;
  cta: string;
  workbookIconSrc: string;
}

const { type, title, href, cta, workbookIconSrc } = Astro.props;

const extIcon = "inline-flex h-8 w-8 shrink-0 items-center justify-center rounded border border-[#1D3533]/20 text-[#1D3533]";
---

<div class="overflow-hidden rounded-[24px] border border-[#E8E6E1] bg-white shadow-sm lg:rounded-[28px]">
  <div class="grid lg:grid-cols-2">
    <!-- Left: dark panel with grid + headline -->
    <div
      class="relative flex min-h-[220px] flex-col justify-end overflow-hidden bg-[#0d3331] p-8 text-white sm:min-h-[260px] lg:min-h-[320px] lg:p-12"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.12]"
        style="background-image: linear-gradient(rgba(255,255,255,0.7) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.7) 1px, transparent 1px); background-size: 24px 24px;"
        aria-hidden="true"
      />
      <div class="pointer-events-none absolute -right-8 -top-8 h-40 w-40 rounded-3xl border-2 border-white/15" aria-hidden="true" />
      <div class="pointer-events-none absolute bottom-12 right-10 flex gap-2 opacity-40" aria-hidden="true">
        <span class="h-10 w-10 rounded-lg border border-white/30" />
        <span class="h-10 w-10 rounded-lg border border-white/20" />
      </div>
      <p class="relative z-[1] max-w-md font-display text-2xl font-bold leading-tight tracking-tight sm:text-3xl lg:text-[1.85rem] lg:leading-snug">
        {title}
      </p>
    </div>

    <!-- Right: light panel -->
    <div class="flex flex-col justify-center bg-[#F3F2F0] p-8 lg:p-12">
      <span
        class="inline-flex w-fit rounded-md bg-sky-100 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-sky-900"
      >
        {type}
      </span>
      <h3 class="mt-5 font-display text-2xl font-bold leading-tight text-[#1D3533] sm:text-3xl">{title}</h3>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href={href}
          class="inline-flex items-center gap-3 text-base font-semibold text-[#1D3533] underline-offset-4 transition hover:underline"
        >
          {cta}
          <span class={extIcon} aria-hidden="true">
            <svg class="h-4 w-4" viewBox="0 0 14 14" fill="none">
              <path
                d="M5 3h6v6M11 3L3 11"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
        </a>
        <img
          src={workbookIconSrc}
          alt=""
          class="hidden h-14 w-auto opacity-80 sm:block lg:h-16"
          width="64"
          height="64"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</div>
