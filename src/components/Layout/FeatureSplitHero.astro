---
/**
 * Shared two-column hero (copy + visual) — same grid as EHR / feature pages.
 * Use slots "left" and "right" for content.
 */
interface Props {
  /** Section wrapper classes (background, overflow, etc.) */
  class?: string;
  /** Extra classes on the inner page-container */
  containerClass?: string;
  /** Grid alignment on large screens: center (default) or start */
  align?: "center" | "start";
  /** Vertical padding */
  pyClass?: string;
}

const {
  class: sectionClass = "bg-white",
  containerClass = "",
  align = "center",
  pyClass = "py-16 lg:py-24",
} = Astro.props as Props;

const itemsAlign = align === "start" ? "lg:items-start" : "lg:items-center";
---

<section class:list={[sectionClass, "relative"]}>
  <div class:list={["page-container", pyClass, containerClass]}>
    <div class:list={["grid gap-10 lg:gap-12 lg:grid-cols-2", itemsAlign]}>
      <slot name="left" />
      <slot name="right" />
    </div>
  </div>
</section>
