---
/**
 * Centered story hero (eyebrow + H1 + intro) — Tebra "Our Story" style.
 */
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  class?: string;
}

const { eyebrow, title, intro, class: className = "" } = Astro.props as Props;
---

<header
  class:list={[
    "mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8",
    className,
  ]}
>
  <p
    class="text-xs font-bold uppercase tracking-[0.28em] text-gray-500 sm:text-sm"
  >
    {eyebrow}
  </p>
  <h1
    class="mt-4 text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.75rem] lg:leading-[1.15]"
  >
    {title}
  </h1>
  <p
    class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg"
  >
    {intro}
  </p>
</header>
