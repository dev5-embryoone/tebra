---
import CarouselCard from "./CarouselCard.astro";
import imgCelebrations from "../../assets/Challenge-Solution-Results_1112x1112.webp";
import imgArjun from "../../assets/Arjun-scaled-e1761674709694.webp";
import imgAshley from "../../assets/4cddcadb033b11e13e8abd0c385294a2c7bb48d1.webp";
import {
  testimonialsCarouselHeader,
  testimonialsCarouselSlides,
  type CarouselSlideImageKey,
} from "../../data/testimonialsCarousel";

const imageByKey: Record<CarouselSlideImageKey, string> = {
  celebrations:
    typeof imgCelebrations === "string" ? imgCelebrations : imgCelebrations.src,
  arjun: typeof imgArjun === "string" ? imgArjun : imgArjun.src,
  ashley: typeof imgAshley === "string" ? imgAshley : imgAshley.src,
};

const slideCount = testimonialsCarouselSlides.length;
---

<section class="page-section border-t border-gray-100 bg-white">
  <div class="page-container">
    <p class="eyebrow">
      {testimonialsCarouselHeader.eyebrow}
    </p>
    <h2 class="heading-sm mt-3 text-tebra-teal-dark">
      {testimonialsCarouselHeader.title}
    </h2>
  </div>

  <div class="relative mx-auto mt-8 w-full max-w-[100vw] sm:mt-10">
    <!-- Side arrows -->
    <button
      type="button"
      class="carousel-prev absolute left-1 top-1/2 z-10 hidden -translate-y-1/2 rounded-full border border-gray-200 bg-white/95 p-2.5 text-tebra-teal-dark shadow-md transition hover:bg-tebra-hero-bg md:left-2 md:flex lg:left-4"
      aria-label="Previous slide"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <button
      type="button"
      class="carousel-next absolute right-1 top-1/2 z-10 hidden -translate-y-1/2 rounded-full border border-gray-200 bg-white/95 p-2.5 text-tebra-teal-dark shadow-md transition hover:bg-tebra-hero-bg md:right-2 md:flex lg:right-4"
      aria-label="Next slide"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <!-- Track: side padding centers first/last slide in viewport -->
    <div
      id="testimonials-carousel-track"
      class="testimonials-carousel-track scrollbar-hide flex w-full cursor-grab snap-x snap-mandatory gap-6 overflow-x-auto active:cursor-grabbing"
      style="padding-left: max(1rem, calc(50vw - min(550px, 46vw))); padding-right: max(1rem, calc(50vw - min(550px, 46vw))); scroll-padding-inline: max(1rem, calc(50vw - min(550px, 46vw)));"
    >
      {testimonialsCarouselSlides.map((slide) => (
        <CarouselCard
          textOnly={slide.textOnly}
          imageSrc={slide.imageKey ? imageByKey[slide.imageKey] : undefined}
          imageAlt={slide.imageAlt}
          title={slide.title}
          body={slide.body}
          author={slide.author}
          org={slide.org}
          ctaHref={slide.ctaHref}
          ctaLabel={slide.ctaLabel}
        />
      ))}
    </div>

    <div
      id="testimonials-carousel-dots"
      class="mt-6 flex items-center justify-center gap-2"
      aria-hidden="true"
    >
      {Array.from({ length: slideCount }, (_, i) => (
        <span
          class="carousel-dot h-1.5 w-1.5 cursor-pointer rounded-full bg-gray-300 transition-all duration-200 data-[active=true]:w-6 data-[active=true]:bg-tebra-teal-dark"
          data-active={i === 0}
          data-index={i}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-carousel-track {
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
    user-select: none;
  }
  .testimonials-carousel-track :global(img) {
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
  .testimonials-carousel-track :global(a) {
    cursor: pointer;
  }
</style>

<script>
  function initTestimonialsCarousel() {
    const track = document.getElementById("testimonials-carousel-track");
    const dotsWrap = document.getElementById("testimonials-carousel-dots");
    const prevBtn = document.querySelector(".carousel-prev");
    const nextBtn = document.querySelector(".carousel-next");
    if (!track || !dotsWrap) return;

    const dots = dotsWrap.querySelectorAll(".carousel-dot");
    const slides = track.querySelectorAll(":scope > article");

    function viewportCenterX() {
      const r = track.getBoundingClientRect();
      return r.left + track.clientWidth / 2;
    }

    function getNearestIndex() {
      const cx = viewportCenterX();
      let best = 0;
      let bestDist = Infinity;
      slides.forEach((slide, i) => {
        const r = slide.getBoundingClientRect();
        const mid = r.left + r.width / 2;
        const d = Math.abs(mid - cx);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });
      return best;
    }

    function setActiveDot(index: number) {
      const i = Math.max(0, Math.min(index, dots.length - 1));
      dots.forEach((d, j) => {
        d.setAttribute("data-active", j === i ? "true" : "false");
      });
    }

    function scrollToSlide(index: number) {
      const slide = slides[index];
      if (!slide) return;
      slide.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
    }

    function snapToNearestCenter() {
      const i = getNearestIndex();
      scrollToSlide(i);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => scrollToSlide(i));
    });

    prevBtn?.addEventListener("click", () => {
      const i = getNearestIndex();
      scrollToSlide(Math.max(0, i - 1));
    });
    nextBtn?.addEventListener("click", () => {
      const i = getNearestIndex();
      scrollToSlide(Math.min(slides.length - 1, i + 1));
    });

    function updateDotFromScroll() {
      setActiveDot(getNearestIndex());
    }

    let scrollEndTimer: ReturnType<typeof setTimeout>;
    track.addEventListener("scroll", () => {
      updateDotFromScroll();
      clearTimeout(scrollEndTimer);
      scrollEndTimer = setTimeout(updateDotFromScroll, 80);
    });
    updateDotFromScroll();

    let dragStartX = 0;
    let scrollStart = 0;
    let dragging = false;
    let dragMoved = false;
    const DRAG_THRESHOLD = 8;

    track.addEventListener("pointerdown", (e) => {
      if (e.pointerType === "mouse" && e.button !== 0) return;
      dragging = true;
      dragMoved = false;
      dragStartX = e.clientX;
      scrollStart = track.scrollLeft;
      track.setPointerCapture(e.pointerId);
      track.classList.add("is-dragging");
    });

    track.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const dx = e.clientX - dragStartX;
      if (Math.abs(dx) > DRAG_THRESHOLD) dragMoved = true;
      track.scrollLeft = scrollStart - dx;
    });

    function endDrag(e: PointerEvent) {
      if (!dragging) return;
      dragging = false;
      track.classList.remove("is-dragging");
      try {
        track.releasePointerCapture(e.pointerId);
      } catch {
        /* ignore */
      }
      if (dragMoved) {
        track.setAttribute("data-just-dragged", "1");
        window.setTimeout(() => track.removeAttribute("data-just-dragged"), 400);
        window.requestAnimationFrame(() => {
          snapToNearestCenter();
        });
      }
    }

    track.addEventListener("pointerup", endDrag);
    track.addEventListener("pointercancel", endDrag);

    track.addEventListener(
      "click",
      (e) => {
        if (track.hasAttribute("data-just-dragged")) {
          e.preventDefault();
          e.stopPropagation();
        }
      },
      true,
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTestimonialsCarousel);
  } else {
    initTestimonialsCarousel();
  }
</script>
