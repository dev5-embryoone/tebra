---
/**
 * Single card for testimonials hero collage (photo, colored quotes, case study, Trustpilot).
 */
interface Props {
  variant:
    | "photo"
    | "quote-teal"
    | "quote-orange"
    | "quote-blue"
    | "case-study"
    | "trustpilot";
  class?: string;
  imageSrc?: string;
  imageAlt?: string;
  quote?: string;
  author?: string;
  role?: string;
  caseStudyTitle?: string;
  caseStudyBody?: string;
}

const {
  variant,
  class: className = "",
  imageSrc,
  imageAlt = "",
  quote,
  author,
  role,
  caseStudyTitle,
  caseStudyBody,
} = Astro.props as Props;
---

{
  variant === "photo" && imageSrc && (
    <div
      class:list={[
        "overflow-hidden rounded-[18px] sm:rounded-[22px] border border-white/60 bg-white shadow-[0_10px_30px_rgba(0,63,59,0.08)]",
        className,
      ]}
    >
      <img
        src={imageSrc}
        alt={imageAlt}
        class="h-full w-full object-cover object-center"
        loading="lazy"
      />
    </div>
  )
}

{
  variant === "quote-teal" && (
    <blockquote
      class:list={[
        "rounded-[18px] sm:rounded-[22px] bg-tebra-teal-dark p-5 sm:p-6 text-white shadow-[0_10px_30px_rgba(0,63,59,0.10)]",
        className,
      ]}
    >
      <p class="text-sm sm:text-base font-medium leading-relaxed">
        &ldquo;{quote}&rdquo;
      </p>
      {(author || role) && (
        <footer class="mt-4 border-t border-white/20 pt-4 text-sm text-white/90">
          {author && <cite class="not-italic font-semibold">{author}</cite>}
          {role && <p class="mt-0.5 text-white/75 text-xs sm:text-sm">{role}</p>}
        </footer>
      )}
    </blockquote>
  )
}

{
  variant === "quote-orange" && (
    <blockquote
      class:list={[
        "rounded-[18px] sm:rounded-[22px] bg-[#FF8A7A] p-5 sm:p-6 text-white shadow-[0_10px_30px_rgba(255,106,91,0.18)]",
        className,
      ]}
    >
      <p class="text-sm sm:text-base font-medium leading-relaxed">
        &ldquo;{quote}&rdquo;
      </p>
      {(author || role) && (
        <footer class="mt-4 text-sm text-white/95">
          {author && <cite class="not-italic font-semibold">{author}</cite>}
          {role && <p class="mt-0.5 text-white/85 text-xs sm:text-sm">{role}</p>}
        </footer>
      )}
    </blockquote>
  )
}

{
  variant === "quote-blue" && (
    <blockquote
      class:list={[
        "rounded-[18px] sm:rounded-[22px] bg-sky-100/90 border border-sky-200/80 p-4 sm:p-5 text-tebra-teal-dark shadow-[0_8px_22px_rgba(2,132,199,0.12)]",
        className,
      ]}
    >
      <p class="text-sm font-medium leading-snug">
        &ldquo;{quote}&rdquo;
      </p>
      {(author || role) && (
        <footer class="mt-3 text-xs text-tebra-teal-dark/80">
          {author && <cite class="not-italic font-semibold">{author}</cite>}
          {role && <span class="block mt-0.5">{role}</span>}
        </footer>
      )}
    </blockquote>
  )
}

{
  variant === "case-study" && (
    <div
      class:list={[
        "rounded-[18px] sm:rounded-[22px] border border-gray-100 bg-white p-5 sm:p-6 shadow-[0_10px_30px_rgba(15,23,42,0.08)]",
        className,
      ]}
    >
      <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-tebra-teal-dark/70">
        Case study
      </p>
      {caseStudyTitle && (
        <h3 class="mt-2 text-base font-semibold text-tebra-teal-dark leading-snug">
          {caseStudyTitle}
        </h3>
      )}
      {caseStudyBody && (
        <p class="mt-3 text-sm text-gray-600 leading-relaxed">{caseStudyBody}</p>
      )}
    </div>
  )
}

{
  variant === "trustpilot" && (
    <div
      class:list={[
        "flex flex-wrap items-center justify-between gap-3 rounded-[18px] sm:rounded-[22px] border border-gray-100 bg-gray-50/90 px-5 py-4 shadow-[0_8px_22px_rgba(0,63,59,0.10)]",
        className,
      ]}
    >
      <span class="text-lg font-semibold text-tebra-teal-dark">Trustpilot</span>
      <div class="flex items-center gap-1" aria-label="5 out of 5 stars">
        {Array.from({ length: 5 }).map(() => (
          <svg
            class="h-5 w-5 text-emerald-500"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
        ))}
      </div>
    </div>
  )
}
