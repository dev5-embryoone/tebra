---
interface Props {
  itemId: string;
  question: string;
  answer: string;
  isOpen?: boolean;
}

const { itemId, question, answer, isOpen = false } = Astro.props as Props;
---

<div class={`faq-item border-b border-gray-200 last:border-b-0 ${isOpen ? 'is-open' : ''}`} data-faq-id={itemId}>
  <button
    type="button"
    class="faq-trigger flex w-full items-center justify-between gap-4 py-5 text-left transition-colors hover:bg-[#F5F3EE] focus:outline-none focus:ring-2 focus:ring-tebra-500 focus:ring-inset"
    aria-expanded={isOpen}
    aria-controls={`faq-answer-${itemId}`}
    id={`faq-question-${itemId}`}
    data-faq-trigger
  >
    <span class="text-base font-medium text-gray-900">{question}</span>
    <span class="faq-icon flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full text-[#c4a574]" aria-hidden="true">
      <span class="faq-icon-plus">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
      </span>
      <span class="faq-icon-minus hidden">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
        </svg>
      </span>
    </span>
  </button>
  <div
    id={`faq-answer-${itemId}`}
    class="faq-answer overflow-hidden transition-all duration-200"
    role="region"
    aria-labelledby={`faq-question-${itemId}`}
  >
    <div class="pb-5 pr-12 text-[15px] leading-relaxed text-gray-600">
      {answer}
    </div>
  </div>
</div>

<style>
  .faq-item .faq-icon-minus {
    display: none;
  }
  .faq-item.is-open .faq-icon-plus {
    display: none;
  }
  .faq-item.is-open .faq-icon-minus {
    display: flex !important;
  }
  .faq-item .faq-answer {
    max-height: 0;
    visibility: hidden;
  }
  .faq-item.is-open .faq-answer {
    max-height: 500px;
    visibility: visible;
  }
  .faq-item.is-open .faq-trigger {
    background-color: #F5F3EE;
  }
</style>
