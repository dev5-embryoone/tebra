---
import { intakeArticleHref, type IntakeArticle } from "../../data/theIntakePage";
import IntakeTagPill from "./IntakeTagPill.astro";

interface Props {
  article: IntakeArticle;
  imageSrc: string;
}

const { article, imageSrc } = Astro.props;

function initials(name: string) {
  return name
    .split(/\s+/)
    .map((p) => p[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();
}
---

<article class="grid overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm lg:grid-cols-2">
  <a
    href={intakeArticleHref(article.slug)}
    class="relative aspect-[4/3] min-h-[220px] min-w-0 bg-gray-100 lg:aspect-auto lg:min-h-[320px]"
  >
    <img
      src={imageSrc}
      alt=""
      class="intake-media-fill absolute inset-0"
      loading="lazy"
    />
  </a>
  <div class="flex flex-col justify-center bg-gray-50 p-6 sm:p-8 lg:p-10">
    <div class="flex flex-wrap items-center gap-2 text-[11px] font-semibold uppercase tracking-wide text-gray-500">
      <IntakeTagPill label={article.tag.label} tone={article.tag.tone} />
      <span class="text-gray-400">·</span>
      <span>{article.readTime}</span>
    </div>
    <a href={intakeArticleHref(article.slug)} class="mt-4 block focus:outline-none focus-visible:ring-2 focus-visible:ring-tebra-teal rounded-sm">
      <p
        class="font-display text-2xl font-bold leading-tight text-tebra-teal-dark sm:text-3xl lg:text-[2rem]"
        role="heading"
        aria-level={2}
      >
        {article.title}
      </p>
    </a>
    {article.excerpt && (
      <p class="mt-4 text-base leading-relaxed text-gray-600">{article.excerpt}</p>
    )}
    <div class="mt-6 flex items-center gap-2">
      <span
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white text-xs font-bold text-tebra-teal-dark shadow-sm"
        aria-hidden="true"
      >
        {initials(article.author)}
      </span>
      <span class="text-sm font-semibold text-tebra-teal-dark">{article.author}</span>
    </div>
  </div>
</article>
