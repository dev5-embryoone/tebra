---
import { intakeArticleHref, type IntakeArticle } from "../../data/theIntakePage";
import IntakeTagPill from "./IntakeTagPill.astro";

interface Props {
  article: IntakeArticle;
  imageSrc: string;
  size?: "sm" | "md" | "lg";
}

const { article, imageSrc, size = "md" } = Astro.props;

const titleClass =
  size === "sm"
    ? "text-base font-bold leading-snug text-tebra-teal-dark line-clamp-3"
    : size === "lg"
      ? "text-xl font-bold leading-snug text-tebra-teal-dark sm:text-2xl line-clamp-3"
      : "text-lg font-bold leading-snug text-tebra-teal-dark line-clamp-3";

const imgAspect = size === "sm" ? "aspect-[4/3]" : "aspect-[16/10]";

function initials(name: string) {
  return name
    .split(/\s+/)
    .map((p) => p[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();
}

---

<article class="group flex h-full flex-col">
  <a href={intakeArticleHref(article.slug)} class="block overflow-hidden rounded-xl bg-gray-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-tebra-teal">
    <div
      class:list={[
        imgAspect,
        "relative w-full min-h-[160px] overflow-hidden sm:min-h-[180px]",
      ]}
    >
      <img
        src={imageSrc}
        alt=""
        class="intake-media-fill absolute inset-0 transition-transform duration-300 group-hover:scale-[1.02]"
        loading="lazy"
        decoding="async"
      />
    </div>
  </a>
  <div class="mt-3 flex flex-1 flex-col">
    <div class="flex flex-wrap items-center gap-2 text-[11px] font-semibold uppercase tracking-wide text-gray-500">
      <IntakeTagPill label={article.tag.label} tone={article.tag.tone} />
      <span class="text-gray-400">·</span>
      <span>{article.readTime}</span>
    </div>
    <a href={intakeArticleHref(article.slug)} class="mt-2 block focus:outline-none focus-visible:ring-2 focus-visible:ring-tebra-teal rounded-sm">
      <!-- p avoids global @layer base h3 (text-3xl/4xl) blowing up card layout -->
      <p class={titleClass} role="heading" aria-level={3}>{article.title}</p>
    </a>
    <div class="mt-auto flex items-center gap-2 pt-3">
      <span
        class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-tebra-teal/10 text-[10px] font-bold text-tebra-teal-dark"
        aria-hidden="true"
      >
        {initials(article.author)}
      </span>
      <span class="text-sm font-medium text-tebra-teal-dark/90">{article.author}</span>
    </div>
  </div>
</article>
