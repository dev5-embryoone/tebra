---
interface Props {
  href: string;
  imageSrc: string;
  title: string;
  description: string;
  ctaLabel?: string;
}

const { href, imageSrc, title, description, ctaLabel = "Watch now" } = Astro.props;
---

<article
  class="relative grid h-full min-h-[280px] overflow-hidden rounded-2xl bg-tebra-teal-dark text-white shadow-md lg:min-h-[320px] lg:grid-cols-5"
>
  <div class="relative z-[1] flex flex-col justify-center p-6 sm:p-8 lg:col-span-3 lg:p-10">
    <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-white/75">Watch now</p>
    <p class="mt-2 font-display text-xl font-bold leading-tight sm:text-2xl" role="heading" aria-level={3}>
      {title}
    </p>
    <p class="mt-3 text-sm leading-relaxed text-white/90 sm:text-base">{description}</p>
    <a
      href={href}
      class="mt-6 inline-flex w-fit items-center justify-center rounded-md bg-tebra-orange px-5 py-2.5 text-sm font-bold text-white hover:opacity-95"
    >
      {ctaLabel}
    </a>
  </div>
  <div class="relative min-h-[180px] lg:col-span-2 lg:min-h-0">
    <img
      src={imageSrc}
      alt=""
      class="intake-media-fill absolute inset-0 object-left-top opacity-90"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-tebra-teal-dark to-transparent lg:bg-gradient-to-l" />
  </div>
</article>
