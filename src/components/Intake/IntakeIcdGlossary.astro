---
import { intakeIcdSampleCategories } from "../../data/theIntakePage";
import icdIllustration from "../../assets/icd-10-code-changes-for-2025-592x400.webp";

const illoSrc = typeof icdIllustration === "string" ? icdIllustration : icdIllustration.src;
---

<section class="border-b border-gray-100 bg-[#E8F3F2]">
  <div class="max-w-content mx-auto px-4 py-10 sm:px-6 sm:py-12 lg:px-12 lg:py-16">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div class="min-w-0">
        <h1 class="font-display text-3xl font-bold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.35rem] lg:leading-tight">
          Top ICD-10-CM codes for independent medical practices
        </h1>
        <p class="mt-4 text-base leading-relaxed text-gray-700 sm:text-lg">
          A library dedicated to ICD-10-CM codes for independent healthcare providers to simplify billing, streamline
          documentation, and enhance patient care.
        </p>
        <div class="mt-8 flex w-full max-w-xl items-center gap-3 rounded-2xl border border-gray-200/80 bg-white px-4 py-3 shadow-sm">
          <svg class="h-5 w-5 shrink-0 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="M20 20l-4-4" stroke-linecap="round" />
          </svg>
          <label class="sr-only" for="icd-glossary-search">Search ICD codes</label>
          <input
            id="icd-glossary-search"
            type="search"
            placeholder="Search…"
            class="min-w-0 flex-1 border-0 bg-transparent text-sm text-gray-900 outline-none placeholder:text-gray-400"
            autocomplete="off"
          />
        </div>
      </div>
      <div class="flex justify-center lg:justify-end">
        <img
          src={illoSrc}
          alt=""
          class="max-h-[280px] w-auto max-w-full object-contain sm:max-h-[320px]"
          width={592}
          height={400}
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<section class="bg-white py-10 sm:py-12 lg:py-14">
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-12">
    <h2 class="sr-only">ICD-10-CM categories</h2>
    <div class="space-y-4">
      {
        intakeIcdSampleCategories.map((cat) => (
          <details
            name="icd-cat"
            class="group overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm open:shadow-md"
            open={cat.id === "a00-b99"}
          >
            <summary class="flex cursor-pointer list-none items-center gap-3 px-4 py-4 marker:content-none [&::-webkit-details-marker]:hidden sm:px-5 sm:py-5">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gray-100 text-gray-500" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span class="min-w-0 flex-1 text-left text-sm font-semibold text-gray-900 sm:text-base">{cat.title}</span>
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-gray-200 text-tebra-orange group-open:border-tebra-orange/40">
                <span class="block h-0.5 w-3 bg-current group-open:hidden" />
                <span class="hidden group-open:block text-lg leading-none font-light">−</span>
              </span>
            </summary>
            <div class="border-t border-gray-100 px-4 pb-5 pt-2 sm:px-5">
              <ul class="grid gap-2 sm:grid-cols-2 sm:gap-x-8 sm:gap-y-2">
                {cat.codes.map((c) => (
                  <li>
                    <a
                      href={c.href}
                      class="inline-flex items-center gap-2 rounded-lg py-2 text-sm font-medium text-tebra-teal-dark hover:bg-gray-50 hover:underline"
                    >
                      <span class="text-gray-400" aria-hidden="true">
                        →
                      </span>
                      {c.code}
                    </a>
                  </li>
                ))}
              </ul>
              <p class="mt-4 text-xs text-gray-500">
                Codes link to our E/M &amp; coding updates article for context. Expand other categories as you add content.
              </p>
            </div>
          </details>
        ))
      }
    </div>

    <nav class="mt-10 text-sm text-gray-500" aria-label="Breadcrumb">
      <a href="/theintake" class="font-medium text-tebra-teal-dark hover:underline">
        The Intake
      </a>
      <span class="mx-2" aria-hidden="true">
        /
      </span>
      <span class="text-gray-700">ICD-10-CM glossary</span>
    </nav>
  </div>
</section>
