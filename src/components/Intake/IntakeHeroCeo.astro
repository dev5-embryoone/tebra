---
interface Props {
  href: string;
  imageSrc: string;
  label: string;
  title: string;
  quote: string;
  author: string;
}

const { href, imageSrc, label, title, quote, author } = Astro.props;
---

<a
  href={href}
  class="intake-hero-card group relative mx-auto flex w-full max-w-2xl flex-col overflow-hidden rounded-2xl bg-tebra-teal-dark text-white shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 lg:mx-0 lg:max-w-none"
>
  <!-- Fixed visual height so portrait images never stretch the whole column -->
  <div
    class="relative h-[200px] w-full shrink-0 overflow-hidden sm:h-[220px] md:h-[240px] lg:h-[260px]"
  >
    <img
      src={imageSrc}
      alt=""
      class="intake-media-fill pointer-events-none absolute inset-0 object-cover object-[center_15%]"
      loading="eager"
      width="800"
      height="520"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-tebra-teal-dark via-tebra-teal-dark/55 to-tebra-teal-dark/20"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute right-4 top-4 h-16 w-16 rounded-full border-2 border-white/25 opacity-50 sm:h-20 sm:w-20"
      aria-hidden="true"
    />
  </div>

  <div class="relative z-[1] space-y-2.5 px-5 pb-6 pt-5 sm:space-y-3 sm:px-6 sm:pb-7 sm:pt-6 lg:px-8">
    <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-white/85 sm:text-[11px]">{label}</p>
    <p
      class="font-display text-xl font-bold leading-snug sm:text-2xl lg:text-[1.65rem] lg:leading-tight"
      role="heading"
      aria-level={2}
    >
      {title}
    </p>
    <p class="text-sm leading-relaxed text-white/92 line-clamp-4 sm:text-[15px] lg:line-clamp-3">{quote}</p>
    <p class="text-sm font-semibold text-white">{author}</p>
  </div>
</a>
