---
import IntakeTagPill from "./IntakeTagPill.astro";
import { intakeArticleHref, type IntakeTagTone } from "../../data/theIntakePage";

interface TrendItem {
  slug: string;
  tag: { label: string; tone: IntakeTagTone };
  title: string;
}
interface Props {
  items: TrendItem[];
}

const { items } = Astro.props;
---

<aside class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm lg:p-6" aria-labelledby="intake-trending-heading">
  <p
    id="intake-trending-heading"
    class="m-0 font-display text-lg font-bold text-tebra-teal-dark"
    role="heading"
    aria-level={2}
  >
    Most Trending
  </p>
  <ul class="mt-5 space-y-5">
    {items.map((item) => (
      <li>
        <a href={intakeArticleHref(item.slug)} class="group block rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-tebra-teal">
          <IntakeTagPill label={item.tag.label} tone={item.tag.tone} class="mb-2" />
          <p class="text-sm font-semibold leading-snug text-gray-900 group-hover:text-tebra-teal-dark group-hover:underline">
            {item.title}
          </p>
        </a>
      </li>
    ))}
  </ul>
</aside>
