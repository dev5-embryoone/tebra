---
export type PracticeStatCase = {
  name: string;
  stat: string;
  specialty: string;
  location: string;
  providers: string;
};

interface Props {
  headline: string;
  cases: readonly PracticeStatCase[];
}

const { headline, cases } = Astro.props as Props;
---

<section class="bg-white py-14 lg:py-20" aria-labelledby="practice-stat-showcase-heading">
  <div class="page-container">
    <h2
      id="practice-stat-showcase-heading"
      class="mx-auto max-w-4xl text-center text-xl font-semibold leading-snug tracking-tight text-tebra-teal-dark sm:text-2xl lg:text-3xl"
    >
      {headline}
    </h2>
    <ul class="mt-12 grid gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3 lg:gap-8" role="list">
      {
        cases.map((c) => (
          <li>
            <article class="flex h-full flex-col rounded-2xl border border-gray-200 bg-tebra-hero-bg/60 p-6 shadow-sm transition-shadow hover:shadow-md sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{c.name}</p>
              <h3 class="mt-4 text-xl font-bold leading-snug text-tebra-teal-dark sm:text-2xl">{c.stat}</h3>
              <dl class="mt-6 space-y-2 border-t border-gray-200/80 pt-4 text-sm text-gray-600">
                <div class="flex justify-between gap-2">
                  <dt class="text-gray-500">Specialty</dt>
                  <dd class="font-medium text-gray-800">{c.specialty}</dd>
                </div>
                <div class="flex justify-between gap-2">
                  <dt class="text-gray-500">Location</dt>
                  <dd class="text-right font-medium text-gray-800">{c.location}</dd>
                </div>
                <div class="flex justify-between gap-2">
                  <dt class="text-gray-500">Practice size</dt>
                  <dd class="font-medium text-gray-800">{c.providers}</dd>
                </div>
              </dl>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>
