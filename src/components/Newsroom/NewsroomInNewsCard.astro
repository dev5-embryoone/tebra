---
import LinkWithArrow from "../LinkWithArrow/LinkWithArrow.astro";

interface Props {
  title: string;
  source: string;
  href: string;
}

const { title, source, href } = Astro.props;
---

<article
  class="flex h-full flex-col rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
>
  <div class="flex items-start justify-between gap-3">
    <span
      class="inline-flex rounded-full bg-sky-100 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-tebra-teal-dark"
    >
      News
    </span>
    <span class="text-xs font-medium text-gray-400">{source}</span>
  </div>
  <h3 class="mt-4 flex-1 text-base font-bold leading-snug text-gray-900">
    <a href={href} class="hover:text-tebra-teal-dark focus:outline-none focus-visible:ring-2 focus-visible:ring-tebra-teal">
      {title}
    </a>
  </h3>
  <div class="mt-6">
    <LinkWithArrow label="Read more" href={href} external={true} variant="tebra" class="text-sm" />
  </div>
</article>
