---
import Button from "../Button/Button.astro";
import { pressResources } from "../../data/newsroomPage";
---

<section
  id="press-resources"
  class="scroll-mt-28 bg-[#b0c2bb] py-16 lg:py-24"
  aria-labelledby="press-resources-heading"
>
  <div class="page-container">
    <h2
      id="press-resources-heading"
      class="text-center font-display text-3xl font-light tracking-tight text-tebra-teal-dark md:text-4xl lg:text-[2.75rem]"
    >
      {pressResources.title}
    </h2>
    <div class="mt-12 grid gap-8 md:grid-cols-2 lg:mt-14 lg:gap-10">
      {pressResources.cards.map((card, i) => (
        <div class="flex flex-col rounded-2xl bg-tebra-teal-dark p-8 text-white shadow-xl md:p-10 lg:min-h-[320px] lg:p-12">
          <div class="mb-6 flex h-28 items-center justify-start" aria-hidden="true">
            {i === 0 ? (
              <svg class="h-24 w-28 text-white/90" viewBox="0 0 120 96" fill="none" aria-hidden="true">
                <rect x="12" y="20" width="72" height="56" rx="4" stroke="currentColor" stroke-width="2" />
                <path d="M24 32h48M24 44h36M24 56h42" stroke="#F27E5E" stroke-width="2" stroke-linecap="round" />
                <path d="M88 52l20 28H68l20-28z" fill="#F27E5E" opacity="0.9" />
              </svg>
            ) : (
              <svg class="h-24 w-32 text-white/90" viewBox="0 0 128 96" fill="none" aria-hidden="true">
                <path d="M16 28h56a8 8 0 018 8v40H16V28z" stroke="currentColor" stroke-width="2" />
                <path d="M72 36h40v40H72V36z" stroke="#F27E5E" stroke-width="2" />
                <path d="M80 48h24M80 58h18" stroke="#F27E5E" stroke-width="2" stroke-linecap="round" />
              </svg>
            )}
          </div>
          <h3 class="font-display text-xl font-semibold md:text-2xl">{card.title}</h3>
          <p class="mt-3 max-w-md text-sm leading-relaxed text-white/90 md:text-base">{card.description}</p>
          <div class="mt-auto pt-8">
            <Button
              href={card.href}
              label={card.cta}
              variant="primary"
              size="md"
              class="rounded-full px-8"
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
