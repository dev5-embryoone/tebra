---
import logoSrc from '../../assets/logo_tebra.ad466dee.svg?url';
import FooterColumn from './FooterColumn.astro';

const whoWeAreFor = [
  { label: "Independent practices", href: "#" },
  { label: "New practices", href: "#" },
  { label: "Billing payments", href: "#" },
  { label: "Specialties", href: "#" },
  { label: "Patients", href: "#" },
];

const products = [
  { label: "Product Tour", href: "#" },
  { label: "Patient Experience", href: "#" },
  { label: "EHR", href: "#" },
  { label: "Billing payments", href: "#" },
  { label: "Data & insights", href: "#" },
  { label: "Find a doctor", href: "#" },
  { label: "Pricing", href: "#" },
  { label: "AI Smart Staff", href: "#" },
];

const resources = [
  { label: "The Intake", href: "#" },
  { label: "Practice Efficiency Grader", href: "#" },
  { label: "Case studies", href: "#" },
  { label: "Blog", href: "#" },
  { label: "Partner Marketplace", href: "#" },
  { label: "Newsroom", href: "#" },
  { label: "Help Center", href: "#" },
  { label: "Quality Programs & Regulatory Support", href: "#" },
];

const about = [
  { label: "Our Story", href: "#" },
  { label: "Leadership", href: "#" },
  { label: "Investors", href: "#" },
  { label: "Partners", href: "#" },
  { label: "Billing payments", href: "#" },
  { label: "Culture & Careers", href: "#" },
  { label: "DEI", href: "#" },
];

const whyTebra = [
  { label: "Attract More Patients", href: "#" },
  { label: "Manage Your Reputation", href: "#" },
  { label: "Enhance Your Patient Experience", href: "#" },
  { label: "Automate Your Practice", href: "#" },
  { label: "Deliver Better Care", href: "#" },
  { label: "Get Paid Faster", href: "#" },
  { label: "Gain Deeper Insights", href: "#" },
];
---

<footer class="bg-[#004d4d] text-white">
  <!-- Upper section: 5 columns - exact match to Tebra footer -->
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 pt-14 pb-10">
    <div class="grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      <FooterColumn title="Who We're For" links={whoWeAreFor} />
      <FooterColumn title="Products" links={products} />
      <FooterColumn title="Resources" links={resources} />
      <FooterColumn title="About" links={about} />
      <FooterColumn title="Why Tebra" links={whyTebra} />
    </div>
  </div>

  <!-- Bottom section: logo + Contact Us + address/phone | copyright + legal -->
  <div class="border-t border-white/15">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-6 flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      <div class="flex flex-col gap-3">
        <a href="/" class="inline-block w-[100px] h-[24px] shrink-0" aria-label="Tebra homepage">
          <img
            src={logoSrc}
            alt=""
            width="100"
            height="24"
            class="h-6 w-auto brightness-0 invert block"
          />
        </a>
        <p class="text-[11px] font-bold uppercase tracking-wide text-white/90 mt-1">Contact Us</p>
        <address class="text-[13px] text-white/90 not-italic leading-[1.5]">
          1111 Bayside Drive<br />
          Suite 270<br />
          Corona Del Mar, CA 92625
        </address>
        <a href="tel:8669383272" class="text-[13px] text-white/90 hover:text-white transition-colors">
          (866) 93-TEBRA (83272)
        </a>
      </div>

      <div class="flex flex-col gap-1 items-start md:items-end md:text-right">
        <p class="text-[13px] text-white/90">
          Copyright © 2026 Tebra Technologies, Inc
        </p>
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-[13px]">
          <a href="#" class="text-white/90 hover:text-white transition-colors">Terms &amp; Conditions</a>
          <a href="#" class="text-white/90 hover:text-white transition-colors">Privacy Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>
