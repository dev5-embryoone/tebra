---
import tourPreviewImage from "../../assets/platform-lab-operations.png";

/** Copy aligned with https://www.tebra.com/product-tour/form */
const tourBullets = [
  "An interactive walk-throughs of all EmbryoOne features",
  "A user-friendly, self-paced experience",
  "No commitment required",
  "Access expert support when you're ready",
];

/** Use global theme token for heading/body green */
const textGreen = "text-tebra-teal-dark";
---

<!--
  EmbryoOne product-tour style: flex 50/50 (reference), logo lives in ProductTourHeader only.
  Min-height below single-row header: --nav-product-tour-offset
-->
<section
  class="flex w-full min-h-[calc(100dvh-var(--nav-product-tour-offset))] flex-col bg-gray-50 lg:h-[calc(100dvh-var(--nav-product-tour-offset))] lg:min-h-0 lg:flex-row lg:overflow-hidden"
>
  <!-- Left: grey half — copy and checklist -->
  <div
    class="flex min-h-0 flex-1 flex-col bg-gray-50 px-6 py-10 sm:px-8 sm:py-12 lg:px-10 lg:py-6 xl:px-12"
  >
    <div class="space-y-6 lg:pt-4">
      <div>
        <h1
          class={`font-display text-3xl font-semibold leading-[1.15] tracking-tight sm:text-4xl lg:text-[2.1rem] lg:leading-[1.1] ${textGreen}`}
        >
          See how EmbryoOne works—<wbr />
          <span class="inline-block">before you commit</span>
        </h1>
        <p
          class={`mt-3 max-w-xl text-[15px] leading-relaxed sm:text-base ${textGreen} opacity-90`}
        >
          Dive into an interactive, self-guided tour and see exactly how EmbryoOne can elevate
          patient satisfaction, streamline operations, and support exceptional care—all
          before you ever talk to sales.
        </p>
      </div>

      <div>
        <p class={`text-sm font-semibold ${textGreen}`}>What’s inside the tour:</p>
        <ul class="mt-3 space-y-2 text-[14px] leading-snug text-gray-800 lg:text-[13px]">
          {tourBullets.map((line) => (
            <li class="flex gap-3">
              <span
                class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-tebra-teal text-white"
                aria-hidden="true"
              >
                <svg class="h-3 w-3" viewBox="0 0 12 10" fill="none">
                  <path
                    d="M1 5l3.5 3.5L11 1"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="pt-2">
        <img
          src={tourPreviewImage.src}
          alt="EmbryoOne platform preview with connected clinic and lab workflows"
          class="w-full max-w-xl rounded-2xl border border-gray-200 object-cover shadow-[0_20px_50px_-30px_rgba(0,0,0,0.35)]"
          loading="lazy"
        />
      </div>
    </div>
  </div>

  <!-- Right: white half — form block centered horizontally + vertically -->
  <div
    class="flex min-h-0 flex-1 flex-col items-center justify-center bg-white px-6 py-12 sm:px-8 lg:px-10 lg:py-6 xl:px-12"
  >
    <div class="w-full max-w-[400px]">
      <h2 class={`font-display text-2xl font-semibold sm:text-3xl lg:text-[1.7rem] ${textGreen}`}>
        Start your tour
      </h2>
      <p class="mt-2 text-[15px] text-gray-600 lg:text-[14px]">
        Answer a few quick questions to personalize your experience.
      </p>

      <form class="mt-6 space-y-4" action="#" method="post">
        <div>
          <label for="tour-email" class="sr-only">Email address</label>
          <input
            id="tour-email"
            name="email"
            type="email"
            autocomplete="email"
            placeholder="Work email"
            required
            class="w-full rounded-md border border-gray-300 bg-white px-4 py-3.5 text-[15px] text-gray-900 shadow-sm outline-none transition placeholder:text-gray-400 focus:border-tebra-teal-dark focus:ring-2 focus:ring-tebra-teal-dark/20"
          />
        </div>
        <p class="text-xs leading-relaxed text-gray-500">
        By submitting my email address above, I acknowledge that EmbryoOne may use my
          information as described in its{" "}
          <a
            href="/privacy"
            class="text-tebra-teal underline underline-offset-2 hover:text-tebra-teal-dark"
          >
            Privacy Policy
          </a>
          .
        </p>
        <button
          type="submit"
          class="w-full rounded-md bg-btn-primary px-6 py-3.5 text-center text-[15px] font-semibold text-white shadow-sm transition hover:bg-btn-primary-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tebra-teal-dark"
        >
          Get started
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-gray-600 lg:text-[13px]">
        Already use EmbryoOne?{" "}
        <a
          href="/sign-in"
          class="font-semibold text-tebra-teal hover:text-tebra-teal-dark hover:underline"
        >
          Sign in →
        </a>
      </p>

      <nav
        class="mt-5 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-center text-xs text-gray-500"
        aria-label="Legal"
      >
        <a
          href="/terms"
          class="text-tebra-teal underline underline-offset-2 hover:text-tebra-teal-dark"
        >
          EmbryoOne Website Terms of Use
        </a>
        <a
          href="/privacy"
          class="text-tebra-teal underline underline-offset-2 hover:text-tebra-teal-dark"
        >
          Privacy Policy
        </a>
      </nav>

      <p class="mt-4 text-center text-[10px] leading-relaxed text-gray-400">
        This site is protected by reCAPTCHA and the Google{" "}
        <a
          class="underline underline-offset-1 hover:text-gray-600"
          href="https://policies.google.com/privacy"
          target="_blank"
          rel="noopener noreferrer"
        >
          Privacy Policy
        </a>{" "}
        and{" "}
        <a
          class="underline underline-offset-1 hover:text-gray-600"
          href="https://policies.google.com/terms"
          target="_blank"
          rel="noopener noreferrer"
        >
          Terms of Service
        </a>{" "}
        apply.
      </p>
    </div>
  </div>
</section>
