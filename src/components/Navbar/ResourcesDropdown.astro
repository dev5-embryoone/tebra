---
import {
  BadgeDollarSign,
  Calculator,
  ChevronDown,
  CirclePlay,
  FileText,
  Gauge,
  LineChart,
  Monitor,
  Network,
  Newspaper,
  Star,
} from "@lucide/astro";

const menuSections = [
  {
    id: "resources-core",
    title: "Resources",
    subtitle: "Educational and strategic content for independent practices.",
    links: [
      { title: "The Intake", href: "/theintake", description: "Insights for those starting, managing and growing independent healthcare practices.", icon: "monitor" },
      { title: "Resource Library", href: "/resources", description: "Access valuable guides, tools, and insights in Tebra's resource library.", icon: "document" },
      { title: "News Room", href: "/newsroom", description: "Stay up to date with what's new and notable in the world of Tebra.", icon: "newspaper" },
      { title: "Testimonials", href: "/resources/testimonials", description: "Discover why healthcare businesses trust Tebra time and time again.", icon: "star" },
      { title: "Case Studies", href: "/case-studies", description: "Get inspired by industry leaders, learn from experts.", icon: "chart" },
      { title: "Partner Marketplace", href: "/partners", description: "Find trusted partners and explore curated solutions to meet your business needs.", icon: "network" },
    ],
  },
  {
    id: "resources-tools",
    title: "Interactive tools",
    subtitle: "Hands-on calculators and assessments for quick insights.",
    links: [
      { title: "Product Tour", href: "/product-tour", description: "Explore Tebra's platform features in an interactive walkthrough.", icon: "play" },
      { title: "EHR Calculator", href: "/ehr-calculator/step-1", description: "Estimate your savings with Tebra's EHR cost calculator.", icon: "calculator" },
      { title: "Billing Calculator", href: "/billing-payments/billing-calculator", description: "See how much revenue your practice could recover.", icon: "billing" },
      { title: "Competitive Scanner", href: "/competitive-scanner", description: "Compare your practice against local peers and discover opportunities.", icon: "chart" },
      { title: "Efficiency Grader", href: "/practice-efficiency-grader", description: "Assess your workflows and uncover ways to improve efficiency.", icon: "gear" },
    ],
  },
] as const;

function getIcon(name: string) {
  const icons = {
    monitor: Monitor,
    document: FileText,
    newspaper: Newspaper,
    star: Star,
    chart: LineChart,
    network: Network,
    play: CirclePlay,
    calculator: Calculator,
    billing: BadgeDollarSign,
    gear: Gauge,
  } as const;
  return icons[name] || icons.document;
}
---

<div class="resources-dropdown relative group">
  <button
    type="button"
    class="resources-dropdown-trigger inline-flex items-center gap-1 rounded-full border border-transparent px-3 py-2 text-sm font-semibold text-tebra-teal-dark cursor-pointer bg-transparent hover:border-[#E8DAF8] hover:bg-white hover:text-[#5E2A84] group-hover:border-[#E8DAF8] group-hover:bg-white group-hover:text-[#5E2A84]"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="nav-dropdown-resources"
    id="nav-trigger-resources"
  >
    Resources
    <ChevronDown class="h-3.5 w-3.5 text-[#7E57A0]/80" aria-hidden="true" />
  </button>

  <div
    id="nav-dropdown-resources"
    class="pointer-events-none fixed left-0 right-0 top-[5.5rem] z-50 opacity-0 invisible group-hover:pointer-events-auto group-hover:opacity-100 group-hover:visible hover:pointer-events-auto hover:opacity-100 hover:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100 group-focus-within:visible"
  >
    <div class="mx-auto w-full max-w-[1060px] px-4 sm:px-6 lg:px-8">
      <div class="max-h-[74vh] overflow-y-auto rounded-2xl border border-[#ECE5F8] bg-white shadow-[0_20px_60px_-38px_rgba(94,42,132,0.45)]">
        <div class="bg-white px-3.5 py-4 sm:px-5 lg:px-6">
          <div class="grid grid-cols-1 gap-2.5 md:grid-cols-2 lg:gap-2">
            {menuSections.map((section) => (
              <section class="min-w-0 px-0 py-1 md:px-1.5 lg:px-2">
                <h3 class="px-1.5 pb-1.5 text-[10px] font-bold uppercase tracking-[0.14em] text-[#6F3E95]">
                  {section.title}
                </h3>
                <ul role="list">
                  {section.links.map((item) => (
                    <li>
                      {(() => {
                        const Icon = getIcon(item.icon);
                        return (
                          <a
                            href={item.href}
                            class="group/item flex items-center gap-2 rounded-md bg-white px-1.5 py-1.5 text-left hover:bg-gray-50"
                          >
                            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-gray-100 text-[#6E3F87] group-hover/item:bg-white">
                              <Icon class="h-3.5 w-3.5 shrink-0" aria-hidden="true" />
                            </span>
                            <span class="min-w-0 text-[13px] font-medium leading-[1.25] text-[#40324F] group-hover/item:text-[#5E2A84]">
                              {item.title}
                            </span>
                          </a>
                        );
                      })()}
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const dropdownId = "resources";
    const root = document.querySelector(".resources-dropdown");
    const trigger = document.querySelector("#nav-trigger-resources");
    const panel = document.querySelector("#nav-dropdown-resources");
    if (!root || !trigger || !panel) return;

    let closeTimer;

    const openMenu = () => {
      window.clearTimeout(closeTimer);
      window.dispatchEvent(new CustomEvent("nav:dropdown-open", { detail: { id: dropdownId } }));
      panel.classList.remove("pointer-events-none", "opacity-0", "invisible");
      panel.classList.add("pointer-events-auto", "opacity-100", "visible");
      trigger.setAttribute("aria-expanded", "true");
    };

    const closeMenu = () => {
      panel.classList.remove("pointer-events-auto", "opacity-100", "visible");
      panel.classList.add("pointer-events-none", "opacity-0", "invisible");
      trigger.setAttribute("aria-expanded", "false");
    };

    const scheduleClose = () => {
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => {
        const active = document.activeElement;
        if (
          root.matches(":hover") ||
          panel.matches(":hover") ||
          (active instanceof Node && (trigger.contains(active) || panel.contains(active)))
        ) {
          return;
        }
        closeMenu();
      }, 120);
    };

    trigger.addEventListener("mouseenter", openMenu);
    trigger.addEventListener("focus", openMenu);
    panel.addEventListener("mouseenter", openMenu);
    panel.addEventListener("focusin", openMenu);

    trigger.addEventListener("mouseleave", scheduleClose);
    panel.addEventListener("mouseleave", scheduleClose);
    panel.addEventListener("focusout", scheduleClose);
    panel.addEventListener("click", (e) => {
      const t = e.target;
      if (t instanceof HTMLElement && t.closest("a[href]")) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });

    document.addEventListener("click", (e) => {
      const t = e.target;
      if (t instanceof Node && !root.contains(t) && !panel.contains(t)) {
        closeMenu();
      }
    });

    window.addEventListener("nav:dropdown-open", (e) => {
      if (!(e instanceof CustomEvent)) return;
      if (e.detail?.id !== dropdownId) closeMenu();
    });
  })();
</script>
