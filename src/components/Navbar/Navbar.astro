---
import NavItem from "./NavItem.astro";
import ProductsDropdown from "./ProductsDropdown.astro";
import AboutDropdown from "./AboutDropdown.astro";
import ResourcesDropdown from "./ResourcesDropdown.astro";
import logoTebraRaw from "../../assets/tebra navbar.svg";

const allPagesLinks = [
  { label: "Case Studies", href: "/case-studies" },
  { label: "About", href: "/about" },
  { label: "Careers", href: "/careers" },
  { label: "Contact", href: "/contact" },
  { label: "Pricing", href: "/pricing" },
  { label: "Integrations", href: "/integrations" },
  { label: "Security", href: "/security" },
  { label: "Compliance", href: "/compliance" },
  { label: "Support", href: "/support" },
  { label: "Documentation", href: "/documentation" },
  { label: "Partners", href: "/partners" },
  { label: "Resources", href: "/resources" },
  { label: "Webinars", href: "/webinars" },
  { label: "Guides", href: "/guides" },
  { label: "EHR", href: "/ehr" },
  { label: "Billing", href: "/billing" },
  { label: "Scheduling", href: "/scheduling" },
  { label: "Patient Portal", href: "/patient-portal" },
  { label: "Telehealth", href: "/telehealth" },
  { label: "Reporting", href: "/reporting" },
  { label: "Analytics", href: "/analytics" },
  { label: "Request a Demo", href: "/demo" },
  { label: "Sign Up", href: "/sign-up" },
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
  { label: "Press", href: "/press" },
  { label: "Events", href: "/events" },
  { label: "Product Tour", href: "/product-tour" },
  { label: "For Providers", href: "/for-providers" },
  { label: "For Billing Companies", href: "/for-billing-companies" },
  { label: "Implementation", href: "/implementation" },
];

const navItems = [
  { label: "Products", href: "#", hasDropdown: true },
  { label: "Features", href: "/features" },
  { label: "Pricing", href: "/pricing" },
  { label: "About", href: "/about", hasDropdown: true },
  { label: "Case Studies", href: "/case-studies" },
  { label: "Resources", href: "/resources", hasDropdown: true },
];

const logoTebra =
  typeof logoTebraRaw === "string" ? logoTebraRaw : logoTebraRaw.src;
---

<nav class="sticky top-0 z-50 bg-white shadow-sm">
  <!-- Top utility bar: Sign In, Help Center, Call sales -->
  <div class="hidden lg:block border-b border-gray-100 bg-white">
    <div class="page-container flex justify-end">
      <div class="flex items-center gap-6 py-2 text-xs font-medium text-gray-600">
        <a href="#login" class="hover:text-tebra-teal transition-colors">Sign In</a>
        <a href="#help" class="hover:text-tebra-teal transition-colors">Help Center</a>
        <a href="tel:+18889383272" class="hover:text-tebra-teal transition-colors">Call sales (888) 938-3272</a>
      </div>
    </div>
  </div>

  <!-- Main nav row -->
  <div class="border-b border-[#E1EBEB] bg-white">
    <div class="page-container flex items-center justify-between gap-6 py-3">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <img
          src={logoTebra}
          alt="Tebra"
          class="h-6 w-auto"
          loading="lazy"
        />
      </a>

      <!-- Desktop nav links (center) -->
      <div class="hidden lg:flex flex-1 items-center justify-center">
        <div class="flex items-center gap-8">
          {navItems.map((item) => (
            item.label === "Products" ? (
              <ProductsDropdown />
            ) : item.label === "About" ? (
              <AboutDropdown />
            ) : item.label === "Resources" ? (
              <ResourcesDropdown />
            ) : (
              <NavItem
                label={item.label}
                href={item.href}
                hasDropdown={item.hasDropdown}
                dropdownLinks={item.dropdownLinks}
              />
            )
          ))}
        </div>
      </div>

      <!-- Desktop: Take a tour + Get a demo only -->
      <div class="hidden lg:flex items-center gap-3 shrink-0">
        <a
          href="/product-tour"
          class="inline-flex items-center rounded-full border border-tebra-teal bg-white px-5 py-2 text-xs font-semibold text-tebra-teal hover:bg-tebra-hero-bg transition-colors"
        >
          Take a tour
        </a>
        <a
          href="/demo"
          class="inline-flex items-center rounded-full bg-tebra-orange px-5 py-2 text-xs font-semibold text-white shadow-sm hover:bg-[#ff5a49] transition-colors"
        >
          Get a demo
        </a>
      </div>

      <!-- Mobile menu button -->
        <button
        id="mobile-menu-button"
        class="inline-flex items-center justify-center rounded-full border border-gray-200 bg-white p-2 text-gray-700 hover:bg-gray-50 lg:hidden"
        aria-label="Open main menu"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-100 bg-white max-h-[80vh] overflow-y-auto">
    <div class="page-container flex flex-col gap-4 py-4">
      <div class="flex flex-col gap-3">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors"
          >
            {item.label}
          </a>
        ))}
      </div>
      <div class="border-t border-gray-100 pt-3">
        <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">All pages</p>
        <div class="flex flex-wrap gap-x-4 gap-y-1">
          {allPagesLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-gray-600 hover:text-tebra-teal transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
      <div class="mt-2 flex flex-col gap-3">
        <a
          href="#login"
          class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors"
        >
          Login
        </a>
        <a
          href="#demo"
          class="inline-flex items-center justify-center rounded-full bg-btn-primary px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-btn-primary-hover transition"
        >
          Get demo
        </a>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const button = document.querySelector<HTMLButtonElement>("#mobile-menu-button");
      const menu = document.querySelector<HTMLDivElement>("#mobile-menu");

      if (!button || !menu) return;

      button.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    });
  </script>
</nav>

