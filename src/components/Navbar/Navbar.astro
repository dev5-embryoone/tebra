---
import { ChevronDown, Menu, X } from "@lucide/astro";
import NavItem from "./NavItem.astro";
import ProductsDropdown from "./ProductsDropdown.astro";
import AboutDropdown from "./AboutDropdown.astro";
import ResourcesDropdown from "./ResourcesDropdown.astro";
import logoPng from "../../assets/logo.png?url";
import logoSvg from "../../assets/logo.svg?url";
import {
  mobileProductSections,
  mobileAboutLinks,
  mobileResourceSections,
} from "../../data/navbarMobile";

const navItems = [
  { label: "Products", href: "#", hasDropdown: true },
  { label: "Features", href: "/features" },
  { label: "Pricing", href: "/pricing" },
  { label: "About", href: "/about", hasDropdown: true },
  { label: "Case Studies", href: "/case-studies" },
  { label: "Resources", href: "/resources", hasDropdown: true },
];

---

<nav class="sticky top-0 z-50 glass-surface" aria-label="Main">
  <!-- Top utility bar: Sign In, Help Center, Call sales -->
  <div class="hidden lg:block bg-transparent">
    <div class="page-container flex justify-end">
      <div class="flex items-center gap-6 py-3 text-xs font-medium text-gray-600">
        <a href="/sign-in" class="hover:text-tebra-teal">Sign In</a>
        <a href="/help" class="hover:text-tebra-teal">Help Center</a>
        <a href="tel:+18889383272" class="hover:text-tebra-teal">Call sales (888) 938-3272</a>
      </div>
    </div>
  </div>

  <!-- Main row + mobile panel (panel absolutely positioned below this block) -->
  <div class="relative bg-transparent">
    <div class="page-container flex items-center justify-between gap-4 py-3 sm:gap-6">
      <a href="/" class="flex min-w-0 shrink-0 items-center gap-3">
        <picture>
          <source srcSet={logoSvg} type="image/svg+xml" />
          <img src={logoPng} alt="Tebra" class="h-6 w-auto object-contain" loading="lazy" />
        </picture>
      </a>

      <!-- Desktop nav links (center) -->
      <div class="hidden flex-1 items-center justify-center lg:flex">
        <div class="flex items-center gap-8">
          {navItems.map((item) =>
            item.label === "Products" ? (
              <ProductsDropdown />
            ) : item.label === "About" ? (
              <AboutDropdown />
            ) : item.label === "Resources" ? (
              <ResourcesDropdown />
            ) : (
              <NavItem
                label={item.label}
                href={item.href}
                hasDropdown={item.hasDropdown}
                dropdownLinks={item.dropdownLinks}
              />
            )
          )}
        </div>
      </div>

      <!-- Desktop: Take a tour + Get a demo -->
      <div class="hidden shrink-0 items-center gap-3 lg:flex">
        <a href="/product-tour" class="btn-pill-outline">
          Take a tour
        </a>
        <a href="/demo" class="btn-pill-solid">
          Get a demo
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        type="button"
        id="mobile-menu-button"
        class="inline-flex shrink-0 items-center justify-center rounded-full border border-gray-200/30 bg-white/80 p-2.5 text-gray-700 hover:bg-white lg:hidden"
        aria-label="Open main menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Menu id="mobile-menu-icon-open" class="h-5 w-5" aria-hidden="true" />
        <X id="mobile-menu-icon-close" class="hidden h-5 w-5" aria-hidden="true" />
      </button>
    </div>

    <!-- Mobile menu: same order as desktop; exclusive accordion (details name) where supported -->
    <div
      id="mobile-menu"
      class="absolute left-0 right-0 top-full z-50 hidden max-h-[min(75vh,calc(100dvh-3.5rem))] overflow-y-auto overscroll-contain bg-white/95 shadow-[0_10px_40px_rgba(72,37,88,0.06)] backdrop-blur-xl lg:hidden"
      role="navigation"
      aria-label="Mobile primary navigation"
    >
      <div class="page-container flex flex-col gap-1 px-4 py-4 sm:px-6">
        <!-- Mobile utilities (match desktop bar) -->
        <div class="mb-3 flex flex-wrap gap-x-5 gap-y-2 pb-3 text-xs font-medium text-gray-600">
          <a href="/sign-in" class="hover:text-tebra-teal">Sign In</a>
          <a href="/help" class="hover:text-tebra-teal">Help Center</a>
          <a href="tel:+18889383272" class="hover:text-tebra-teal">Call sales</a>
        </div>

        <details name="main-nav" class="group rounded-xl bg-white/70 open:bg-white">
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-2 rounded-xl px-3 py-3.5 text-sm font-semibold text-tebra-teal-dark outline-none ring-tebra-teal/30 marker:content-none [&::-webkit-details-marker]:hidden hover:bg-gray-50/70"
          >
            <span>Products</span>
            <ChevronDown
              class="h-4 w-4 shrink-0 text-gray-400"
              aria-hidden="true"
            />
          </summary>
          <div class="px-2 pb-3 pt-1">
            {
              mobileProductSections.map((section) => (
                <div class="mt-3 first:mt-2">
                  <p class="px-2 pb-1.5 text-[11px] font-bold uppercase tracking-[0.08em] text-gray-500">
                    {section.heading}
                  </p>
                  <ul class="flex flex-col gap-0.5" role="list">
                    {section.links.map((link) => (
                      <li>
                        <a
                          href={link.href}
                          class="block rounded-lg px-3 py-2.5 text-sm text-gray-700 hover:bg-white hover:text-tebra-teal"
                        >
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
            <a
              href="/product-tour"
              class="mx-2 mt-4 flex items-center gap-2 rounded-lg border border-tebra-teal/20 bg-tebra-hero-bg px-3 py-2.5 text-sm font-semibold text-tebra-teal hover:bg-white"
            >
              Take product tour
            </a>
          </div>
        </details>

        {
          navItems
            .filter((i) => i.label === "Features" || i.label === "Pricing")
            .map((item) => (
              <a
                href={item.href}
                class="rounded-xl px-3 py-3.5 text-sm font-semibold text-tebra-teal-dark hover:bg-gray-50"
              >
                {item.label}
              </a>
            ))
        }

        <details name="main-nav" class="group rounded-xl bg-white/70 open:bg-white">
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-2 rounded-xl px-3 py-3.5 text-sm font-semibold text-tebra-teal-dark outline-none marker:content-none [&::-webkit-details-marker]:hidden hover:bg-gray-50/70"
          >
            <span>About</span>
            <ChevronDown
              class="h-4 w-4 shrink-0 text-gray-400"
              aria-hidden="true"
            />
          </summary>
          <div class="px-2 pb-3 pt-1">
            <ul class="flex flex-col gap-0.5 py-1" role="list">
              {
                mobileAboutLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="block rounded-lg px-3 py-2.5 text-sm text-gray-700 hover:bg-white hover:text-tebra-teal"
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </details>

        <a
          href="/case-studies"
          class="rounded-xl px-3 py-3.5 text-sm font-semibold text-tebra-teal-dark hover:bg-gray-50"
        >
          Case Studies
        </a>

        <details name="main-nav" class="group rounded-xl bg-white/70 open:bg-white">
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-2 rounded-xl px-3 py-3.5 text-sm font-semibold text-tebra-teal-dark outline-none marker:content-none [&::-webkit-details-marker]:hidden hover:bg-gray-50/70"
          >
            <span>Resources</span>
            <ChevronDown
              class="h-4 w-4 shrink-0 text-gray-400"
              aria-hidden="true"
            />
          </summary>
          <div class="px-2 pb-3 pt-1">
            {
              mobileResourceSections.map((section) => (
                <div class="mt-3 first:mt-2">
                  <p class="px-2 pb-1.5 text-[11px] font-bold uppercase tracking-[0.08em] text-gray-500">
                    {section.heading}
                  </p>
                  <ul class="flex flex-col gap-0.5" role="list">
                    {section.links.map((link) => (
                      <li>
                        <a
                          href={link.href}
                          class="block rounded-lg px-3 py-2.5 text-sm text-gray-700 hover:bg-white hover:text-tebra-teal"
                        >
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </details>

        <div class="mt-4 flex flex-col gap-3 pt-4">
          <a href="/product-tour" class="btn-pill-outline">
            Take a tour
          </a>
          <a href="/demo" class="btn-pill-solid">
            Get a demo
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      function init() {
        const button = document.querySelector("#mobile-menu-button");
        const menu = document.querySelector("#mobile-menu");
        const iconOpen = document.querySelector("#mobile-menu-icon-open");
        const iconClose = document.querySelector("#mobile-menu-icon-close");
        if (!button || !menu) return;

        const setOpen = (open) => {
          menu.classList.toggle("hidden", !open);
          button.setAttribute("aria-expanded", open ? "true" : "false");
          iconOpen?.classList.toggle("hidden", open);
          iconClose?.classList.toggle("hidden", !open);
          document.body.style.overflow = open ? "hidden" : "";
          if (open) {
            menu.querySelector("a[href]")?.focus();
          }
        };

        button.addEventListener("click", (e) => {
          e.stopPropagation();
          const willOpen = menu.classList.contains("hidden");
          setOpen(willOpen);
        });

        menu.addEventListener("click", (event) => {
          const t = event.target;
          if (t instanceof HTMLElement && t.closest("a")) {
            setOpen(false);
          }
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && !menu.classList.contains("hidden")) {
            setOpen(false);
            button.focus();
          }
        });

        document.addEventListener("click", (e) => {
          if (menu.classList.contains("hidden")) return;
          const t = e.target;
          if (t instanceof Node && !menu.contains(t) && !button.contains(t)) {
            setOpen(false);
          }
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    })();
  </script>
</nav>
