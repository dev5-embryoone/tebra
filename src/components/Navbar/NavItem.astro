---
import { ChevronDown } from "@lucide/astro";

interface DropdownLink {
  label: string;
  href: string;
}

interface Props {
  label: string;
  href?: string;
  hasDropdown?: boolean;
  dropdownLinks?: DropdownLink[];
}

const { label, href = "#", hasDropdown = false, dropdownLinks = [] } = Astro.props as Props;
const hasDropdownPanel = dropdownLinks.length > 0;
---

{hasDropdownPanel ? (
  <div class="relative group">
    <button
      type="button"
      class="nav-link cursor-pointer bg-transparent border-0"
      class="inline-flex items-center gap-1 rounded px-2 py-1.5 text-sm font-medium text-[#1a1a1a] hover:bg-[#f5f0eb] hover:text-tebra-teal group-hover:bg-[#f5f0eb] cursor-pointer bg-transparent border-0"
      aria-haspopup="true"
      aria-expanded="false"
      aria-controls="nav-dropdown-{label.replace(/\s+/g, '-').toLowerCase()}"
      id="nav-trigger-{label.replace(/\s+/g, '-').toLowerCase()}"
    >
      {label}
      <ChevronDown class="h-3 w-3 text-gray-400" aria-hidden="true" />
    </button>
    <div
      id="nav-dropdown-{label.replace(/\s+/g, '-').toLowerCase()}"
      class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible z-50"
    >
      <div class="min-w-[480px] rounded-lg border border-gray-200 bg-white py-3 px-2 shadow-lg">
        <div class="grid grid-cols-3 gap-x-4 gap-y-0">
          {dropdownLinks.map((link) => (
            <a
              href={link.href}
              class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-tebra-teal rounded"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
) : (
  <a
    href={href}
    class="nav-link"
    class="inline-flex items-center gap-1 rounded px-2 py-1.5 text-sm font-medium text-[#1a1a1a] hover:bg-[#f5f0eb] hover:text-tebra-teal"
  >
    {label}
    {hasDropdown && (
      <ChevronDown class="h-3 w-3 text-gray-400" aria-hidden="true" />
    )}
  </a>
)}

