---
interface Props {
  label: string;
  href?: string;
  hasDropdown?: boolean;
}

const { label, href = "#", hasDropdown = false } = Astro.props as Props;
---

<a
  href={href}
  class="inline-flex items-center gap-1 text-sm font-medium text-tebra-teal-dark hover:text-tebra-teal transition-colors"
>
  {label}
  {hasDropdown && (
    <svg
      class="h-3 w-3 text-gray-400"
      viewBox="0 0 16 16"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M4 6l4 4 4-4"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )}
</a>

