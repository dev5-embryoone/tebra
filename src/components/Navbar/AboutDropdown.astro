---
import aboutImage from "../../assets/about.webp";
const aboutSrc = typeof aboutImage === "string" ? aboutImage : aboutImage.src;

const leftLinks = [
  { title: "Our Story", href: "/about/story", description: "We're redefining practice success at the crossroads of compassion and connectivity." },
  { title: "Leadership", href: "/leadership", description: "Meet the team leading the charge to bring complete well-being to practices, providers, and patients." },
  { title: "Partners", href: "/partners", description: "Market best-in-class healthcare solutions for providers and practices nationwide." },
];

const middleLinks = [
  { title: "Investors", href: "/investors", description: "The Tebra investment partners fuel our commitment to unlocking better healthcare." },
  { title: "DEI", href: "/diversity-equity-and-inclusion", description: "We're committed to celebrating diverse personalities, backgrounds, and experiences." },
  { title: "Careers", href: "/careers", description: "At Tebra, we're building the future of well-being together." },
];
---

<div class="about-dropdown relative group">
  <button
    type="button"
    class="about-dropdown-trigger inline-flex items-center gap-1 rounded px-2 py-1.5 text-sm font-medium text-[#1a1a1a] hover:bg-[#f5f0eb] hover:text-tebra-teal transition-colors cursor-pointer bg-transparent border-0 group-hover:bg-[#f5f0eb]"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="nav-dropdown-about"
    id="nav-trigger-about"
  >
    About
    <svg class="h-3.5 w-3.5 text-gray-500 group-hover:rotate-180 transition-transform" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>

  <div
    id="nav-dropdown-about"
    class="fixed left-0 right-0 top-[5.5rem] pt-0 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50"
  >
    <div class="w-full max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12 bg-white border-t border-gray-100 rounded-b-2xl shadow-xl">
      <div class="py-8 lg:py-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
          <!-- Left column: About -->
          <div class="lg:col-span-4">
            <h3 class="text-sm font-bold text-[#1a1a1a] mb-5">About</h3>
            <ul class="space-y-5">
              {leftLinks.map((item) => (
                <li>
                  <a href={item.href} class="group/item block text-left">
                    <span class="block text-sm font-semibold text-[#1a1a1a] group-hover/item:text-tebra-teal transition-colors">{item.title}</span>
                    <span class="block text-sm text-gray-600 mt-1 leading-snug">{item.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Middle column -->
          <div class="lg:col-span-4 border-l border-gray-200 pl-8">
            <ul class="space-y-5">
              {middleLinks.map((item) => (
                <li>
                  <a href={item.href} class="group/item block text-left">
                    <span class="block text-sm font-semibold text-[#1a1a1a] group-hover/item:text-tebra-teal transition-colors">{item.title}</span>
                    <span class="block text-sm text-gray-600 mt-1 leading-snug">{item.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Right column: CTA panel -->
          <div class="lg:col-span-4 border-l border-gray-200 pl-8">
            <div class="rounded-xl bg-tebra-50/80 p-5">
              <img
                src={aboutSrc}
                alt="Explore Tebra's all-in-one platform"
                class="w-full max-w-[200px] mx-auto rounded-full aspect-square object-cover mb-4"
                loading="lazy"
              />
              <h4 class="text-base font-bold text-[#1a1a1a] mb-2">Explore our all-in-one platform</h4>
              <p class="text-sm text-gray-600 leading-snug mb-4">
                Tebra's products come together to form the complete operating system for practice success.
              </p>
              <a
                href="/product-tour"
                class="inline-flex items-center gap-2 text-sm font-semibold text-tebra-teal hover:text-tebra-teal-dark transition-colors"
              >
                Take product tour
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
