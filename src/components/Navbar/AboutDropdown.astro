---
import {
  Briefcase,
  Building2,
  ChevronDown,
  Handshake,
  HeartHandshake,
  Users,
} from "@lucide/astro";
import aboutImage from "../../assets/about.webp";
const aboutSrc = typeof aboutImage === "string" ? aboutImage : aboutImage.src;

const menuSections = [
  {
    id: "about-company",
    title: "Company",
    subtitle: "Learn who we are and where we are headed.",
    links: [
      { title: "Our Story", href: "/about/story", description: "We're redefining practice success at the crossroads of compassion and connectivity.", icon: "story" },
      { title: "Leadership", href: "/leadership", description: "Meet the team leading the charge to bring complete well-being to practices, providers, and patients.", icon: "leadership" },
      { title: "Investors", href: "/investors", description: "The EmbryoOne investment partners fuel our commitment to unlocking better healthcare.", icon: "investors" },
    ],
  },
  {
    id: "about-ecosystem",
    title: "Ecosystem",
    subtitle: "See how we collaborate and build for impact.",
    links: [
      { title: "Partners", href: "/partners", description: "Market best-in-class healthcare solutions for providers and practices nationwide.", icon: "partners" },
      { title: "DEI", href: "/diversity-equity-and-inclusion", description: "We're committed to celebrating diverse personalities, backgrounds, and experiences.", icon: "dei" },
      { title: "Careers", href: "/careers", description: "At EmbryoOne, we're building the future of well-being together.", icon: "careers" },
    ],
  },
] as const;

function getIcon(name: string) {
  const icons = {
    story: Building2,
    leadership: Users,
    investors: Briefcase,
    partners: Handshake,
    dei: HeartHandshake,
    careers: Briefcase,
  } as const;
  return icons[name] || icons.story;
}
---

<div class="about-dropdown relative group">
  <button
    type="button"
    class="about-dropdown-trigger inline-flex items-center gap-1 rounded-full border border-transparent px-3 py-2 text-sm font-semibold text-tebra-teal-dark cursor-pointer bg-transparent hover:border-[#E8DAF8] hover:bg-white hover:text-[#5E2A84] group-hover:border-[#E8DAF8] group-hover:bg-white group-hover:text-[#5E2A84]"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="nav-dropdown-about"
    id="nav-trigger-about"
  >
    About
    <ChevronDown class="h-3.5 w-3.5 text-[#7E57A0]/80" aria-hidden="true" />
  </button>

  <div
    id="nav-dropdown-about"
    class="pointer-events-none fixed inset-x-0 top-[var(--nav-sticky-offset)] z-[100] pt-2 opacity-0 invisible group-hover:pointer-events-auto group-hover:opacity-100 group-hover:visible hover:pointer-events-auto hover:opacity-100 hover:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100 group-focus-within:visible"
  >
    <div class="mx-auto w-full max-w-[1060px] px-4 sm:px-6 lg:px-8">
      <div class="max-h-[74vh] overflow-y-auto rounded-2xl border border-[#ECE5F8] bg-white shadow-[0_20px_60px_-38px_rgba(94,42,132,0.45)]">
        <div class="bg-white px-3.5 py-4 sm:px-5 lg:px-6">
          <div class="grid grid-cols-1 gap-2.5 md:grid-cols-2 lg:grid-cols-3 lg:gap-2">
            {menuSections.map((section) => (
              <section class="min-w-0 px-0 py-1 md:px-1.5 lg:px-2">
                <h3 class="px-1.5 pb-1.5 text-[10px] font-bold uppercase tracking-[0.14em] text-[#6F3E95]">
                  {section.title}
                </h3>
                <ul role="list">
                  {section.links.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class="group/item flex items-center gap-2 rounded-md bg-white px-1.5 py-1.5 text-left hover:bg-gray-50"
                      >
                        {(() => {
                          const Icon = getIcon(item.icon);
                          return <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-gray-100 text-[#6E3F87] group-hover/item:bg-white"><Icon class="h-3.5 w-3.5" aria-hidden="true" /></span>;
                        })()}
                        <span class="block text-[13px] font-medium leading-[1.25] text-[#40324F] group-hover/item:text-[#5E2A84]">
                          {item.title}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
            <aside class="min-w-0 rounded-xl border border-[#ECE5F8] bg-gray-50 p-3.5">
              <img
                src={aboutSrc}
                alt="Explore EmbryoOne's all-in-one platform"
                class="mx-auto mb-2.5 w-full max-w-[96px] rounded-full aspect-square object-cover"
                loading="lazy"
              />
              <h4 class="text-[13px] font-bold text-[#4D236D]">Explore our all-in-one platform</h4>
              <p class="mt-1 text-[12px] leading-[1.35] text-[#726781]">
                EmbryoOne's products come together to form the complete operating system for practice success.
              </p>
              <a
                href="/product-tour"
                class="mt-2 inline-flex items-center gap-2 text-[12px] font-semibold text-[#6E3F87] hover:text-[#4D236D]"
              >
                Take product tour
              </a>
            </aside>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const dropdownId = "about";
    const root = document.querySelector(".about-dropdown");
    const trigger = document.querySelector("#nav-trigger-about");
    const panel = document.querySelector("#nav-dropdown-about");
    if (!root || !trigger || !panel) return;

    let closeTimer;

    const openMenu = () => {
      window.clearTimeout(closeTimer);
      window.dispatchEvent(new CustomEvent("nav:dropdown-open", { detail: { id: dropdownId } }));
      panel.classList.remove("pointer-events-none", "opacity-0", "invisible");
      panel.classList.add("pointer-events-auto", "opacity-100", "visible");
      trigger.setAttribute("aria-expanded", "true");
    };

    const closeMenu = () => {
      panel.classList.remove("pointer-events-auto", "opacity-100", "visible");
      panel.classList.add("pointer-events-none", "opacity-0", "invisible");
      trigger.setAttribute("aria-expanded", "false");
    };

    const scheduleClose = () => {
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => {
        const active = document.activeElement;
        if (
          root.matches(":hover") ||
          panel.matches(":hover") ||
          (active instanceof Node && (trigger.contains(active) || panel.contains(active)))
        ) {
          return;
        }
        closeMenu();
      }, 120);
    };

    trigger.addEventListener("mouseenter", openMenu);
    trigger.addEventListener("focus", openMenu);
    panel.addEventListener("mouseenter", openMenu);
    panel.addEventListener("focusin", openMenu);

    trigger.addEventListener("mouseleave", scheduleClose);
    panel.addEventListener("mouseleave", scheduleClose);
    panel.addEventListener("focusout", scheduleClose);
    panel.addEventListener("click", (e) => {
      const t = e.target;
      if (t instanceof HTMLElement && t.closest("a[href]")) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });

    document.addEventListener("click", (e) => {
      const t = e.target;
      if (t instanceof Node && !root.contains(t) && !panel.contains(t)) {
        closeMenu();
      }
    });

    window.addEventListener("nav:dropdown-open", (e) => {
      if (!(e instanceof CustomEvent)) return;
      if (e.detail?.id !== dropdownId) closeMenu();
    });
  })();
</script>
