---
import {
  Blocks,
  Camera,
  ChevronDown,
  Gauge,
  Heart,
  Home,
  Microscope,
  ShieldCheck,
  Snowflake,
  Sparkles,
  Stethoscope,
  UserRoundPlus,
  UsersRound,
} from "@lucide/astro";

const menuSections = [
  {
    id: "products-lab-system",
    title: "Lab System",
    links: [
      {
        title: "Witness",
        href: "/products/witness",
        description: "Track every lab action and prevent mismatches in real time",
        icon: "witness",
      },
      {
        title: "Lab Health",
        href: "/products/lab-health",
        description: "Monitor temperature, air quality, and lab conditions continuously",
        icon: "labHealth",
      },
      {
        title: "Consumption",
        href: "/products/consumption",
        description: "Track inventory usage and reduce manual errors in the lab",
        icon: "consumption",
      },
      {
        title: "Cryo Tracker",
        href: "/products/cryo-tracker",
        description: "Manage embryo storage, location, and lifecycle with precision",
        icon: "cryo",
      },
    ],
  },
  {
    id: "products-embryo-intelligence",
    title: "Embryo Intelligence",
    links: [
      {
        title: "Embryo Intelligence",
        href: "/products/embryo-intelligence",
        description: "Connect embryo data, imaging, and analysis in one workflow",
        icon: "embryoIntelligence",
      },
      {
        title: "Embryo Capture",
        href: "/products/embryo-capture",
        description: "Capture high-resolution embryo images directly from the workstation",
        icon: "embryoCapture",
      },
      {
        title: "AI Grading",
        href: "/products/ai-grading",
        description: "Standardize embryo assessment with AI-assisted grading",
        icon: "aiGrading",
      },
    ],
  },
  {
    id: "products-clinical-patient",
    title: "Clinical & Patient",
    links: [
      {
        title: "EHR",
        href: "/products/ehr",
        description: "Manage IVF cycles, records, and clinical workflows in one system",
        icon: "ehr",
      },
      {
        title: "Patient Experience",
        href: "/products/patient-experience",
        description: "Give patients real-time visibility into their treatment journey",
        icon: "patientExperience",
      },
      {
        title: "People",
        href: "/products/people",
        description: "Coordinate staff roles, tasks, and lab responsibilities efficiently",
        icon: "people",
      },
    ],
  },
] as const;

function getIcon(name: string) {
  const icons = {
    labSystem: Blocks,
    witness: ShieldCheck,
    labHealth: Heart,
    consumption: Gauge,
    cryo: Snowflake,
    embryoIntelligence: Microscope,
    embryoCapture: Camera,
    aiGrading: Sparkles,
    ehr: Stethoscope,
    patientExperience: UserRoundPlus,
    people: UsersRound,
    home: Home,
  } as const;
  return icons[name] || icons.home;
}

---

<div class="products-dropdown relative group">
  <button
    type="button"
    class="products-dropdown-trigger inline-flex items-center gap-1 rounded-full border border-transparent px-3 py-2 text-sm font-semibold text-tebra-teal-dark cursor-pointer bg-transparent hover:border-[#E8DAF8] hover:bg-white hover:text-[#5E2A84] group-hover:border-[#E8DAF8] group-hover:bg-white group-hover:text-[#5E2A84]"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="nav-dropdown-products"
    id="nav-trigger-products"
  >
    Products
    <ChevronDown class="h-3.5 w-3.5 text-[#7E57A0]/80" aria-hidden="true" />
  </button>

  <div
    id="nav-dropdown-products"
    class="pointer-events-none absolute left-1/2 top-full z-[100] w-[1040px] max-w-[min(1040px,calc(100vw-2rem))] -translate-x-1/2 pt-3 opacity-0 invisible group-hover:pointer-events-auto group-hover:opacity-100 group-hover:visible hover:pointer-events-auto hover:opacity-100 hover:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100 group-focus-within:visible"
  >
    <div class="max-h-[74vh] overflow-y-auto rounded-2xl border border-[#ECE5F8] bg-white p-4 shadow-[0_20px_60px_-38px_rgba(94,42,132,0.45)] sm:p-5">
      <div class="grid grid-cols-1 gap-2.5 md:grid-cols-2 lg:grid-cols-3 lg:gap-2">
        {menuSections.map((section) => (
          <section class="min-w-0 px-0 py-1 md:px-1.5 lg:px-2">
            <h3 class="px-1.5 pb-1.5 text-[10px] font-bold uppercase tracking-[0.14em] text-[#6F3E95]">
              {section.title}
            </h3>
            <ul role="list">
              {section.links.map((item) => (
                <li>
                  {(() => {
                    const Icon = getIcon(item.icon);
                    return (
                      <a
                        href={item.href}
                        class="group/item flex items-start gap-2 rounded-md bg-white px-1.5 py-1.5 text-left hover:bg-gray-50"
                      >
                        <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-gray-100 text-[#6E3F87] group-hover/item:bg-white">
                          <Icon class="h-3.5 w-3.5" aria-hidden="true" />
                        </span>
                        <span class="min-w-0">
                          <span class="block text-[13px] font-semibold leading-[1.2] text-[#40324F] group-hover/item:text-[#5E2A84]">
                            {item.title}
                          </span>
                          <span class="mt-0.5 block whitespace-normal break-words text-[11px] leading-[1.25] text-[#726781]">
                            {item.description}
                          </span>
                        </span>
                      </a>
                    );
                  })()}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const dropdownId = "products";
    const root = document.querySelector(".products-dropdown");
    const trigger = document.querySelector("#nav-trigger-products");
    const panel = document.querySelector("#nav-dropdown-products");
    if (!root || !trigger || !panel) return;
    let closeTimer;

    const openMenu = () => {
      window.clearTimeout(closeTimer);
      window.dispatchEvent(new CustomEvent("nav:dropdown-open", { detail: { id: dropdownId } }));
      panel.classList.remove("pointer-events-none", "opacity-0", "invisible");
      panel.classList.add("pointer-events-auto", "opacity-100", "visible");
      trigger.setAttribute("aria-expanded", "true");
    };

    const closeMenu = () => {
      panel.classList.remove("pointer-events-auto", "opacity-100", "visible");
      panel.classList.add("pointer-events-none", "opacity-0", "invisible");
      trigger.setAttribute("aria-expanded", "false");
    };

    const scheduleClose = () => {
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => {
        const active = document.activeElement;
        if (
          root.matches(":hover") ||
          panel.matches(":hover") ||
          (active instanceof Node && (trigger.contains(active) || panel.contains(active)))
        ) {
          return;
        }
        closeMenu();
      }, 120);
    };

    trigger.addEventListener("mouseenter", openMenu);
    trigger.addEventListener("focus", openMenu);
    panel.addEventListener("mouseenter", openMenu);
    panel.addEventListener("focusin", openMenu);

    trigger.addEventListener("mouseleave", scheduleClose);
    panel.addEventListener("mouseleave", scheduleClose);
    panel.addEventListener("focusout", scheduleClose);

    panel.addEventListener("click", (e) => {
      const t = e.target;
      if (t instanceof HTMLElement && t.closest("a[href]")) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });

    document.addEventListener("click", (e) => {
      const t = e.target;
      if (t instanceof Node && !root.contains(t) && !panel.contains(t)) {
        closeMenu();
      }
    });

    window.addEventListener("nav:dropdown-open", (e) => {
      if (!(e instanceof CustomEvent)) return;
      if (e.detail?.id !== dropdownId) closeMenu();
    });
  })();
</script>
