---
/**
 * RPA hero: photo + code snippets + ERA process panel (Tebra billing RPA page).
 */
interface Props {
  imageSrc: string;
  imageAlt: string;
}

const { imageSrc, imageAlt } = Astro.props as Props;
---

<div class="relative mx-auto w-full max-w-xl lg:max-w-none">
  <div class="relative">
    <img
      src={imageSrc}
      alt={imageAlt}
      class="w-full rounded-2xl border border-gray-200/80 object-cover shadow-xl sm:rounded-3xl"
      width="640"
      height="480"
      loading="eager"
    />

    <!-- Code snippet blocks (top-right) -->
    <div class="absolute -top-2 right-0 z-10 flex flex-col gap-2 sm:right-2 sm:top-2">
      <div
        class="w-[min(140px,38vw)] rounded-lg border border-gray-700 bg-[#1e1e1e] p-2 font-mono text-[9px] leading-tight text-gray-100 shadow-lg sm:w-[150px] sm:text-[10px]"
        aria-hidden="true"
      >
        <p class="text-amber-300">async function postERA()</p>
        <p class="text-emerald-400">await validate();</p>
        <p class="text-sky-400">return sync();</p>
      </div>
      <div
        class="ml-4 w-[min(130px,36vw)] rounded-lg border border-gray-700 bg-[#252525] p-2 font-mono text-[9px] leading-tight text-gray-200 shadow-lg sm:ml-6 sm:w-[140px] sm:text-[10px]"
        aria-hidden="true"
      >
        <p class="text-rose-300">rules.match(payer)</p>
        <p class="text-yellow-200">→ batch.submit()</p>
      </div>
    </div>

    <!-- ERA process card (bottom-left) -->
    <div
      class="absolute -bottom-3 left-1/2 z-10 w-[min(calc(100%-0.5rem),300px)] -translate-x-1/2 rounded-xl border border-gray-200 bg-white p-3 shadow-2xl sm:left-4 sm:w-[280px] sm:translate-x-0 sm:p-4 lg:bottom-4 lg:left-6"
    >
      <p class="text-sm font-semibold text-tebra-teal-dark">ERA process</p>
      <div class="mt-3 space-y-2">
        <div>
          <label class="text-[10px] font-medium uppercase tracking-wide text-gray-500">Username</label>
          <div class="mt-0.5 rounded-lg border border-gray-200 bg-gray-50 px-2 py-1.5 text-xs text-gray-800">medical-billing</div>
        </div>
        <div>
          <label class="text-[10px] font-medium uppercase tracking-wide text-gray-500">Action</label>
          <div class="mt-0.5 rounded-lg border border-gray-200 bg-gray-50 px-2 py-1.5 text-xs font-medium text-tebra-teal-dark">POST</div>
        </div>
        <div>
          <p class="text-[10px] font-medium uppercase tracking-wide text-gray-500">Loading file</p>
          <div class="mt-1.5 h-2 w-full overflow-hidden rounded-full bg-gray-100">
            <div class="h-full w-[75%] rounded-full bg-tebra-teal"></div>
          </div>
        </div>
        <div class="flex flex-wrap gap-3 pt-1 text-[11px] text-gray-600">
          <label class="flex cursor-default items-center gap-1.5">
            <span class="h-3.5 w-3.5 rounded border border-gray-300 bg-white" aria-hidden="true"></span>
            Pause
          </label>
          <label class="flex cursor-default items-center gap-1.5">
            <span class="h-3.5 w-3.5 rounded border border-gray-300 bg-white" aria-hidden="true"></span>
            Debug
          </label>
          <label class="flex cursor-default items-center gap-1.5">
            <span class="h-3.5 w-3.5 rounded border border-tebra-teal bg-tebra-teal" aria-hidden="true"></span>
            Load
          </label>
        </div>
      </div>
    </div>
  </div>
</div>
