---
/**
 * Hero visual: photo + floating claim UI (matches Tebra electronic claims page feel).
 */
interface Props {
  imageSrc: string;
  imageAlt: string;
}

const { imageSrc, imageAlt } = Astro.props as Props;
---

<div class="relative mx-auto w-full max-w-xl lg:max-w-none">
  <div class="relative">
    <img
      src={imageSrc}
      alt={imageAlt}
      class="w-full rounded-2xl border border-gray-200/80 object-cover shadow-xl sm:rounded-3xl"
      width="640"
      height="480"
      loading="eager"
    />

    <!-- Top-right notification -->
    <div
      class="absolute -right-1 top-2 z-10 max-w-[min(100%,220px)] rounded-xl border border-gray-200 bg-white p-3 text-xs leading-snug text-gray-800 shadow-lg sm:right-2 sm:top-4 sm:max-w-[240px] sm:p-3.5 sm:text-sm"
    >
      <p class="font-medium text-tebra-teal-dark">Ready to submit</p>
      <p class="mt-1 text-gray-600">There are 4 total claims that are ready for electronic submission.</p>
    </div>

    <!-- Bottom-left modal -->
    <div
      class="absolute -bottom-2 left-1/2 z-10 w-[min(calc(100%-1rem),320px)] -translate-x-1/2 rounded-xl border border-gray-200 bg-white/95 p-3 shadow-2xl backdrop-blur-sm sm:left-4 sm:w-[300px] sm:translate-x-0 sm:p-4 lg:bottom-6 lg:left-6"
    >
      <p class="text-sm font-semibold text-tebra-teal-dark">Electronic claims</p>
      <div class="mt-3 space-y-2">
        {
          ["Start date", "End date", "Insurance companies", "Patients"].map((label) => (
            <div>
              <label class="block text-[10px] font-medium uppercase tracking-wide text-gray-500">{label}</label>
              <div class="mt-0.5 flex h-8 items-center justify-between rounded-lg border border-gray-200 bg-gray-50 px-2 text-xs text-gray-600">
                <span>—</span>
                <svg class="h-3.5 w-3.5 text-gray-400" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                </svg>
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-4 flex justify-end gap-2">
        <button
          type="button"
          class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-semibold text-gray-600"
        >
          Cancel
        </button>
        <button
          type="button"
          class="rounded-full bg-tebra-teal-dark px-3 py-1.5 text-xs font-semibold text-white"
        >
          Submit
        </button>
      </div>
    </div>
  </div>
</div>
