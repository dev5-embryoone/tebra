---
interface Props {
  /** Button label - only prop you need to change for reuse */
  label: string;
  /** primary (filled) or secondary (outline) or outline-light (white on dark) or outline-dark (dark border) */
  variant?: 'primary' | 'secondary' | 'outline-light' | 'outline-dark';
  /** If set, renders as <a href="...">; otherwise <button> */
  href?: string;
  /** Button type when not a link */
  type?: 'button' | 'submit';
  /** Size affects padding and text */
  size?: 'sm' | 'md' | 'lg';
  /** Extra CSS classes */
  class?: string;
  /** Optional id for the element (e.g. for JS hooks) */
  id?: string;
}

const {
  label,
  variant = 'primary',
  href,
  type = 'button',
  size = 'md',
  class: className = '',
  id,
} = Astro.props as Props;

const base =
  'inline-flex items-center justify-center font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2';

const variants = {
  primary:
    'bg-btn-primary text-white shadow-sm hover:bg-btn-primary-hover focus:ring-btn-primary',
  secondary:
    'border-2 border-border-muted bg-white text-gray-800 hover:border-gray-400 hover:bg-gray-50 focus:ring-gray-300',
  /** For use on dark backgrounds (e.g. CTA strip) */
  'outline-light':
    'border-2 border-white bg-transparent text-white hover:bg-white/10 focus:ring-white',
  /** Dark border, hover fill (e.g. FAQ Show more) */
  'outline-dark':
    'border-2 border-gray-900 bg-transparent text-gray-900 hover:bg-gray-900 hover:text-white focus:ring-gray-900',
};

const sizes = {
  sm: 'rounded-full px-6 py-2.5 text-sm',
  md: 'rounded-xl px-6 py-3.5 text-base',
  lg: 'rounded-full px-6 py-3 text-sm shadow-lg shadow-btn-primary/30',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`.trim();
---

{href ? (
  <a id={id} href={href} class={classes}>
    {label}
  </a>
) : (
  <button id={id} type={type} class={classes}>
    {label}
  </button>
)}
