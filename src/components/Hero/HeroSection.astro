---
interface Props {
  title: string;
  eyebrow?: string;
  subtitle: string;
  supporting?: string;
  primaryCtaLabel: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
}

const {
  title,
  eyebrow = "EHR+ for private practices",
  subtitle,
  supporting = "We safeguard your practice with full security and HIPAA compliance.",
  primaryCtaLabel,
  primaryCtaHref = "#demo",
  secondaryCtaLabel = "Take a quick tour",
  secondaryCtaHref = "#tour",
} = Astro.props as Props;
---

<section class="page-section bg-tebra-hero-bg">
  <div class="page-container grid gap-12 lg:grid-cols-2 lg:items-center">
    <div class="space-y-6">
      <div class="flex items-center gap-4 text-xs text-tebra-teal">
        <div class="flex items-center gap-1">
          <span class="text-base leading-none text-[#FFB800]">★</span>
          <span class="font-semibold text-tebra-teal-dark">4.5</span>
          <span class="text-gray-300">|</span>
          <span class="tracking-wide text-gray-500">★★★★★</span>
        </div>
        <div class="h-3 w-px bg-gray-200" />
        <div class="flex items-center gap-1">
          <span class="text-base leading-none text-[#FFB800]">★</span>
          <span class="font-semibold text-tebra-teal-dark">4.1</span>
          <span class="text-gray-300">|</span>
          <span class="tracking-wide text-gray-500">★★★★☆</span>
        </div>
      </div>
      <div class="inline-flex items-center gap-2 rounded-full bg-[#E4F3F3] px-3 py-1 text-xs font-medium text-tebra-teal">
        <span class="h-1.5 w-1.5 rounded-full bg-tebra-teal" />
        <span>{eyebrow}</span>
      </div>
      <h1 class="text-5xl font-bold tracking-tight text-tebra-teal-dark sm:text-6xl">
        {title}
      </h1>
      <p class="max-w-xl text-lg text-gray-600">
        {subtitle}
      </p>
      <p class="max-w-xl text-sm text-gray-500">
        {supporting}
      </p>

      <div class="flex flex-wrap items-center gap-4 pt-2">
        <a
          href={primaryCtaHref}
          class="inline-flex items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#ff5a49] transition"
        >
          {primaryCtaLabel}
        </a>
        <a
          href={secondaryCtaHref}
          class="inline-flex items-center rounded-full border border-tebra-teal bg-transparent px-6 py-3 text-sm font-semibold text-tebra-teal hover:bg-white transition"
        >
          {secondaryCtaLabel}
          <svg
            class="ml-1.5 h-4 w-4"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M4 8h7M8 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </div>
    </div>

    <div class="relative">
      <div
        class="relative overflow-hidden rounded-3xl border border-gray-100 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]"
      >
        <div class="h-64 w-full bg-gradient-to-br from-tebra-teal via-[#00B4A2] to-[#4F46E5] opacity-90 sm:h-80 lg:h-96" />
        <div class="pointer-events-none absolute inset-x-6 bottom-6 rounded-2xl bg-white/90 p-4 shadow-lg backdrop-blur">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
                EHR+ overview
              </p>
              <p class="mt-1 text-sm font-medium text-gray-900">
                Take a quick tour of Tebra&apos;s EHR+ platform
              </p>
            </div>
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-tebra-orange text-white">
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path
                  d="M6 4.667L11 8l-5 3.333V4.667z"
                  fill="currentColor"
                />
              </svg>
            </div>
          </div>
        </div>
      </div>

      <div class="pointer-events-none absolute -left-6 -top-6 hidden h-16 w-16 rounded-full border border-dashed border-tebra-300 md:block" />
      <div class="pointer-events-none absolute -right-4 bottom-10 hidden h-8 w-8 rounded-full bg-tebra-200 md:block" />
    </div>
  </div>
</section>

