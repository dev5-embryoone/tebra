---
import heroImageRaw from "../../assets/hero-short.webp";
import hipaaRaw from "../../assets/hipaa.webp";
import hitrustRaw from "../../assets/hitrust.webp";
import aipcaRaw from "../../assets/aipca.webp";
import pciRaw from "../../assets/pci.webp";
import paymentsRaw from "../../assets/payments.webp";
import billingRaw from "../../assets/billing.webp";
import marketingRaw from "../../assets/marketing.webp";
import patientExperienceRaw from "../../assets/patient-experience.webp";

interface Props {
  title: string;
  eyebrow?: string;
  subtitle: string;
  supporting?: string;
  primaryCtaLabel: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  /** Optional custom hero image URL so pages can reuse this layout with different art */
  imageSrc?: string;
  imageAlt?: string;
  /** Show floating vertical feature images behind hero copy (features page only) */
  featureFloating?: boolean;
  /** G2-style rating strip above eyebrow (specialty pages often hide this) */
  showRatingStrip?: boolean;
  /** HIPAA / compliance logo strip below hero */
  showComplianceStrip?: boolean;
}

const {
  title,
  eyebrow = "EHR+ for private practices",
  subtitle,
  supporting = "We safeguard your practice with full security and HIPAA compliance.",
  primaryCtaLabel,
  primaryCtaHref = "#demo",
  secondaryCtaLabel = "Take a quick tour",
  secondaryCtaHref = "#tour",
  imageSrc,
  imageAlt,
  featureFloating = false,
  showRatingStrip = true,
  showComplianceStrip = true,
} = Astro.props as Props;

const defaultHeroImage =
  typeof heroImageRaw === "string" ? heroImageRaw : heroImageRaw.src;

const hipaa = typeof hipaaRaw === "string" ? hipaaRaw : hipaaRaw.src;
const hitrust = typeof hitrustRaw === "string" ? hitrustRaw : hitrustRaw.src;
const aipca = typeof aipcaRaw === "string" ? aipcaRaw : aipcaRaw.src;
const pci = typeof pciRaw === "string" ? pciRaw : pciRaw.src;
const payments =
  typeof paymentsRaw === "string" ? paymentsRaw : paymentsRaw.src;
const billing =
  typeof billingRaw === "string" ? billingRaw : billingRaw.src;
const marketing =
  typeof marketingRaw === "string" ? marketingRaw : marketingRaw.src;
const patientExperience =
  typeof patientExperienceRaw === "string"
    ? patientExperienceRaw
    : patientExperienceRaw.src;

const heroImage = imageSrc ?? defaultHeroImage;
const heroImageAlt = imageAlt ?? "Tebra EHR+ platform hero";
---

<section class="page-section bg-tebra-hero-bg">
  <div class="page-container grid gap-12 lg:grid-cols-2 lg:items-center">
    <div class="space-y-6">
      {showRatingStrip && (
        <div class="hero-rating-strip">
          <div class="hero-rating-block">
            <span class="hero-rating-star">★</span>
            <span class="hero-rating-score">4.5</span>
            <span class="text-gray-300">|</span>
            <span class="hero-rating-text">★★★★★</span>
          </div>
          <div class="hero-rating-divider" />
          <div class="hero-rating-block">
            <span class="hero-rating-star">★</span>
            <span class="hero-rating-score">4.1</span>
            <span class="text-gray-300">|</span>
            <span class="hero-rating-text">★★★★☆</span>
          </div>
        </div>
      )}
      <div class="hero-eyebrow-pill">
        <span class="h-1.5 w-1.5 rounded-full bg-tebra-teal" />
        <span>{eyebrow}</span>
      </div>
      <h1 class="hero-heading">
        {title}
      </h1>
      <p class="max-w-xl text-base text-gray-600 sm:text-lg">
        {subtitle}
      </p>
      {supporting ? (
        <p class="max-w-xl text-sm text-gray-500">
          {supporting}
        </p>
      ) : null}

      <div class="flex flex-wrap items-center gap-4 pt-2">
        <a
          href={primaryCtaHref}
          class="inline-flex items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#ff5a49] transition"
        >
          {primaryCtaLabel}
        </a>
        <a
          href={secondaryCtaHref}
          class="inline-flex items-center rounded-full border border-tebra-teal bg-transparent px-6 py-3 text-sm font-semibold text-tebra-teal hover:bg-white transition"
        >
          {secondaryCtaLabel}
          <svg
            class="ml-1.5 h-4 w-4"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M4 8h7M8 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </div>
    </div>

    <div class="relative flex justify-center lg:justify-start">
      {featureFloating ? (
        <div class="grid grid-cols-2 gap-4 lg:gap-6">
          <img
            src={payments}
            alt="Payments feature"
            class="image-float max-w-[180px] rounded-3xl border border-gray-100 bg-white/80 shadow-xl"
            loading="lazy"
          />
          <img
            src={billing}
            alt="Billing feature"
            class="image-float max-w-[180px] rounded-3xl border border-gray-100 bg-white/80 shadow-xl"
            loading="lazy"
          />
          <img
            src={marketing}
            alt="Marketing feature"
            class="image-float max-w-[180px] rounded-3xl border border-gray-100 bg-white/80 shadow-xl"
            loading="lazy"
          />
          <img
            src={patientExperience}
            alt="Patient experience feature"
            class="image-float max-w-[180px] rounded-3xl border border-gray-100 bg-white/80 shadow-xl"
            loading="lazy"
          />
        </div>
      ) : (
        <img
          src={heroImage}
          alt={heroImageAlt}
          class="max-w-full rounded-3xl border border-gray-100 shadow-[0_24px_60px_rgba(15,23,42,0.12)]"
          loading="lazy"
        />
      )}
    </div>
  </div>
</section>

{showComplianceStrip ? (
  <section class="hero-compliance-strip">
    <div class="hero-compliance-inner">
      <p class="hero-compliance-text">
        We safeguard your practice with full security and HIPAA compliance.
      </p>
      <div class="hero-compliance-logos">
        <img src={hipaa} alt="HIPAA compliant" class="h-14 md:h-16 w-auto" loading="lazy" />
        <img src={hitrust} alt="HITRUST certified" class="h-14 md:h-16 w-auto" loading="lazy" />
        <img src={aipca} alt="AICPA SOC" class="h-14 md:h-16 w-auto" loading="lazy" />
        <img src={pci} alt="PCI compliant" class="h-14 md:h-16 w-auto" loading="lazy" />
      </div>
    </div>
  </section>
) : null}

