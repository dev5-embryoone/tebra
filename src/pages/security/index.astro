---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/Cards/ContentCard.astro";
import { pageCards } from "../../data/pageCards";

const cards = pageCards.security ?? [];
---
<BaseLayout
  title="Security | Tebra"
  description="How Tebra keeps your practice data secure."
>
  <section class="page-section bg-white">
    <div class="page-container">
      <h1 class="text-3xl font-semibold text-gray-900">Security</h1>
      <p class="mt-3 max-w-2xl text-gray-600">
        How Tebra keeps your practice and patient data secure with encryption, access controls, and compliance.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {cards.map((card) => (
          <ContentCard title={card.title} description={card.description} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
