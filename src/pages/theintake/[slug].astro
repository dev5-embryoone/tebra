---
import IntakeLayout from "../../layouts/IntakeLayout.astro";
import IntakeCategoryHub from "../../components/Intake/IntakeCategoryHub.astro";
import IntakeIcdGlossary from "../../components/Intake/IntakeIcdGlossary.astro";
import IntakeSplitFeature from "../../components/Intake/IntakeSplitFeature.astro";
import IntakeArticleCard from "../../components/Intake/IntakeArticleCard.astro";
import IntakeTagPill from "../../components/Intake/IntakeTagPill.astro";
import {
  getAllIntakeArticleSlugs,
  getIntakeArticleBySlug,
  intakeEditorialBody,
  isIntakeHubSlug,
  INTAKE_HUB_SLUGS,
  getIntakeHubMeta,
  getIntakeHubArticles,
  getIntakeNewsFeaturedArticle,
} from "../../data/theIntakePage";
import { intakeImage } from "../../lib/intakeImages";
import icdFeatured from "../../assets/icd-10-code-changes-for-2025-592x400.webp";

const icdFeaturedSrc = typeof icdFeatured === "string" ? icdFeatured : icdFeatured.src;

export function getStaticPaths() {
  const hubPaths = INTAKE_HUB_SLUGS.map((slug) => ({ params: { slug } }));
  const articlePaths = getAllIntakeArticleSlugs()
    .filter((s) => !isIntakeHubSlug(s))
    .map((slug) => ({ params: { slug } }));
  return [...hubPaths, ...articlePaths];
}

const slug = Astro.params.slug ?? "";
const hubMeta = isIntakeHubSlug(slug) ? getIntakeHubMeta(slug) : null;
const article = !hubMeta ? getIntakeArticleBySlug(slug) : null;

if (!hubMeta && !article) {
  return Astro.redirect("/theintake");
}

const hubArticles = hubMeta ? getIntakeHubArticles(slug) : [];
const newsFeatured = hubMeta?.kind === "news" ? getIntakeNewsFeaturedArticle() : undefined;

const layoutTitle = hubMeta
  ? `${hubMeta.title} | The Intake`
  : `${article!.title} | The Intake`;
const layoutDescription = hubMeta
  ? hubMeta.description
  : article!.excerpt ??
    article!.pullQuote?.replace(/^["“]|["”]$/g, "").slice(0, 155) ??
    `${article!.title} — ${article!.author} on The Intake.`;

let articleBody: string[] = [];
let articleImageSrc = "";
if (article) {
  articleImageSrc = intakeImage(article.imageKey);
  articleBody = intakeEditorialBody(article.title, article.author);
}
---

<IntakeLayout title={layoutTitle} description={layoutDescription}>
  {
    hubMeta?.kind === "icd" ? (
      <IntakeIcdGlossary />
    ) : hubMeta?.kind === "category" ? (
      <IntakeCategoryHub
        title={hubMeta.title}
        description={hubMeta.description}
        articles={hubArticles}
        viewAllHref={hubMeta.viewAllHref}
      />
    ) : hubMeta?.kind === "news" ? (
      <>
        <section class="border-b border-gray-100 bg-[#F8F9F9] py-10 sm:py-12 lg:py-14">
          <div class="max-w-content mx-auto px-4 text-center sm:px-6 lg:px-12">
            <h1 class="font-display text-3xl font-bold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.5rem]">
              {hubMeta.title}
            </h1>
            <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg">
              {hubMeta.description}
            </p>
          </div>
        </section>
        {newsFeatured ? (
          <div class="max-w-content mx-auto px-4 py-10 sm:px-6 lg:px-12 lg:py-12">
            <IntakeSplitFeature article={newsFeatured} imageSrc={icdFeaturedSrc} />
          </div>
        ) : null}
        <section class="border-t border-gray-100 bg-white py-10 lg:py-14">
          <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-12">
            <h2 class="font-display text-xl font-bold text-tebra-teal-dark sm:text-2xl">More stories</h2>
            <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {hubArticles.map((a) => (
                <IntakeArticleCard article={a} imageSrc={intakeImage(a.imageKey)} size="md" />
              ))}
            </div>
          </div>
        </section>
      </>
    ) : hubMeta?.kind === "reports" ? (
      <>
        <section class="border-b border-gray-100 bg-[#F8F9F9] py-10 sm:py-12 lg:py-14">
          <div class="max-w-content mx-auto px-4 text-center sm:px-6 lg:px-12">
            <h1 class="font-display text-3xl font-bold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.5rem]">
              {hubMeta.title}
            </h1>
            <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg">
              {hubMeta.description}
            </p>
          </div>
        </section>
        <section class="py-10 lg:py-14">
          <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-12">
            <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {hubArticles.length ? (
                hubArticles.map((a) => (
                  <IntakeArticleCard article={a} imageSrc={intakeImage(a.imageKey)} size="md" />
                ))
              ) : (
                <p class="text-gray-600">No reports yet — browse The Intake for the latest.</p>
              )}
            </div>
          </div>
        </section>
      </>
    ) : article ? (
      <article class="border-b border-gray-100 bg-white">
        <div class="max-w-content mx-auto px-4 py-8 sm:px-6 lg:px-12 lg:py-10">
          <nav class="text-sm text-gray-500" aria-label="Breadcrumb">
            <a href="/theintake" class="font-medium text-tebra-teal-dark hover:underline">
              The Intake
            </a>
            <span class="mx-2" aria-hidden="true">
              /
            </span>
            <span class="line-clamp-1 text-gray-700">{article.title}</span>
          </nav>

          <div class="mt-8 grid gap-10 lg:grid-cols-2 lg:items-start lg:gap-12">
            <div class="overflow-hidden rounded-2xl border border-gray-100 bg-gray-50 shadow-sm">
              <div class="relative aspect-[16/10] min-h-[200px] w-full sm:min-h-[240px]">
                <img
                  src={articleImageSrc}
                  alt=""
                  class="intake-media-fill absolute inset-0"
                  width={1200}
                  height={750}
                  loading="eager"
                />
              </div>
            </div>

            <header class="min-w-0">
              {article.heroEyebrow ? (
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-tebra-orange">{article.heroEyebrow}</p>
              ) : null}
              <div class="mt-3 flex flex-wrap items-center gap-2 text-[11px] font-semibold uppercase tracking-wide text-gray-500">
                <IntakeTagPill label={article.tag.label} tone={article.tag.tone} />
                <span class="text-gray-400">·</span>
                <span>{article.readTime}</span>
              </div>
              <h1 class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.25rem] lg:leading-tight">
                {article.title}
              </h1>
              <p class="mt-4 text-base font-semibold text-gray-900">By {article.author}</p>
              {article.pullQuote ? (
                <blockquote class="mt-6 border-l-4 border-tebra-orange/80 bg-tebra-hero-bg/80 py-4 pl-5 pr-4 text-lg font-medium leading-relaxed text-tebra-teal-dark">
                  {article.pullQuote}
                </blockquote>
              ) : null}
              {article.excerpt ? <p class="mt-6 text-lg leading-relaxed text-gray-600">{article.excerpt}</p> : null}
            </header>
          </div>

          <div class="mt-12 max-w-3xl space-y-5">
            {articleBody.map((p) => (
              <p class="text-base leading-relaxed text-gray-700">{p}</p>
            ))}
          </div>

          <div class="mt-12 flex flex-wrap gap-4 border-t border-gray-100 pt-10">
            <a
              href="/theintake"
              class="inline-flex items-center rounded-full border border-gray-300 px-5 py-2.5 text-sm font-semibold text-tebra-teal-dark hover:border-tebra-teal hover:bg-gray-50"
            >
              ← Back to The Intake
            </a>
            <a
              href="/demo"
              class="inline-flex items-center rounded-full bg-tebra-cta-coral px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:opacity-95"
            >
              Request a demo
            </a>
          </div>
        </div>
      </article>
    ) : (
      <div class="max-w-content mx-auto px-4 py-16 text-center">
        <p class="text-gray-600">This section is coming soon.</p>
        <a href="/theintake" class="mt-4 inline-block font-semibold text-tebra-teal-dark hover:underline">
          Back to The Intake
        </a>
      </div>
    )
  }
</IntakeLayout>
