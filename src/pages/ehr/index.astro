---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeatureSplitHero from "../../components/Layout/FeatureSplitHero.astro";
import RatingStrip from "../../components/Hero/RatingStrip.astro";
import ehrpageImage from "../../assets/ehrpage.webp";
import fabiusImage from "../../assets/Fabius.webp";
import ehrBadgeImage from "../../assets/EHR-features-badge.webp";
const ehrpageSrc = typeof ehrpageImage === "string" ? ehrpageImage : ehrpageImage.src;
const fabiusSrc = typeof fabiusImage === "string" ? fabiusImage : fabiusImage.src;
const ehrBadgeSrc = typeof ehrBadgeImage === "string" ? ehrBadgeImage : ehrBadgeImage.src;
---

<BaseLayout
  title="EHR Software for Independent Practices | Tebra"
  description="From charting and patient records to scheduling, billing, and telehealth, Tebra's EHR platform connects all workflows into a single, cloud-based electronic health records system."
>
  <!-- Promo banner -->
  <a
    href="/ehr-calculator/step-1"
    class="block bg-[#FFF5F0] border-b border-[#FFE4DC] py-2.5 text-center text-sm font-medium text-[#8B4513] hover:bg-[#FFEDE6] transition-colors"
  >
    Stuck with an expensive EHR? | Discover your cost savings in minutes →
  </a>

  <!-- Hero -->
  <FeatureSplitHero class="bg-white">
    <div slot="left" class="space-y-6">
      <RatingStrip />
      <h1 class="text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
        EHR software for independent healthcare practices
      </h1>
      <p class="max-w-xl text-lg text-gray-600 leading-relaxed">
        From charting and patient records to scheduling, billing, and telehealth, Tebra's EHR platform connects all workflows into a single, cloud-based electronic health records system.
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <a
          href="#demo"
          class="inline-flex items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#ff5a49] transition-colors"
        >
          See Tebra EHR in action
        </a>
        <a
          href="/ehr-calculator/step-1"
          class="inline-flex items-center justify-center rounded-full border border-tebra-teal bg-white px-6 py-3 text-sm font-semibold text-tebra-teal hover:bg-tebra-hero-bg transition-colors"
        >
          Try EHR savings calculator
        </a>
      </div>
    </div>

    <div slot="right" class="relative flex justify-center lg:justify-end">
      <img
        src={ehrpageSrc}
        alt="Tebra EHR software for independent healthcare practices - electronic labs, prescriptions, and telehealth"
        class="w-full max-w-lg rounded-2xl border border-gray-100 shadow-xl object-contain"
        loading="lazy"
      />
    </div>
  </FeatureSplitHero>

  <!-- How to choose EHR -->
  <section class="bg-gray-50 border-t border-gray-100">
    <div class="page-container py-16 lg:py-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl">
          How to choose the right EHR software for your practice
        </h2>
        <p class="mt-4 text-lg text-gray-600">
          View the features, practice types, comparisons, and answers you need to evaluate Tebra EHR.
        </p>
      </div>

      <!-- Pill tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-14">
        <a
          href="#ehr-features"
          class="rounded-full bg-tebra-100 px-5 py-2.5 text-sm font-semibold text-tebra-teal-dark hover:bg-tebra-200 transition-colors"
        >
          EHR features
        </a>
        <a
          href="#practice-types"
          class="rounded-full bg-white border border-gray-200 px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:border-tebra-teal transition-colors"
        >
          Practice types
        </a>
        <a
          href="#compare"
          class="rounded-full bg-white border border-gray-200 px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:border-tebra-teal transition-colors"
        >
          Compare EHR software
        </a>
        <a
          href="#faqs"
          class="rounded-full bg-white border border-gray-200 px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:border-tebra-teal transition-colors"
        >
          FAQs
        </a>
      </div>

      <!-- EHR features: centered heading + subheading -->
      <div id="ehr-features" class="text-center max-w-3xl mx-auto mb-10">
        <h3 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl">
          EHR features that support your entire practice
        </h3>
        <p class="mt-3 text-gray-600 leading-relaxed">
          The core EHR features private practices rely on day to day.
        </p>
      </div>

      <!-- Testimonial + EHR image side by side -->
      <div class="grid gap-8 lg:grid-cols-2 lg:items-center lg:gap-12 mb-14">
        <!-- Left: Testimonial box -->
        <div class="rounded-2xl bg-[#FDF5F3] border border-[#F5E0DB] p-6 sm:p-8 flex flex-col sm:flex-row gap-6 items-start">
          <div class="flex-1 text-left min-w-0">
            <p class="text-tebra-teal-dark font-medium text-lg sm:text-xl leading-snug">
              "Tebra helps my private practice grow by being easily scalable. The EHR platform is easy to navigate."
            </p>
            <div class="mt-5 flex items-center gap-4">
              <img
                src={fabiusSrc}
                alt="Dr. Fabius Santos"
                class="h-14 w-14 shrink-0 rounded-full object-cover"
                loading="lazy"
              />
              <div>
                <p class="font-semibold text-tebra-teal-dark">Dr. Fabius Santos DNP, PMHNP-BC</p>
                <p class="text-sm text-gray-500 mt-0.5">Optimal Psychiatry and Wellness</p>
              </div>
            </div>
          </div>
          <div class="shrink-0 flex items-center justify-center w-24 h-24 rounded-full bg-gray-200/80 p-3">
            <img
              src={ehrBadgeSrc}
              alt="Momentum Leader WINTER 2026 G2"
              class="w-full h-full object-contain"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Right: EHR image -->
        <div class="flex justify-center lg:justify-end">
          <img
            src={ehrpageSrc}
            alt="EHR patient demographics and practice features"
            class="w-full max-w-2xl rounded-xl border border-gray-200 shadow-lg object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
