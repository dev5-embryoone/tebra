---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AiPromoBanner from "../../components/Ai/AiPromoBanner.astro";
import FeatureSplitHero from "../../components/Layout/FeatureSplitHero.astro";
import RatingStrip from "../../components/Hero/RatingStrip.astro";
import PageSection from "../../components/Layout/PageSection.astro";
import AiHeroCollage from "../../components/Ai/AiHeroCollage.astro";
import AiFeatureMockVisual from "../../components/Ai/AiFeatureMockVisual.astro";
import PxResourceCard from "../../components/PatientExperience/PxResourceCard.astro";
import PxFaqSection from "../../components/PatientExperience/PxFaqSection.astro";
import CTASection from "../../components/Sections/CTASection.astro";
import LinkWithArrow from "../../components/LinkWithArrow/LinkWithArrow.astro";

import resourcesThumb from "../../assets/Webinar-listing-resources-page-412x264-min.png";

import {
  aiMeta,
  aiHero,
  aiTopFeatures,
  aiPoweredEhrIntro,
  aiFeatureBlocks,
  aiSecurityLine,
  aiVideoBand,
  aiTestimonials,
  aiProvidersBand,
  aiBadges,
  aiReputationIntro,
  aiReputationPillars,
  aiResourcesIntro,
  aiResources,
  aiClosingBand,
  aiBottomCta,
  aiFaqs,
} from "../../data/aiPage";

function src(img: { src: string } | string) {
  return typeof img === "string" ? img : img.src;
}

const thumbSrc = src(resourcesThumb);

function topIcon(kind: "notes" | "reply" | "insights") {
  const c = "mx-auto mb-4 flex h-14 w-14 items-center justify-center text-tebra-teal-dark";
  if (kind === "notes") {
    return `<svg class="${c}" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M18 14h22l8 8v28a4 4 0 0 1-4 4H18a4 4 0 0 1-4-4V18a4 4 0 0 1 4-4z"/><path d="M40 14v10h10"/><path d="M24 34h16M24 42h12"/><path d="M28 22h-6v-4"/></svg>`;
  }
  if (kind === "reply") {
    return `<svg class="${c}" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="28" cy="24" r="10"/><path d="M40 36c4 2 8 6 10 12H18s2-8 10-12"/><path d="M44 20h10v10"/><path d="M54 20L38 36"/></svg>`;
  }
  return `<svg class="${c}" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M32 10v8"/><path d="M32 46v8"/><path d="M14 32h8"/><path d="M42 32h8"/><circle cx="32" cy="32" r="6"/><path d="M22 22l-4-4"/><path d="M42 42l4 4"/></svg>`;
}

function mockVariantForBlock(id: string): "notes" | "reviews" | "insights" {
  if (id === "ai-note-assist") return "notes";
  if (id === "ai-review-replies") return "reviews";
  return "insights";
}
---

<BaseLayout title={aiMeta.title} description={aiMeta.description}>
  <AiPromoBanner slot="before-navbar" />

  <FeatureSplitHero class="bg-white" pyClass="pt-6 pb-14 lg:pt-10 lg:pb-20" align="start">
    <div slot="left" class="mx-auto flex max-w-xl flex-col space-y-6 text-center lg:mx-0 lg:max-w-none lg:text-left">
      <div class="flex justify-center lg:justify-start">
        <RatingStrip />
      </div>
      <h1 class="text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
        {aiHero.title}
      </h1>
      <p class="text-lg leading-relaxed text-gray-600 lg:max-w-xl">
        {aiHero.subtitle}
      </p>
      <div class="flex flex-wrap justify-center gap-4 pt-1 lg:justify-start">
        <a
          href={aiHero.primaryCta.href}
          class="inline-flex items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[#ff5a49]"
        >
          {aiHero.primaryCta.label}
        </a>
        <a
          href={aiHero.secondaryCta.href}
          class="inline-flex items-center justify-center rounded-full border border-tebra-teal bg-white px-6 py-3 text-sm font-semibold text-tebra-teal transition-colors hover:bg-tebra-hero-bg"
        >
          {aiHero.secondaryCta.label}
        </a>
      </div>
    </div>

    <div slot="right" class="flex justify-center lg:justify-end lg:pt-4">
      <div class="w-full max-w-lg lg:max-w-none">
        <AiHeroCollage />
      </div>
    </div>
  </FeatureSplitHero>

  <!-- Three pillars -->
  <section id="ai-features" class="border-t border-gray-100 bg-white py-14 lg:py-20">
    <div class="page-container">
      <div class="grid gap-10 md:grid-cols-3 md:gap-8 lg:gap-12">
        {
          aiTopFeatures.map((f, i) => (
            <article class="text-center">
              <div set:html={topIcon(i === 0 ? "notes" : i === 1 ? "reply" : "insights")} />
              <h2 class="text-lg font-semibold text-tebra-teal-dark sm:text-xl">{f.title}</h2>
              <p class="mt-3 text-sm leading-relaxed text-gray-600 sm:text-[15px]">{f.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Dark feature bands -->
  <section class="bg-tebra-teal-dark py-14 text-white lg:py-20" aria-labelledby="ai-powered-ehr-heading">
    <div class="page-container">
      <h2 id="ai-powered-ehr-heading" class="mx-auto max-w-4xl text-center text-2xl font-semibold leading-tight sm:text-3xl lg:text-4xl">
        {aiPoweredEhrIntro.title}
      </h2>

      <div class="mt-14 space-y-20 lg:mt-20 lg:space-y-24">
        {
          aiFeatureBlocks.map((block) => {
            const v = mockVariantForBlock(block.id);
            return (
              <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14 xl:gap-16">
                <div
                  class:list={[
                    "space-y-5",
                    block.imageRight ? "lg:order-1" : "lg:order-2",
                    "text-center lg:text-left",
                  ]}
                >
                  <p class="text-sm font-semibold uppercase tracking-wide text-tebra-orange">{block.eyebrow}</p>
                  <h3 class="text-xl font-semibold leading-snug sm:text-2xl lg:text-3xl">{block.title}</h3>
                  <p class="text-base leading-relaxed text-white/85">{block.description}</p>
                  <ul class="mx-auto max-w-xl space-y-2.5 text-left text-sm text-white/90 lg:mx-0">
                    {block.bullets.map((b) => (
                      <li class="flex gap-2">
                        <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-tebra-orange" aria-hidden="true" />
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                  <div class:list={["flex justify-center lg:justify-start"]}>
                    <a
                      href={block.cta.href}
                      class="inline-flex items-center justify-center rounded-full border border-white/40 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition hover:bg-white/15"
                    >
                      {block.cta.label}
                    </a>
                  </div>
                </div>
                <div class:list={[block.imageRight ? "lg:order-2" : "lg:order-1", "flex justify-center"]}>
                  <div class="w-full max-w-md">
                    <AiFeatureMockVisual variant={v} />
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>

      <p class="mx-auto mt-16 max-w-2xl text-center text-sm text-white/75 lg:mt-20">{aiSecurityLine}</p>
    </div>
  </section>

  <!-- Video / narrative band -->
  <PageSection variant="muted">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-tebra-orange">{aiVideoBand.eyebrow}</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-4xl">
        {aiVideoBand.title}
      </h2>
      <p class="mt-4 text-lg text-gray-600">{aiVideoBand.subtitle}</p>
    </div>
  </PageSection>

  <!-- Testimonials: mobile horizontal snap + dots; desktop 3-col grid -->
  <section class="bg-white py-14 lg:py-20" aria-label="Testimonials">
    <div class="page-container">
      <div
        id="ai-testimonial-track"
        class="scrollbar-hide flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-2 lg:grid lg:grid-cols-3 lg:gap-6 lg:overflow-visible lg:pb-0"
        tabindex="0"
      >
        {
          aiTestimonials.map((t, i) => {
            const base =
              "min-w-[min(100%,calc(100vw-2.5rem))] shrink-0 snap-center rounded-2xl border border-gray-200/80 p-6 shadow-sm sm:min-w-[min(100%,380px)] lg:min-w-0 lg:snap-none lg:p-8";
            const theme =
              t.variant === "dark"
                ? "border-tebra-teal-dark bg-tebra-teal-dark text-white"
                : t.variant === "cream"
                  ? "bg-[#F9F6F1] text-tebra-teal-dark"
                  : "bg-[#EEF2F3] text-tebra-teal-dark";
            return (
              <article class:list={[base, theme]} data-ai-testimonial-card data-index={i}>
                <p class="text-[10px] font-semibold uppercase tracking-[0.25em] text-current opacity-70">Testimonial</p>
                <blockquote class="mt-4 font-display text-lg font-semibold leading-snug sm:text-xl lg:text-2xl">
                  “{t.quote}”
                </blockquote>
                <footer class="mt-6 border-t border-current/10 pt-4 text-sm">
                  <cite class="not-italic">
                    <span class="block font-semibold">{t.author}</span>
                    <span class="mt-1 block opacity-80">{t.org}</span>
                  </cite>
                </footer>
              </article>
            );
          })
        }
      </div>
      <div id="ai-testimonial-dots" class="mt-6 flex justify-center gap-2 lg:hidden" role="tablist" aria-label="Testimonial slides">
        {
          aiTestimonials.map((_, i) => (
            <button
              type="button"
              data-ai-dot={i}
              class:list={[
                "h-2.5 w-2.5 rounded-full transition",
                i === 0 ? "bg-tebra-teal-dark" : "bg-gray-300",
              ]}
              aria-label={`Go to testimonial ${i + 1}`}
              aria-current={i === 0 ? "true" : "false"}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Providers + badges -->
  <PageSection variant="alt">
    <p class="mx-auto max-w-3xl text-center text-lg font-medium leading-relaxed text-tebra-teal-dark">
      {aiProvidersBand.title}
    </p>
    <div class="mx-auto mt-10 flex max-w-4xl flex-wrap justify-center gap-3">
      {
        aiBadges.map((b) => (
          <span class="rounded-full border border-gray-200 bg-white px-4 py-2 text-xs font-semibold text-gray-700 shadow-sm">
            {b}
          </span>
        ))
      }
    </div>
  </PageSection>

  <!-- Reputation -->
  <PageSection variant="default">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-4xl">{aiReputationIntro.title}</h2>
      <p class="mt-4 text-lg text-gray-600">{aiReputationIntro.subtitle}</p>
    </div>
    <div class="mt-12 grid gap-8 md:grid-cols-3 md:gap-6">
      {
        aiReputationPillars.map((p) => (
          <article class="rounded-2xl border border-gray-100 bg-tebra-hero-bg/60 p-6 text-center lg:p-8">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
              <svg class="h-6 w-6 text-tebra-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                <path d="M9 12l2 2 4-4" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-tebra-teal-dark">{p.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-600">{p.description}</p>
          </article>
        ))
      }
    </div>
  </PageSection>

  <!-- Resources -->
  <PageSection variant="muted">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row sm:items-end">
      <h2 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl">{aiResourcesIntro.title}</h2>
      <LinkWithArrow label={aiResourcesIntro.linkLabel} href={aiResourcesIntro.linkHref} external={false} />
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        aiResources.map((r, i) => (
          <PxResourceCard
            type={r.type}
            title={r.title}
            href={r.href}
            imageSrc={i < 4 ? thumbSrc : undefined}
            imageAlt={r.title}
          />
        ))
      }
    </div>
  </PageSection>

  <!-- Closing band -->
  <section class="relative overflow-hidden bg-[#FAF9F6] py-16 lg:py-24">
    <div class="pointer-events-none absolute -right-20 top-10 h-48 w-48 rounded-full bg-tebra-hero-bg opacity-80" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -left-16 bottom-0 h-40 w-40 rounded-full bg-orange-100/40" aria-hidden="true"></div>
    <div class="page-container relative text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-4xl">{aiClosingBand.title}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">{aiClosingBand.description}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href={aiClosingBand.primaryCta.href}
          class="inline-flex items-center justify-center rounded-full bg-tebra-orange px-7 py-3.5 text-sm font-semibold text-white shadow-sm transition hover:bg-[#ff5a49]"
        >
          {aiClosingBand.primaryCta.label}
        </a>
        <a
          href={aiClosingBand.secondaryCta.href}
          class="inline-flex items-center justify-center rounded-full border border-tebra-teal bg-white px-7 py-3.5 text-sm font-semibold text-tebra-teal transition hover:bg-tebra-hero-bg"
        >
          {aiClosingBand.secondaryCta.label}
        </a>
      </div>
    </div>
  </section>

  <PxFaqSection faqs={[...aiFaqs]} id="faq" showEyebrow={false} centered />

  <CTASection
    title={aiBottomCta.title}
    description={aiBottomCta.description}
    primaryCtaLabel={aiBottomCta.primaryCtaLabel}
    primaryCtaHref={aiBottomCta.primaryCtaHref}
    secondaryCtaLabel={aiBottomCta.secondaryCtaLabel}
    secondaryCtaHref={aiBottomCta.secondaryCtaHref}
  />
</BaseLayout>

<script>
  const track = document.getElementById("ai-testimonial-track");
  const dots = document.querySelectorAll("[data-ai-dot]");
  const cards = document.querySelectorAll("[data-ai-testimonial-card]");

  if (track && dots.length && cards.length) {
    const setActive = (index) => {
      dots.forEach((d, i) => {
        const on = i === index;
        d.classList.toggle("bg-tebra-teal-dark", on);
        d.classList.toggle("bg-gray-300", !on);
        d.setAttribute("aria-current", on ? "true" : "false");
      });
    };

    const scrollToIndex = (index) => {
      const card = cards[index];
      if (!card) return;
      track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: "smooth" });
    };

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const idx = Number(dot.getAttribute("data-ai-dot"));
        if (!Number.isNaN(idx)) scrollToIndex(idx);
      });
    });

    let scrollTimeout;
    track.addEventListener("scroll", () => {
      window.clearTimeout(scrollTimeout);
      scrollTimeout = window.setTimeout(() => {
        const trackRect = track.getBoundingClientRect();
        const mid = trackRect.left + trackRect.width / 2;
        let best = 0;
        let bestDist = Infinity;
        cards.forEach((card, i) => {
          const r = card.getBoundingClientRect();
          const c = r.left + r.width / 2;
          const dist = Math.abs(c - mid);
          if (dist < bestDist) {
            bestDist = dist;
            best = i;
          }
        });
        setActive(best);
      }, 50);
    });

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 1024px)").matches) setActive(0);
    });
  }
</script>
