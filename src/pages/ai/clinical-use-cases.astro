---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button/Button.astro";
import useCaseVisual from "../../assets/ai-grading-lab-workflow.png";

const useCases = [
  {
    title: "Embryo Selection",
    copy: "Improve consistency in selecting embryos for transfer.",
  },
  {
    title: "Lab Workflow Optimization",
    copy: "Reduce manual steps and accelerate grading.",
  },
  {
    title: "Quality Assurance",
    copy: "Standardize grading across teams and locations.",
  },
  {
    title: "Decision Support",
    copy: "Provide data-backed insights for clinicians.",
  },
];

const roleValue = [
  "Embryologists: faster grading",
  "Doctors: better insights",
  "Lab Directors: standardized performance",
];

const workflowSteps = [
  {
    number: "1",
    icon: "📷",
    label: "Capture",
    title: "Capture",
    description:
      "Capture embryo images directly from your imaging workflow and route them into one structured review stream. No duplicate uploads or disconnected handoffs between lab tools.",
  },
  {
    number: "2",
    icon: "🧠",
    label: "Grade",
    title: "Grade",
    description:
      "AI evaluates morphology and proposes grades with confidence context in seconds. Teams can prioritize high-impact reviews faster while preserving consistency across operators.",
  },
  {
    number: "3",
    icon: "🔎",
    label: "Review",
    title: "Review",
    description:
      "Embryologists validate, compare, and refine AI outputs in a guided review interface. This creates a shared quality checkpoint before clinical decisions are finalized.",
  },
  {
    number: "4",
    icon: "🩺",
    label: "Decide",
    title: "Decide",
    description:
      "Clinicians receive structured, decision-ready grading context to support transfer planning. Insights remain explainable and connected to the full lab assessment history.",
  },
  {
    number: "5",
    icon: "📝",
    label: "Document",
    title: "Document",
    description:
      "Final outcomes, user actions, and overrides are recorded in an audit-ready trail. Documentation stays complete and aligned with quality and compliance expectations.",
  },
];

const outcomes = ["Reduced decision time", "Improved consistency", "Better documentation"];

const clinicalFaqs = [
  {
    question: "How does AI support embryo selection without replacing clinical judgment?",
    answer:
      "EmbryoOne AI provides structured grading support, confidence context, and morphology-based insights to inform decisions. Final selection always remains with the clinical team, allowing embryologists and doctors to apply expert judgment at every stage. This creates stronger consistency while preserving full human control.",
  },
  {
    question: "Can the platform be used across different embryologists and shift teams?",
    answer:
      "Yes. The workflows are designed to standardize grading and review patterns across users, helping reduce variation between shifts and team members. Shared process steps, traceable decisions, and consistent output formats help teams collaborate with fewer interpretation gaps. This improves continuity in high-volume lab operations.",
  },
  {
    question: "How does AI help improve day-to-day lab workflow efficiency?",
    answer:
      "AI accelerates image assessment and highlights priority cases faster, reducing manual review time in routine workflows. Teams can move from capture to review and documentation with fewer handoffs and less administrative overhead. This helps labs keep pace during peak cycle windows without compromising quality.",
  },
  {
    question: "What visibility do doctors and lab directors get from clinical use cases?",
    answer:
      "Doctors receive clearer grading context and faster access to decision-ready embryo information, improving treatment planning speed. Lab directors gain a more standardized operational view across teams, including consistency and process adherence patterns. Together, this supports stronger clinical coordination and better governance.",
  },
  {
    question: "Is every decision and review action traceable for quality assurance?",
    answer:
      "Yes. EmbryoOne captures review activity, grade confirmations, and workflow actions as part of an auditable record. Teams can reconstruct decision pathways for internal QA discussions and compliance checks without manual reconciliation. This supports safer operations and more reliable documentation practices.",
  },
];
---

<BaseLayout
  title="Clinical Use Cases | EmbryoOne AI"
  description="See how EmbryoOne AI supports embryo selection, workflow optimization, quality assurance, and day-to-day clinical decisions."
>
  <section class="page-section bg-white">
    <div class="page-container grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="eyebrow text-[#6C3CF0]">Clinical Use Cases</p>
        <h1 class="mt-3 text-4xl font-semibold leading-tight text-tebra-teal-dark sm:text-5xl">
          AI that supports real clinical decisions
        </h1>
        <p class="mt-5 max-w-xl text-base text-gray-600 sm:text-lg">
          From embryo selection to workflow optimization, EmbryoOne AI integrates directly into
          everyday IVF lab operations.
        </p>
        <p class="mt-4 max-w-xl text-base text-gray-600 sm:text-lg">
          Designed for real lab pace, the platform helps teams assess embryos faster, prioritize
          review with confidence signals, and maintain consistent grading standards across shifts.
          This supports clearer communication between embryologists, clinicians, and lab leadership.
        </p>
        <p class="mt-4 max-w-xl text-base text-gray-600 sm:text-lg">
          By connecting grading insights to downstream workflow decisions, EmbryoOne reduces manual
          coordination overhead and improves traceability from analysis to final clinical action.
          Teams gain stronger operational control without compromising expert judgment.
        </p>
      </div>
      <img
        src={useCaseVisual.src}
        alt="Clinical workflow screen showing AI support in embryo review"
        class="w-full rounded-3xl border border-[#E9DDFB] shadow-[0_24px_48px_-34px_rgba(108,60,240,0.45)]"
        loading="lazy"
      />
    </div>
  </section>

  <section class="page-section bg-[#F7F1FF]">
    <div class="page-container">
      <h2 class="heading-md text-center text-tebra-teal-dark">Use Cases in Practice</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {useCases.map((item) => (
          <article class="rounded-2xl border border-[#EADDFD] bg-white p-6 shadow-[0_14px_28px_-24px_rgba(108,60,240,0.55)]">
            <h3 class="text-xl font-semibold text-[#4A1F82]">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[#574C6A]">{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-white">
    <div class="page-container grid gap-8 md:grid-cols-2 md:items-center md:[grid-template-columns:minmax(0,0.95fr)_minmax(0,1.05fr)] lg:gap-12">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Workflow Integration</h2>
        <p class="mt-4 text-base text-gray-700">
          AI fits directly into your existing workflow with no disruption to clinical routines and
          no added tool switching for your team.
        </p>
        <p class="mt-4 text-base text-gray-700">
          From image intake to final documentation, each stage remains connected so teams can move
          faster without losing decision quality or traceability context.
        </p>
        <p class="mt-6 text-base font-medium text-[#51285f]">No disruption. Just enhancement.</p>
      </div>

      <div class="rounded-3xl border border-[#E3D8FF] bg-[#F3EEFF] p-6 shadow-[0_24px_44px_-34px_rgba(15,23,42,0.45)] sm:p-8">
        <div class="relative space-y-6">
          <div
            class="clinical-stepper-line-track pointer-events-none absolute left-[1.15rem] top-6 h-[calc(100%-5.65rem)] w-px overflow-hidden"
            aria-hidden="true"
          >
            <div class="clinical-stepper-line-track-inner h-full w-full origin-top bg-[#F39A7B]"></div>
          </div>

          {workflowSteps.map((step, index) => (
            <div class="clinical-stepper-item relative">
              <div class="flex items-start gap-4">
                <div class="relative z-[1] mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#F3EEFF] text-[42px] font-semibold leading-none text-[#51285f]">
                  {step.number}
                </div>
                <div class="min-w-0">
                  <p class="text-xs font-semibold uppercase tracking-wide text-[#51285f]/70">
                    <span class="mr-1" aria-hidden="true">{step.icon}</span>{step.label}
                  </p>
                  <h3 class="mt-1 text-base font-semibold text-[#51285f]">{step.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-[#5B4F70]">{step.description}</p>
                </div>
              </div>
              {index < workflowSteps.length - 1 && <div class="mt-1"></div>}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="page-section bg-[#F7F1FF]">
    <div class="page-container">
      <h2 class="heading-md text-tebra-teal-dark">Role-Based Value</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        {roleValue.map((item) => {
          const [role, value] = item.split(":");
          return (
            <div class="rounded-2xl border border-[#EADDFD] bg-[#FAF7FF] p-5 shadow-[0_14px_28px_-24px_rgba(108,60,240,0.45)]">
              <p class="text-sm font-semibold uppercase tracking-wide text-[#7A56A8]">{role}</p>
              <p class="mt-2 text-base font-medium text-[#51285f]">{value?.trim() ?? item}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-[#51285f]">
    <div class="page-container">
      <div class="mx-auto max-w-5xl">
        <p class="eyebrow !text-gray-200">Clinical Use Cases FAQ</p>
        <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">Frequently Asked Questions</h2>
        <p class="mt-4 text-base text-gray-200">
          Answers to common questions about how AI supports clinical decisions, team workflows, and
          operational consistency in IVF labs.
        </p>
        <div class="mt-8 space-y-3">
          {clinicalFaqs.map((item, index) => (
            <details
              class="rounded-2xl border border-white/20 bg-white/5 px-5 py-4 text-white"
              open={index === 0}
            >
              <summary class="cursor-pointer list-none pr-7 text-base font-semibold marker:content-none">
                {item.question}
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-gray-200">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="page-container rounded-3xl bg-[#51285f] px-6 py-10 text-white sm:px-10">
      <h2 class="text-3xl font-semibold sm:text-4xl">See AI in your workflow across your IVF workflows</h2>
      <div class="mt-7">
        <Button href="/demo" label="Book demo" variant="outline-light" size="md" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .clinical-stepper-item {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 900ms ease,
      transform 900ms ease;
  }

  .clinical-stepper-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .clinical-stepper-line-track-inner {
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 900ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .clinical-stepper-item {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .clinical-stepper-line-track-inner {
      transform: scaleY(1);
      transition: none;
    }
  }
</style>

<script>
  const clinicalStepperItems = Array.from(document.querySelectorAll(".clinical-stepper-item"));
  const clinicalLineInner = document.querySelector(".clinical-stepper-line-track-inner");
  const clinicalStepCount = clinicalStepperItems.length;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const setClinicalLineProgress = (fraction) => {
    if (clinicalLineInner) clinicalLineInner.style.transform = `scaleY(${Math.min(1, Math.max(0, fraction))})`;
  };

  if (reduceMotion) {
    clinicalStepperItems.forEach((item) => item.classList.add("is-visible"));
    if (clinicalLineInner) clinicalLineInner.style.transform = "scaleY(1)";
  } else if (clinicalStepperItems.length) {
    let animationFrame = null;
    if (clinicalLineInner) clinicalLineInner.style.transform = "scaleY(0)";

    const playClinicalStepperAnimation = () => {
      clinicalStepperItems.forEach((item) => item.classList.remove("is-visible"));
      setClinicalLineProgress(0);
      animationFrame = window.requestAnimationFrame(() => {
        clinicalStepperItems.forEach((item, index) => {
          window.setTimeout(() => {
            item.classList.add("is-visible");
            setClinicalLineProgress((index + 1) / clinicalStepCount);
          }, index * 520);
        });
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            playClinicalStepperAnimation();
          } else {
            clinicalStepperItems.forEach((item) => item.classList.remove("is-visible"));
            setClinicalLineProgress(0);
            if (animationFrame) {
              window.cancelAnimationFrame(animationFrame);
              animationFrame = null;
            }
          }
        });
      },
      { threshold: 0.35 }
    );

    observer.observe(clinicalStepperItems[0]);
  }
</script>
