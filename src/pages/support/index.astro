---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/Cards/ContentCard.astro";
import { pageCards } from "../../data/pageCards";

const cards = pageCards.support ?? [];
---
<BaseLayout
  title="Support | Tebra"
  description="Get help and support for Tebra products."
>
  <section class="page-section bg-white">
    <div class="page-container">
      <h1 class="text-3xl font-semibold text-gray-900">Support</h1>
      <p class="mt-3 max-w-2xl text-gray-600">
        Visit the{" "}
        <a href="/help" class="font-semibold text-tebra-teal underline hover:no-underline">
          Tebra Help Center
        </a>{" "}
        for articles and how-tos, or explore quick links below.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {cards.map((card) => (
          <ContentCard title={card.title} description={card.description} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
