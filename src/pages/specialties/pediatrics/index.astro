---
import SpecialtyLandingPage from "../../../components/Specialties/SpecialtyLandingPage.astro";
import heroImageRaw from "../../../assets/LP-Campaign-Photo-Carousel-Image-1200x1080-1.png";
import accMarketing from "../../../assets/medical-practice-marketing-min.webp";
import accPx from "../../../assets/patient-experience.webp";
import accEhr from "../../../assets/EHR-min.webp";
import accBilling from "../../../assets/BILLING-PAYMENTS-min.webp";
import accInsights from "../../../assets/Challenge-Solution-Results_1112x1112.webp";
import accImpl from "../../../assets/Simplify-operations.png";
import {
  pediatricsMeta,
  pediatricsBreadcrumb,
  pediatricsHero,
  pediatricsAccordionIntro,
  pediatricsAccordionItems,
  pediatricsWhyIntro,
  pediatricsWhyBlocks,
  pediatricsChallengesIntro,
  pediatricsStats,
  pediatricsMidCta,
  pediatricsPlatformIntro,
  pediatricsPlatformCards,
  pediatricsTestimonialsIntro,
  pediatricsTestimonials,
  pediatricsCaseStudiesIntro,
  pediatricsCaseStudySlugs,
  pediatricsBottomCta,
} from "../../../data/pediatricsPage";
import { caseStudies, type CaseStudy } from "../../../data/caseStudies";
import type { SpecialtyLandingConfig } from "../../../data/specialtyPageTypes";

const heroImage = typeof heroImageRaw === "string" ? heroImageRaw : heroImageRaw.src;
const accordionImages = [
  typeof accMarketing === "string" ? accMarketing : accMarketing.src,
  typeof accPx === "string" ? accPx : accPx.src,
  typeof accEhr === "string" ? accEhr : accEhr.src,
  typeof accBilling === "string" ? accBilling : accBilling.src,
  typeof accInsights === "string" ? accInsights : accInsights.src,
  typeof accImpl === "string" ? accImpl : accImpl.src,
];

const accordionItems = pediatricsAccordionItems.map((item, i) => ({
  title: item.title,
  body: item.body,
  image: accordionImages[i] ?? accordionImages[0],
  imageAlt: `${item.title} — Tebra for pediatrics`,
}));

const featuredCaseStudies = pediatricsCaseStudySlugs
  .map((slug) => caseStudies.find((c) => c.slug === slug))
  .filter((c): c is CaseStudy => Boolean(c));

const config: SpecialtyLandingConfig = {
  meta: { ...pediatricsMeta },
  breadcrumb: [...pediatricsBreadcrumb],
  hero: {
    eyebrow: pediatricsHero.eyebrow,
    title: pediatricsHero.title,
    subtitle: pediatricsHero.subtitle,
    primaryCta: { ...pediatricsHero.primaryCta },
    secondaryCta: { ...pediatricsHero.secondaryCta },
    imageSrc: heroImage,
    imageAlt: "Caregiver and child — pediatric care with Tebra",
    showRatingStrip: false,
    showComplianceStrip: false,
  },
  valueSection: {
    mode: "accordion",
    accordionName: "pediatrics-why",
    sectionTitle: pediatricsAccordionIntro.title,
    items: accordionItems,
  },
  whyTebra: {
    eyebrow: pediatricsWhyIntro.eyebrow,
    title: pediatricsWhyIntro.title,
    blocks: pediatricsWhyBlocks.map((b) => ({ title: b.title, description: b.description })),
    titleStyle: "serif",
    gridVariant: "spacious",
  },
  challenges: {
    title: pediatricsChallengesIntro.title,
    stats: pediatricsStats.map((s) => ({ ...s })),
    midCta: { ...pediatricsMidCta },
    midCtaStyle: "overlay",
  },
  platform: {
    eyebrow: pediatricsPlatformIntro.eyebrow,
    title: pediatricsPlatformIntro.title,
    subtitle: pediatricsPlatformIntro.subtitle,
    cards: pediatricsPlatformCards.map((c) => ({ ...c })),
  },
  testimonials: {
    title: pediatricsTestimonialsIntro.title,
    items: pediatricsTestimonials.map((t) => ({ ...t })),
  },
  caseStudies: {
    title: pediatricsCaseStudiesIntro.title,
    ctaLabel: pediatricsCaseStudiesIntro.ctaLabel,
    ctaHref: pediatricsCaseStudiesIntro.ctaHref,
    studies: featuredCaseStudies,
  },
  bottomCta: { ...pediatricsBottomCta },
};
---

<SpecialtyLandingPage config={config} />
