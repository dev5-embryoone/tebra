---
import SpecialtyLandingPage from "../../../components/Specialties/SpecialtyLandingPage.astro";
import heroImageRaw from "../../../assets/Amanda-Piwonka-1.jpg";
import accMarketing from "../../../assets/medical-practice-marketing-min.webp";
import accPx from "../../../assets/patient-experience.webp";
import accEhr from "../../../assets/EHR-min.webp";
import accBilling from "../../../assets/BILLING-PAYMENTS-min.webp";
import accInsights from "../../../assets/Challenge-Solution-Results_1112x1112.webp";
import accImpl from "../../../assets/Simplify-operations.png";
import accEhrExtra from "../../../assets/ehrpage.webp";
import {
  npMeta,
  npBreadcrumb,
  npHero,
  npAccordionIntro,
  npAccordionItems,
  npWhyIntro,
  npWhyBlocks,
  npChallengesIntro,
  npStats,
  npMidCta,
  npPlatformIntro,
  npPlatformCards,
  npTestimonials,
  npCaseStudiesIntro,
  npCaseStudySlugs,
  npBottomCta,
} from "../../../data/nursePractitionersPage";
import { caseStudies, type CaseStudy } from "../../../data/caseStudies";
import type { SpecialtyLandingConfig } from "../../../data/specialtyPageTypes";

const heroImage = typeof heroImageRaw === "string" ? heroImageRaw : heroImageRaw.src;
const accordionImages = [
  typeof accMarketing === "string" ? accMarketing : accMarketing.src,
  typeof accPx === "string" ? accPx : accPx.src,
  typeof accEhr === "string" ? accEhr : accEhr.src,
  typeof accBilling === "string" ? accBilling : accBilling.src,
  typeof accInsights === "string" ? accInsights : accInsights.src,
  typeof accImpl === "string" ? accImpl : accImpl.src,
  typeof accEhrExtra === "string" ? accEhrExtra : accEhrExtra.src,
];

const accordionItems = npAccordionItems.map((item, i) => ({
  title: item.title,
  body: item.body,
  image: accordionImages[i % accordionImages.length],
  imageAlt: `${item.title} — Tebra for nurse practitioners`,
}));

const featuredCaseStudies = npCaseStudySlugs
  .map((slug) => caseStudies.find((c) => c.slug === slug))
  .filter((c): c is CaseStudy => Boolean(c));

const config: SpecialtyLandingConfig = {
  meta: { ...npMeta },
  breadcrumb: [...npBreadcrumb],
  hero: {
    eyebrow: npHero.eyebrow,
    title: npHero.title,
    subtitle: npHero.subtitle,
    primaryCta: { ...npHero.primaryCta },
    secondaryCta: { ...npHero.secondaryCta },
    imageSrc: heroImage,
    imageAlt: "Nurse practitioner with tablet providing patient care",
    showRatingStrip: false,
    showComplianceStrip: false,
  },
  valueSection: {
    mode: "accordion",
    accordionName: "nurse-practitioners-why",
    sectionTitle: npAccordionIntro.title,
    items: accordionItems,
  },
  whyTebra: {
    eyebrow: npWhyIntro.eyebrow,
    title: npWhyIntro.title,
    blocks: npWhyBlocks.map((b) => ({ title: b.title, description: b.description })),
    titleStyle: "serif",
    gridVariant: "spacious",
  },
  challenges: {
    title: npChallengesIntro.title,
    stats: npStats.map((s) => ({ ...s })),
    midCta: { ...npMidCta },
    midCtaStyle: "overlay",
  },
  platform: {
    eyebrow: npPlatformIntro.eyebrow,
    title: npPlatformIntro.title,
    subtitle: npPlatformIntro.subtitle,
    cards: npPlatformCards.map((c) => ({ ...c })),
  },
  testimonials: {
    title: npTestimonials.title,
    items: npTestimonials.items.map((t) => ({ ...t })),
  },
  caseStudies: {
    title: npCaseStudiesIntro.title,
    ctaLabel: npCaseStudiesIntro.ctaLabel,
    ctaHref: npCaseStudiesIntro.ctaHref,
    studies: featuredCaseStudies,
  },
  bottomCta: { ...npBottomCta },
};
---

<SpecialtyLandingPage config={config} />
