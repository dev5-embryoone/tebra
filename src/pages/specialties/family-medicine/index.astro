---
import SpecialtyLandingPage from "../../../components/Specialties/SpecialtyLandingPage.astro";
import heroImageRaw from "../../../assets/Banner_Illo.svg";
import {
  fmMeta,
  fmBreadcrumb,
  fmHero,
  fmFeaturesIntro,
  fmFeatures,
  fmWhyIntro,
  fmWhyBlocks,
  fmChallengesIntro,
  fmStats,
  fmMidCta,
  fmPlatformIntro,
  fmPlatformCards,
  fmTestimonialsIntro,
  fmTestimonials,
  fmCaseStudiesIntro,
  fmCaseStudySlugs,
  fmBottomCta,
} from "../../../data/familyMedicinePage";
import { caseStudies, type CaseStudy } from "../../../data/caseStudies";
import type { SpecialtyLandingConfig } from "../../../data/specialtyPageTypes";

const heroImage = typeof heroImageRaw === "string" ? heroImageRaw : heroImageRaw.src;

const featuredCaseStudies = fmCaseStudySlugs
  .map((slug) => caseStudies.find((c) => c.slug === slug))
  .filter((c): c is CaseStudy => Boolean(c));

const config: SpecialtyLandingConfig = {
  meta: { ...fmMeta },
  breadcrumb: [...fmBreadcrumb],
  hero: {
    eyebrow: fmHero.eyebrow,
    title: fmHero.title,
    subtitle: fmHero.subtitle,
    primaryCta: { ...fmHero.primaryCta },
    secondaryCta: { ...fmHero.secondaryCta },
    imageSrc: heroImage,
    imageAlt: "Tebra platform for family medicine practices",
  },
  valueSection: {
    mode: "grid",
    sectionTitle: fmFeaturesIntro.title,
    items: fmFeatures.map((f) => ({ title: f.title, description: f.description })),
  },
  whyTebra: {
    eyebrow: fmWhyIntro.eyebrow,
    title: fmWhyIntro.title,
    description: fmWhyIntro.subtitle,
    blocks: fmWhyBlocks.map((b) => ({ title: b.title, description: b.description })),
    titleStyle: "default",
    gridVariant: "default",
  },
  challenges: {
    title: fmChallengesIntro.title,
    stats: fmStats.map((s) => ({ ...s })),
    midCta: { ...fmMidCta },
    midCtaStyle: "inline",
  },
  platform: {
    eyebrow: fmPlatformIntro.eyebrow,
    title: fmPlatformIntro.title,
    subtitle: fmPlatformIntro.subtitle,
    cards: fmPlatformCards.map((c) => ({ ...c })),
  },
  testimonials: {
    title: fmTestimonialsIntro.title,
    items: fmTestimonials.map((t) => ({ ...t })),
  },
  caseStudies: {
    title: fmCaseStudiesIntro.title,
    ctaLabel: fmCaseStudiesIntro.ctaLabel,
    ctaHref: fmCaseStudiesIntro.ctaHref,
    studies: featuredCaseStudies,
  },
  bottomCta: { ...fmBottomCta },
};
---

<SpecialtyLandingPage config={config} />
