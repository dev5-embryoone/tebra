---
import SpecialtyLandingPage from "../../../components/Specialties/SpecialtyLandingPage.astro";
import heroImageRaw from "../../../assets/Banner-1-768x768.jpg";
import accMarketing from "../../../assets/medical-practice-marketing-min.webp";
import accPx from "../../../assets/patient-experience.webp";
import accEhr from "../../../assets/EHR-min.webp";
import accBilling from "../../../assets/BILLING-PAYMENTS-min.webp";
import accInsights from "../../../assets/Challenge-Solution-Results_1112x1112.webp";
import accImpl from "../../../assets/Simplify-operations.png";
import {
  pcMeta,
  pcBreadcrumb,
  pcHero,
  pcAccordionIntro,
  pcAccordionItems,
  pcWhyIntro,
  pcWhyBlocks,
  pcChallengesIntro,
  pcStats,
  pcMidCta,
  pcPlatformIntro,
  pcPlatformCards,
  pcTestimonialsIntro,
  pcTestimonials,
  pcCaseStudiesIntro,
  pcCaseStudySlugs,
  pcBottomCta,
} from "../../../data/primaryCarePage";
import { caseStudies, type CaseStudy } from "../../../data/caseStudies";
import type { SpecialtyLandingConfig } from "../../../data/specialtyPageTypes";

const heroImage = typeof heroImageRaw === "string" ? heroImageRaw : heroImageRaw.src;
const accordionImages = [
  typeof accMarketing === "string" ? accMarketing : accMarketing.src,
  typeof accPx === "string" ? accPx : accPx.src,
  typeof accEhr === "string" ? accEhr : accEhr.src,
  typeof accBilling === "string" ? accBilling : accBilling.src,
  typeof accInsights === "string" ? accInsights : accInsights.src,
  typeof accImpl === "string" ? accImpl : accImpl.src,
];

const accordionItems = pcAccordionItems.map((item, i) => ({
  title: item.title,
  body: item.body,
  image: accordionImages[i] ?? accordionImages[0],
  imageAlt: `${item.title} — Tebra for primary care`,
}));

const featuredCaseStudies = pcCaseStudySlugs
  .map((slug) => caseStudies.find((c) => c.slug === slug))
  .filter((c): c is CaseStudy => Boolean(c));

const config: SpecialtyLandingConfig = {
  meta: { ...pcMeta },
  breadcrumb: [...pcBreadcrumb],
  hero: {
    eyebrow: pcHero.eyebrow,
    title: pcHero.title,
    subtitle: pcHero.subtitle,
    primaryCta: { ...pcHero.primaryCta },
    secondaryCta: { ...pcHero.secondaryCta },
    imageSrc: heroImage,
    imageAlt: "Primary care physician consulting with a patient",
    showRatingStrip: false,
    showComplianceStrip: false,
  },
  valueSection: {
    mode: "accordion",
    accordionName: "primary-care-why",
    sectionTitle: pcAccordionIntro.title,
    items: accordionItems,
  },
  whyTebra: {
    eyebrow: pcWhyIntro.eyebrow,
    title: pcWhyIntro.title,
    blocks: pcWhyBlocks.map((b) => ({ title: b.title, description: b.description })),
    titleStyle: "serif",
    gridVariant: "spacious",
  },
  challenges: {
    title: pcChallengesIntro.title,
    stats: pcStats.map((s) => ({ ...s })),
    midCta: { ...pcMidCta },
    midCtaStyle: "overlay",
  },
  platform: {
    eyebrow: pcPlatformIntro.eyebrow,
    title: pcPlatformIntro.title,
    subtitle: pcPlatformIntro.subtitle,
    cards: pcPlatformCards.map((c) => ({ ...c })),
  },
  testimonials: {
    title: pcTestimonialsIntro.title,
    items: pcTestimonials.map((t) => ({ ...t })),
  },
  caseStudies: {
    title: pcCaseStudiesIntro.title,
    ctaLabel: pcCaseStudiesIntro.ctaLabel,
    ctaHref: pcCaseStudiesIntro.ctaHref,
    studies: featuredCaseStudies,
  },
  bottomCta: { ...pcBottomCta },
};
---

<SpecialtyLandingPage config={config} />
