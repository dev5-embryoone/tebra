---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Resources | Tebra"
  description="Guides, whitepapers, and resources for practice management."
>
  <section class="page-section bg-white">
    <div class="page-container">
      <h1 class="text-2xl font-semibold text-gray-900">Resources</h1>
      <p class="mt-2 text-gray-600">Guides, stories, and tools for your practice.</p>
      <ul class="mt-6 space-y-2 text-tebra-teal font-medium">
        <li>
          <a href="/resources/testimonials" class="hover:text-tebra-teal-dark underline-offset-2 hover:underline"
            >Testimonials</a
          >
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
