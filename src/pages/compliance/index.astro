---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/Cards/ContentCard.astro";
import { pageCards } from "../../data/pageCards";

const cards = pageCards.compliance ?? [];
---
<BaseLayout
  title="Compliance | Tebra"
  description="Tebra helps practices meet regulatory and compliance requirements."
>
  <section class="page-section bg-white">
    <div class="page-container">
      <h1 class="text-3xl font-semibold text-gray-900">Compliance</h1>
      <p class="mt-3 max-w-2xl text-gray-600">
        Tools and resources to help your practice meet HIPAA and other regulatory requirements.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {cards.map((card) => (
          <ContentCard title={card.title} description={card.description} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
