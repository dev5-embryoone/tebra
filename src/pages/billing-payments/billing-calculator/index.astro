---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductPageBreadcrumb from "../../../components/PatientExperience/ProductPageBreadcrumb.astro";
import BillingRevenueCalculator from "../../../components/BillingCalculator/BillingRevenueCalculator.astro";
import CTASection from "../../../components/Sections/CTASection.astro";
import {
  billingCalculatorMeta,
  billingCalculatorBreadcrumb,
  billingCalculatorHero,
  billingCalculatorBottom,
} from "../../../data/billingCalculatorPage";
---

<BaseLayout
  title={billingCalculatorMeta.title}
  description={billingCalculatorMeta.description}
  showBreadcrumb={false}
>
  <span id="demo" class="sr-only" aria-hidden="true">Demo</span>
  <section class="bg-gradient-to-b from-[#fff9f6] to-[#faf8f6] pb-4 pt-8 sm:pt-10 lg:pt-12">
    <div class="page-container">
      <ProductPageBreadcrumb items={[...billingCalculatorBreadcrumb]} />
      <div class="mx-auto max-w-4xl text-center">
        <h1
          class="font-display text-3xl font-bold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.35rem] lg:leading-tight"
        >
          {billingCalculatorHero.title}
        </h1>
        <p
          class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg"
        >
          {billingCalculatorHero.subtitle}
        </p>
      </div>
    </div>
  </section>

  <BillingRevenueCalculator />

  <section class="border-t border-gray-100 bg-white py-14 lg:py-20">
    <div class="page-container">
      <div class="mx-auto max-w-3xl text-center">
        <h2
          class="text-2xl font-bold tracking-tight text-tebra-teal-dark sm:text-3xl"
        >
          {billingCalculatorBottom.title}
        </h2>
        <p class="mt-3 text-gray-600">
          {billingCalculatorBottom.subtitle}
        </p>
      </div>
      <div
        class="mx-auto mt-10 grid max-w-5xl gap-6 sm:grid-cols-2 lg:grid-cols-3"
      >
        <a
          href={billingCalculatorBottom.tour.href}
          class="group flex flex-col rounded-2xl border border-gray-200 bg-tebra-hero-bg/40 p-6 text-left transition-shadow hover:shadow-md"
        >
          <span class="text-sm font-semibold text-tebra-teal-dark group-hover:underline">
            {billingCalculatorBottom.tour.label}
          </span>
          <span class="mt-2 text-sm text-gray-600">
            Explore billing tools, eligibility, statements, and ERA posting.
          </span>
        </a>
        <a
          href={billingCalculatorBottom.demo.href}
          class="group flex flex-col rounded-2xl border border-gray-200 bg-white p-6 text-left transition-shadow hover:shadow-md"
        >
          <span class="text-sm font-semibold text-tebra-teal-dark group-hover:underline">
            {billingCalculatorBottom.demo.label}
          </span>
          <span class="mt-2 text-sm text-gray-600">
            See how practices and billing companies reduce denials and collect
            faster.
          </span>
        </a>
        <a
          href={billingCalculatorBottom.sales.href}
          class="group flex flex-col rounded-2xl border border-gray-200 bg-white p-6 text-left transition-shadow hover:shadow-md sm:col-span-2 lg:col-span-1"
        >
          <span class="text-sm font-semibold text-tebra-teal-dark group-hover:underline">
            {billingCalculatorBottom.sales.label}
          </span>
          <span class="mt-2 text-sm text-gray-600">
            Talk to an expert about automation and clean claims — without
            switching EHRs.
          </span>
        </a>
      </div>
    </div>
  </section>

  <CTASection
    title="Automate, optimize, and thrive with Tebra"
    description="The leading practice automation solution for independent practices."
    primaryCtaLabel="Get a demo"
    primaryCtaHref="#demo"
    secondaryCtaLabel="Explore for Free"
    secondaryCtaHref="/pricing"
  />
</BaseLayout>
