---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FeatureSplitHero from "../../../components/Layout/FeatureSplitHero.astro";
import PageSection from "../../../components/Layout/PageSection.astro";
import ProductPageBreadcrumb from "../../../components/PatientExperience/ProductPageBreadcrumb.astro";
import EcsHeroVisual from "../../../components/Billing/EcsHeroVisual.astro";
import ProductAlternatingFeature from "../../../components/Product/ProductAlternatingFeature.astro";
import CaseStudyCard from "../../../components/Cards/CaseStudyCard.astro";
import CTASection from "../../../components/Sections/CTASection.astro";
import LinkWithArrow from "../../../components/LinkWithArrow/LinkWithArrow.astro";

import heroPhoto from "../../../assets/BILLING-Hub-In-house-billers.webp";
import featImg1 from "../../../assets/BILLING-SOFTWARE-min.webp";
import featImg2 from "../../../assets/Simplify-operations.png";
import featImg3 from "../../../assets/BILLING-PAYMENTS-min.webp";
import featImg4 from "../../../assets/BILLING-Hub-Billing-cos.webp";
import featImg5 from "../../../assets/BILLING-Hub-Outsourcing-billing.webp";

import { caseStudies } from "../../../data/caseStudies";
import {
  ecsMeta,
  ecsBreadcrumb,
  ecsHero,
  ecsFeaturesIntro,
  ecsFeatures,
  ecsAllInOne,
  ecsTestimonialsIntro,
  ecsTestimonials,
  ecsCaseStudiesIntro,
  ecsCaseStudySlugs,
  ecsPreFooterCta,
  ecsIntakeIntro,
  ecsIntakeArticles,
  ecsBottomCta,
} from "../../../data/electronicClaimSubmissionPage";

function src(img: { src: string } | string) {
  return typeof img === "string" ? img : img.src;
}

const heroSrc = src(heroPhoto);
const featureImgs = [featImg1, featImg2, featImg3, featImg4, featImg5].map(src);

const featuredCaseStudies = ecsCaseStudySlugs
  .map((slug) => caseStudies.find((c) => c.slug === slug))
  .filter(Boolean);
---

<BaseLayout title={ecsMeta.title} description={ecsMeta.description} showBreadcrumb={false}>
  <div class="bg-[#FDF8F5]">
    <div class="page-container pt-8 pb-2">
      <ProductPageBreadcrumb items={[...ecsBreadcrumb]} />
    </div>
  </div>

  <!-- Hero: text first on mobile (left column), visual second — matches Tebra -->
  <FeatureSplitHero class="bg-[#FDF8F5]" align="start" pyClass="pb-14 pt-2 lg:pb-20 lg:pt-4">
    <div
      slot="left"
      class="mx-auto flex max-w-xl flex-col space-y-5 text-center lg:mx-0 lg:max-w-none lg:text-left"
    >
      <h1 class="text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
        {ecsHero.title}
      </h1>
      <p class="text-lg leading-relaxed text-tebra-teal-dark/90 lg:max-w-xl">
        {ecsHero.subtitle}
      </p>
      <div class="flex flex-wrap justify-center gap-3 pt-1 lg:justify-start">
        <a
          href={ecsHero.primaryCta.href}
          class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[#ff5a49]"
        >
          {ecsHero.primaryCta.label}
        </a>
        <a
          href={ecsHero.secondaryCta.href}
          class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-tebra-teal bg-white px-6 py-3 text-sm font-semibold text-tebra-teal transition-colors hover:bg-white/90"
        >
          {ecsHero.secondaryCta.label}
        </a>
      </div>
    </div>

    <div slot="right" class="flex justify-center lg:justify-end lg:pt-2">
      <EcsHeroVisual imageSrc={heroSrc} imageAlt="Billing specialist using Tebra for electronic claim submissions" />
    </div>
  </FeatureSplitHero>

  <!-- Main features -->
  <PageSection variant="default" class="!py-14 lg:!py-20">
    <h2
      class="mx-auto max-w-4xl text-center text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-4xl"
    >
      {ecsFeaturesIntro.title}
    </h2>
    <div class="mt-14 space-y-16 lg:mt-20 lg:space-y-24">
      {
        ecsFeatures.map((f, i) => (
          <ProductAlternatingFeature
            title={f.title}
            body={f.body}
            imageSrc={featureImgs[i % featureImgs.length]}
            imageAlt={`Tebra billing — ${f.title}`}
            reverse={i % 2 === 0}
          />
        ))
      }
    </div>
  </PageSection>

  <!-- All-in-one -->
  <section class="bg-gray-100 py-14 lg:py-20">
    <div class="page-container">
      <div
        class="overflow-hidden rounded-2xl rounded-tl-[2rem] bg-white p-8 shadow-sm ring-1 ring-gray-200/80 sm:p-10 lg:rounded-tl-[2.5rem] lg:p-12 xl:p-14"
      >
        <div class="grid gap-10 lg:grid-cols-2 lg:items-start lg:gap-14">
          <div class="text-center lg:text-left">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-tebra-teal">{ecsAllInOne.eyebrow}</p>
            <h2 class="mt-3 text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-4xl">
              {ecsAllInOne.title}
            </h2>
            <a
              href={ecsAllInOne.linkHref}
              class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-tebra-teal hover:text-tebra-teal-dark"
            >
              {ecsAllInOne.linkLabel}
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path
                  d="M6 3h7v7M13 3L5 11"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </div>
          <ul class="mx-auto max-w-md space-y-3 lg:mx-0">
            {
              ecsAllInOne.checklist.map((item) => (
                <li class="flex gap-3 text-left text-base text-gray-800">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-tebra-hero-bg text-tebra-teal" aria-hidden="true">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M3 8l3 3 7-7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="mt-10 flex justify-center border-t border-gray-100 pt-8 lg:hidden">
          <a
            href={ecsAllInOne.linkHref}
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-tebra-teal"
          >
            {ecsAllInOne.linkLabel}
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M6 3h7v7M13 3L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <PageSection variant="default" class="!py-14 lg:!py-20">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-start lg:gap-12">
      <div class="text-center lg:text-left">
        <h2 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-4xl">
          {ecsTestimonialsIntro.title}
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-gray-600 lg:mx-0">
          {ecsTestimonialsIntro.description}
        </p>
        <a
          href={ecsTestimonialsIntro.ctaHref}
          class="mt-6 inline-flex min-h-[44px] items-center justify-center rounded-full border border-tebra-teal bg-transparent px-6 py-2.5 text-sm font-semibold text-tebra-teal transition-colors hover:bg-tebra-hero-bg"
        >
          {ecsTestimonialsIntro.ctaLabel}
        </a>

        <!-- Trust badges row (desktop: under copy; mobile: full width below) -->
        <div class="mt-8 hidden flex-wrap items-center justify-center gap-3 border-t border-gray-100 pt-8 sm:flex lg:justify-start">
          <span class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-semibold text-gray-700 shadow-sm">
            Google reviews
          </span>
          <span class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-semibold text-gray-700 shadow-sm">
            G2 · 4.5
          </span>
          <span class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-semibold text-gray-700 shadow-sm">
            Capterra · Top rated
          </span>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {
          ecsTestimonials.map((t) => {
            const isDark = t.variant === "dark";
            return (
              <blockquote
                class:list={[
                  "relative flex min-h-[240px] flex-col justify-between rounded-2xl border p-6 shadow-sm sm:p-8",
                  isDark
                    ? "border-tebra-teal-dark bg-tebra-teal-dark text-white"
                    : "border-gray-200 bg-[#F5F0E8] text-tebra-teal-dark",
                ]}
              >
                {!isDark && (
                  <div
                    class="pointer-events-none absolute right-4 top-4 h-24 w-24 opacity-[0.07]"
                    aria-hidden="true"
                  >
                    <svg viewBox="0 0 100 100" fill="currentColor" class="h-full w-full">
                      <path d="M50 5 L95 30 V70 L50 95 L5 70 V30 Z" />
                    </svg>
                  </div>
                )}
                <p
                  class:list={[
                    "relative z-[1] font-display text-lg font-semibold italic leading-snug sm:text-xl",
                    isDark ? "text-white" : "text-tebra-teal-dark",
                  ]}
                >
                  {t.quote}
                </p>
                <footer class="relative z-[1] mt-6 text-sm">
                  <cite class="not-italic">
                    <span class="block font-semibold">{t.author}</span>
                    <span class:list={["mt-1 block", isDark ? "text-white/80" : "text-gray-600"]}>{t.org}</span>
                  </cite>
                </footer>
              </blockquote>
            );
          })
        }
      </div>
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3 sm:hidden">
      <span class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-semibold text-gray-700">Google reviews</span>
      <span class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-semibold text-gray-700">G2 · 4.5</span>
      <span class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-semibold text-gray-700">Capterra</span>
    </div>
  </PageSection>

  <!-- Case studies -->
  <PageSection variant="muted" class="!py-14 lg:!py-20">
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-tebra-orange">{ecsCaseStudiesIntro.eyebrow}</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl lg:text-4xl">
        {ecsCaseStudiesIntro.title}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-gray-600">{ecsCaseStudiesIntro.description}</p>
      <a
        href={ecsCaseStudiesIntro.ctaHref}
        class="mt-6 inline-flex min-h-[44px] items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#ff5a49]"
      >
        {ecsCaseStudiesIntro.ctaLabel}
      </a>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featuredCaseStudies.map((c) => c && <CaseStudyCard caseStudy={c} />)}
    </div>
  </PageSection>

  <!-- Pre-footer CTA band -->
  <section class="relative overflow-hidden bg-[#FAF9F6] py-14 lg:py-20">
    <div class="pointer-events-none absolute -right-16 top-0 h-40 w-40 rounded-full bg-tebra-hero-bg opacity-80" aria-hidden="true"></div>
    <div class="page-container relative text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-tebra-teal-dark sm:text-3xl">{ecsPreFooterCta.title}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-gray-600 sm:text-lg">{ecsPreFooterCta.description}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href={ecsPreFooterCta.primaryCta.href}
          class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-tebra-orange px-7 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#ff5a49]"
        >
          {ecsPreFooterCta.primaryCta.label}
        </a>
        <a
          href={ecsPreFooterCta.secondaryCta.href}
          class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-tebra-teal bg-white px-7 py-3 text-sm font-semibold text-tebra-teal transition hover:bg-tebra-hero-bg"
        >
          {ecsPreFooterCta.secondaryCta.label}
        </a>
      </div>
    </div>
  </section>

  <!-- Intake-style links -->
  <PageSection variant="default" class="!py-12 lg:!py-16">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-tebra-teal">{ecsIntakeIntro.subtitle}</p>
        <h2 class="mt-1 text-xl font-semibold text-tebra-teal-dark sm:text-2xl">{ecsIntakeIntro.title}</h2>
      </div>
      <LinkWithArrow label="View all" href="/theintake" external={false} />
    </div>
    <ul class="mt-8 divide-y divide-gray-200 border-t border-gray-200">
      {
        ecsIntakeArticles.map((a) => (
          <li>
            <a href={a.href} class="block py-4 text-base font-medium text-gray-900 transition hover:text-tebra-teal">
              {a.title}
            </a>
          </li>
        ))
      }
    </ul>
  </PageSection>

  <CTASection
    title={ecsBottomCta.title}
    description={ecsBottomCta.description}
    primaryCtaLabel={ecsBottomCta.primaryCtaLabel}
    primaryCtaHref={ecsBottomCta.primaryCtaHref}
    secondaryCtaLabel={ecsBottomCta.secondaryCtaLabel}
    secondaryCtaHref={ecsBottomCta.secondaryCtaHref}
  />
</BaseLayout>
