---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Button from "../../../components/Button/Button.astro";
import peopleHeroImage from "../../../assets/operators1.png";
import roleManagementImage from "../../../assets/patients1.png";
import taskTrackingImage from "../../../assets/session.png";
import operatorPerformanceImage from "../../../assets/operatorlog1.png";
import accountabilityImage from "../../../assets/witness104.png";

const valuePoints = [
  "Clear team ownership",
  "Faster coordination",
  "Consistent accountability",
];
---

<BaseLayout
  title="People | IVF team coordination"
  description="Assign roles, manage tasks, and track responsibilities across lab and clinical IVF workflows."
>
  <section class="relative overflow-hidden bg-tebra-hero-bg py-14 sm:py-16 lg:py-20">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <p class="eyebrow">Products • People</p>
        <h1 class="mt-3 text-4xl font-semibold leading-tight text-tebra-teal-dark sm:text-5xl">
          Coordinate your lab and clinical teams
        </h1>
        <p class="mt-5 max-w-xl text-base text-gray-600 sm:text-lg">
          Assign roles, manage tasks, and track responsibilities across your IVF workflow.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/product-tour" label="Explore People" variant="primary" size="md" />
          <Button href="/demo" label="Book a demo" variant="secondary" size="md" />
        </div>
      </div>
      <img src={peopleHeroImage.src} alt="Staff management dashboard with team performance data" class="w-full" loading="eager" />
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Role Management</h2>
        <p class="mt-4 text-base text-gray-600">
          Assign access and responsibilities based on role so each team member works with the right
          permissions and scope.
        </p>
      </div>
      <img src={roleManagementImage.src} alt="Role and team assignment interface" class="w-full" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-gray-50">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div class="md:order-2">
        <h2 class="heading-md text-tebra-teal-dark">Task Tracking</h2>
        <p class="mt-4 text-base text-gray-600">
          Keep daily workflows on schedule with clear task ownership, status updates, and progress
          visibility.
        </p>
      </div>
      <img src={taskTrackingImage.src} alt="Task tracking interface across IVF workflows" class="w-full md:order-1" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Operator Performance</h2>
        <p class="mt-4 text-base text-gray-600">
          Monitor throughput, timing, and consistency across operators to support coaching and
          operational improvements.
        </p>
      </div>
      <img src={operatorPerformanceImage.src} alt="Operator performance dashboard and metrics" class="w-full" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-gray-50">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div class="md:order-2">
        <h2 class="heading-md text-tebra-teal-dark">Accountability</h2>
        <p class="mt-4 text-base text-gray-600">
          Maintain clear audit trails for actions, decisions, and handoffs across clinical and lab
          workflows.
        </p>
      </div>
      <img src={accountabilityImage.src} alt="Accountability and audit log views for team actions" class="w-full md:order-1" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container">
      <h2 class="heading-md text-center text-tebra-teal-dark">Built for coordinated teams</h2>
      <div class="mx-auto mt-8 grid max-w-4xl gap-4 md:grid-cols-3">
        {valuePoints.map((point) => (
          <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5 text-center text-sm font-semibold text-tebra-teal-dark">
            {point}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="page-container rounded-3xl border border-gray-200 bg-gray-50 px-6 py-10 sm:px-10">
      <h2 class="text-3xl font-semibold text-tebra-teal-dark sm:text-4xl">Launch team workflows quickly</h2>
      <p class="mt-4 max-w-3xl text-base text-gray-600">
        Configure roles, assign responsibilities, and align task tracking across departments without
        changing existing processes.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <Button href="/demo" label="Book a demo" variant="primary" size="md" />
        <Button href="/product-tour" label="Take a quick product tour" variant="secondary" size="md" />
      </div>
    </div>
  </section>
</BaseLayout>
