---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Button from "../../../components/Button/Button.astro";
import opsDashboardImage from "../../../assets/people-ops-dashboard.png";
import taskBoardImage from "../../../assets/people-task-board.png";
import taskCalendarImage from "../../../assets/people-task-calendar.png";
import teamDirectoryImage from "../../../assets/people-directory.png";
import teamStructureImage from "../../../assets/people-team-structure.png";
import orgFlowImage from "../../../assets/people-org-flow.png";
import teamChatImage from "../../../assets/people-chat.png";
import expensesImage from "../../../assets/people-expenses.png";

const opsSnapshotPoints = [
  {
    title: "Task Visibility",
    description: "Track pending, in-progress, and completed tasks across departments.",
  },
  {
    title: "Priority Awareness",
    description: "Identify urgent work instantly with visual priority indicators.",
  },
  {
    title: "Performance Signals",
    description: "See completion trends and operational bottlenecks.",
  },
  {
    title: "Actionable Insights",
    description: "Move from tracking to decision-making.",
  },
];

const taskHighlights = [
  "Kanban Workflow: Drag and move tasks across Pending, In Progress, and Completed.",
  "Calendar Sync: See deadlines, audits, and procedures on one timeline.",
  "Automated Tracking: No manual follow-ups - system highlights delays instantly.",
  "Role-Based Assignment: Assign by role, department, and case.",
];

const directoryPoints = [
  "Centralized profiles with role, department, branch, and status",
  "Real-time availability to see active, assigned, or unavailable staff",
  "Search and filter to find team members instantly",
];

const communicationPoints = [
  "Direct Messages for patient-specific workflow discussions",
  "Team Channels for lab, nursing, and operations coordination",
  "Contextual communication linked to tasks, patients, and cycles",
];

const expensePoints = [
  "Expense categories for cryo storage, consumables, and equipment maintenance",
  "Approval workflows from Pending to Approved to Rejected",
  "Financial visibility into real operational spending",
];

const outcomePoints = [
  "Reduce missed tasks",
  "Improve lab coordination",
  "Increase accountability",
  "Standardize workflows",
  "Eliminate communication gaps",
];
---

<BaseLayout
  title="People | IVF team and operations management"
  description="Coordinate lab, nursing, operations, and physician workflows in one operational layer built for IVF teams."
>
  <section class="relative overflow-hidden bg-tebra-hero-bg py-14 sm:py-16 lg:py-20">
    <div class="page-container grid gap-8 md:grid-cols-2 md:items-center md:[grid-template-columns:minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-12">
      <div>
        <p class="eyebrow">Products • People</p>
        <h1 class="mt-3 text-4xl font-semibold leading-tight text-tebra-teal-dark sm:text-5xl">
          Run your IVF clinic like a coordinated team not a disconnected system.
        </h1>
        <p class="mt-5 max-w-xl text-base text-gray-600 sm:text-lg">
          Your lab, nursing, operations, and doctors do not work in silos. EmbryoOne People
          connects every role, task, and responsibility into a single operational layer.
        </p>
        <p class="mt-4 max-w-xl text-base text-gray-600 sm:text-lg">
          From embryologists to front-desk staff, assign work, track performance, and ensure
          nothing falls through the cracks.
        </p>
        <p class="mt-4 inline-flex rounded-full bg-tebra-teal-dark/5 px-4 py-2 text-sm font-semibold text-tebra-teal-dark">
          Built specifically for IVF workflows, not generic HR tools
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/product-tour" label="See Team in Action" variant="primary" size="md" />
          <Button href="/demo" label="Request Demo" variant="secondary" size="md" />
        </div>
      </div>

      <div class="relative min-h-[320px]">
        <div class="floating-card absolute left-2 top-0 w-[82%] rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-tebra-teal-dark">👩‍⚕️ Embryology Team - 8 members</p>
        </div>
        <div class="floating-card absolute right-0 top-16 w-[70%] rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-tebra-teal-dark">📋 Tasks overdue: 14</p>
        </div>
        <div class="floating-card absolute left-8 top-36 w-[75%] rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-tebra-teal-dark">🧪 Lab Operations - Active</p>
        </div>
        <div class="floating-card absolute right-4 top-56 w-[74%] rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-tebra-teal-dark">💬 6 unread team messages</p>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Everything your team is doing in one view</h2>
        <p class="mt-4 text-base text-gray-600">
          No more switching between systems to understand what is happening.
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {opsSnapshotPoints.map((item) => (
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-semibold text-tebra-teal-dark">{item.title}</h3>
              <p class="mt-1 text-sm text-gray-600">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
      <img src={opsDashboardImage.src} alt="Operations snapshot dashboard with task and workload metrics" class="w-full rounded-2xl border border-gray-200" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-gray-50">
    <div class="page-container">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">From lab prep to patient readiness every task accounted for</h2>
        <p class="mt-4 text-base text-gray-600">
          EmbryoOne turns IVF operations into structured workflows.
        </p>
        <div class="mt-6 inline-flex rounded-xl border border-gray-200 bg-white p-1 text-sm">
          <span class="rounded-lg bg-tebra-teal px-4 py-2 font-semibold text-white">Overview</span>
          <span class="px-4 py-2 text-gray-600">List</span>
          <span class="px-4 py-2 text-gray-600">Board</span>
          <span class="px-4 py-2 text-gray-600">Calendar</span>
        </div>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <img src={opsDashboardImage.src} alt="Task overview analytics with status and priority cards" class="w-full rounded-2xl border border-gray-200 bg-white" loading="lazy" />
        <img src={taskBoardImage.src} alt="Kanban board showing pending in progress and completed tasks" class="w-full rounded-2xl border border-gray-200 bg-white" loading="lazy" />
        <img src={taskCalendarImage.src} alt="Task calendar showing due dates audits and procedures" class="w-full rounded-2xl border border-gray-200 bg-white" loading="lazy" />
      </div>
      <ul class="mt-8 grid gap-3 md:grid-cols-2">
        {taskHighlights.map((item) => (
          <li class="rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm text-gray-600">
            <span class="font-semibold text-tebra-teal-dark">{item.split(":")[0]}:</span>{item.split(":")[1]}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Know your entire team instantly</h2>
        <p class="mt-4 text-base text-gray-600">
          From doctors to lab technicians, manage everyone in one structured directory.
        </p>
        <ul class="mt-6 space-y-3">
          {directoryPoints.map((point) => (
            <li class="flex items-start gap-3 text-gray-600">
              <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-sm font-semibold text-tebra-teal-dark">
          No spreadsheets. No confusion. Just a clean, searchable team structure built for clinics.
        </p>
      </div>
      <img src={teamDirectoryImage.src} alt="Team directory with roles branches departments and status" class="w-full rounded-2xl border border-gray-200" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-gray-50">
    <div class="page-container">
      <h2 class="heading-md text-tebra-teal-dark">Your clinic structured the way it actually works</h2>
      <p class="mt-4 max-w-4xl text-base text-gray-600">
        Visualize how your teams operate not just who exists. Each department has defined roles,
        assigned responsibilities, and workflow ownership. No overlap. No ambiguity.
      </p>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <img src={teamStructureImage.src} alt="Department team cards for embryology lab nursing and quality teams" class="w-full rounded-2xl border border-gray-200 bg-white" loading="lazy" />
        <img src={orgFlowImage.src} alt="Organization structure and reporting flow across branches and departments" class="w-full rounded-2xl border border-gray-200 bg-white" loading="lazy" />
      </div>
      <div class="mt-6 flex flex-wrap gap-2">
        <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-tebra-teal-dark border border-gray-200">Embryology</span>
        <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-tebra-teal-dark border border-gray-200">Lab Operations</span>
        <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-tebra-teal-dark border border-gray-200">Nursing</span>
        <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-tebra-teal-dark border border-gray-200">Andrology</span>
        <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-tebra-teal-dark border border-gray-200">QA & Compliance</span>
        <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-tebra-teal-dark border border-gray-200">Admin / Front Desk</span>
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Stop chasing people. Start collaborating.</h2>
        <p class="mt-4 text-base text-gray-600">
          Built-in communication ensures nothing is lost between departments.
        </p>
        <ul class="mt-6 space-y-3">
          {communicationPoints.map((point) => (
            <li class="flex items-start gap-3 text-gray-600">
              <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-sm font-semibold text-tebra-teal-dark">
          No WhatsApp. No fragmented conversations. Everything stays inside your clinical workflow.
        </p>
      </div>
      <img src={teamChatImage.src} alt="Built in team chat with direct messages and task linked communication" class="w-full rounded-2xl border border-gray-200" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-gray-50">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div class="md:order-2">
        <h2 class="heading-md text-tebra-teal-dark">Track costs tied to real operations</h2>
        <p class="mt-4 text-base text-gray-600">
          Your lab spends daily. Now you can track it intelligently.
        </p>
        <ul class="mt-6 space-y-3">
          {expensePoints.map((point) => (
            <li class="flex items-start gap-3 text-gray-600">
              <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-sm font-semibold text-tebra-teal-dark">
          Turn operational spending into measurable insight.
        </p>
      </div>
      <img src={expensesImage.src} alt="Expense tracking table with categories approval states and financial totals" class="w-full rounded-2xl border border-gray-200 md:order-1" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container">
      <h2 class="heading-md text-center text-tebra-teal-dark">
        This is not HR software it is IVF operations infrastructure
      </h2>
      <div class="mx-auto mt-8 grid max-w-5xl gap-4 md:grid-cols-5">
        {outcomePoints.map((point) => (
          <div class="rounded-2xl border border-gray-200 bg-gray-50 px-4 py-5 text-center text-sm font-semibold text-tebra-teal-dark">
            ✓ {point}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="page-container rounded-3xl bg-tebra-teal-dark px-6 py-10 sm:px-10">
      <h2 class="text-3xl font-semibold text-white sm:text-4xl">Bring your entire team onto one system</h2>
      <p class="mt-4 max-w-3xl text-base text-gray-100">
        From embryologists to administrators everyone works in sync.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <Button href="/demo" label="Book a Demo" variant="primary" size="md" />
        <Button href="/product-tour" label="Explore Platform" variant="secondary" size="md" />
      </div>
    </div>
  </section>

  <style>
    .floating-card {
      animation: float-card 5.4s ease-in-out infinite;
    }

    .floating-card:nth-child(2) {
      animation-delay: 0.8s;
    }
    .floating-card:nth-child(3) {
      animation-delay: 1.5s;
    }
    .floating-card:nth-child(4) {
      animation-delay: 2.2s;
    }

    @keyframes float-card {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-8px);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .floating-card {
        animation: none;
      }
    }
  </style>
</BaseLayout>
