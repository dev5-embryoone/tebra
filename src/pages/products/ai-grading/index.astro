---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Button from "../../../components/Button/Button.astro";
import aiHeroGridImage from "../../../assets/ai-grading-hero-grid.png";
import aiDashboardGridImage from "../../../assets/ai-grading-dashboard-grid.png";
import aiResultsCardImage from "../../../assets/ai-grading-results-card.png";
import aiStep2DetectImage from "../../../assets/ai-grading-step2-detect.png";
import aiStep3ResultsImage from "../../../assets/ai-grading-step3-results.png";
import aiDetailedModalImage from "../../../assets/ai-grading-detailed-modal.png";
import aiLabWorkflowImage from "../../../assets/ai-grading-lab-workflow.png";

const outputOverviewPoints = [
  "Automatic grading using Gardner system",
  "Confidence score for every prediction",
  "Visual comparison across embryos",
  "Quick filtering and search",
];

const detectionPoints = [
  "Automatic embryo detection",
  "Bounding box visualization",
  "Manual selection & correction",
  "Maintain full human control",
];

const detailedAnalysisPoints = [
  "Predicted vs actual grade comparison",
  "Confidence metrics",
  "Manual override controls",
  "Add remarks and observations",
];

const decisionSupportPoints = [
  "Consolidated embryo results",
  "Easy access to details",
  "Quick decision support",
  "Integration-ready outputs",
];

const differentiationCards = [
  {
    code: "CG",
    title: "Consistent Grading",
    description: "Reduce inter-observer variability with standardized AI analysis.",
  },
  {
    code: "SP",
    title: "Faster Workflow",
    description: "Grade embryos in seconds instead of manual evaluation.",
  },
  {
    code: "AC",
    title: "Accuracy Driven",
    description: "Up to 83% accuracy aligned with Gardner grading standards.",
  },
  {
    code: "HC",
    title: "Human Control",
    description: "Always keep embryologists in the decision loop.",
  },
];

const integrationPoints = [
  "Direct input from Embryo Capture",
  "Sync with patient records",
  "Store results in lab system",
  "Connect with cryo & workflow modules",
];

const workflowSteps = [
  {
    number: "1",
    label: "Upload & Classify",
    title: "Upload embryo image",
    description: "Capture from camera or upload from your lab imaging system to start grading.",
  },
  {
    number: "2",
    label: "Detect & Select",
    title: "Validate detected embryos",
    description: "AI identifies embryos and lets embryologists confirm, refine, or discard selections.",
  },
  {
    number: "3",
    label: "Results",
    title: "Review and finalize grades",
    description: "Compare predictions, confidence, and clinical input before finalizing outcomes.",
  },
];

const aiGradingFaqs = [
  {
    question: "Can embryologists override AI grading results?",
    answer:
      "Yes. AI Grading supports full human control, including manual adjustments, validation, and final sign-off by the embryologist.",
  },
  {
    question: "How are confidence scores used in review?",
    answer:
      "Each prediction includes confidence context so teams can prioritize review, compare outputs, and document decisions with better transparency.",
  },
  {
    question: "Does AI Grading fit existing IVF workflows?",
    answer:
      "EmbryoOne AI Grading is designed to integrate with image capture, clinical records, and downstream lab workflows without disrupting existing processes.",
  },
  {
    question: "Are grading decisions traceable for audit and quality review?",
    answer:
      "Yes. Predictions, manual edits, and remarks are captured in the review flow to support traceability, quality checks, and team consistency.",
  },
];
---

<BaseLayout
  title="AI Grading | AI-powered embryo assessment"
  description="EmbryoOne AI Grading delivers fast, consistent embryo assessments using Gardner standards with explainable confidence and human validation."
>
  <section class="relative overflow-hidden bg-tebra-hero-bg py-14 sm:py-16 lg:py-20">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center md:[grid-template-columns:minmax(0,0.72fr)_minmax(0,1.28fr)] lg:gap-10">
      <div>
        <p class="eyebrow">Products • AI Grading</p>
        <h1 class="mt-3 text-4xl font-semibold leading-tight text-tebra-teal-dark sm:text-5xl">
          Grade embryos with AI-powered precision
        </h1>
        <p class="mt-5 max-w-xl text-base text-gray-600 sm:text-lg">
          EmbryoOne AI Grading analyzes embryo images using Gardner grading standards delivering
          fast, consistent, and objective results with up to 83% accuracy. Reduce variability,
          speed up workflows, and support better clinical decisions.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/product-tour" label="Start grading" variant="primary" size="md" />
          <Button href="/demo" label="View demo" variant="secondary" size="md" />
        </div>
      </div>
      <img src={aiHeroGridImage.src} alt="Embryo grading grid with predicted grades and confidence levels" class="w-full rounded-2xl border border-gray-200" loading="eager" />
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">See every embryo, graded instantly</h2>
        <p class="mt-4 text-base text-gray-600">
          View all embryos in a structured grid with predicted grades, confidence levels, and
          timestamps. Quickly identify high-quality embryos and prioritize decision-making.
        </p>
        <ul class="mt-6 space-y-3">
          {outputOverviewPoints.map((point) => (
            <li class="flex items-start gap-3 text-gray-600">
              <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </div>
      <img src={aiResultsCardImage.src} alt="Single embryo grading result card with grade and confidence" class="w-full rounded-2xl border border-gray-200" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-gray-50">
    <div class="page-container grid gap-8 md:grid-cols-2 md:items-center md:[grid-template-columns:minmax(0,0.95fr)_minmax(0,1.05fr)] lg:gap-12">
      <div>
        <h2 class="text-4xl font-semibold leading-tight text-tebra-teal-dark sm:text-5xl">
          AI grading in 3 simple steps
        </h2>
        <p class="mt-5 max-w-xl text-base text-gray-600 sm:text-lg">
          EmbryoOne is designed to fit directly into embryologist workflows. From upload to final
          validation, your team gets rapid AI support without disrupting clinical control.
        </p>
        <div class="mt-8">
          <Button href="/product-tour" label="Get started with AI Grading" variant="primary" size="md" />
        </div>
      </div>

      <div class="rounded-3xl border border-[#E7DEF7] bg-[#F8F5FF] p-6 sm:p-8">
        <div class="space-y-6">
          {workflowSteps.map((step, index) => (
            <div class="ai-stepper-item relative pl-12">
              {index < workflowSteps.length - 1 && (
                <span class="absolute left-4 top-10 h-[calc(100%-8px)] w-px -translate-x-1/2 bg-[#DCCEF8]"></span>
              )}
              <span class="absolute left-0 top-0 inline-flex h-10 w-8 items-start justify-center text-4xl font-semibold leading-none text-[#4A2A73]">
                {step.number}
              </span>
              <p class="text-xs font-semibold uppercase tracking-wide text-[#7A649C]">{step.label}</p>
              <h3 class="mt-1 text-xl font-semibold text-[#2E1A47]">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[#5C4E73]">{step.description}</p>
            </div>
          ))}
        </div>
        <div class="mt-7 flex flex-wrap gap-2">
          <span class="rounded-full bg-[#E9DDFF] px-3 py-1 text-xs font-semibold text-[#4A2A73]">real-time</span>
          <span class="rounded-full bg-[#E9DDFF] px-3 py-1 text-xs font-semibold text-[#4A2A73]">validation</span>
          <span class="rounded-full bg-[#E9DDFF] px-3 py-1 text-xs font-semibold text-[#4A2A73]">confidence</span>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div class="md:order-2">
        <h2 class="heading-md text-tebra-teal-dark">AI detects embryos your team stays in control</h2>
        <p class="mt-4 text-base text-gray-600">
          EmbryoOne automatically detects embryos within the image and highlights them with
          bounding boxes. Embryologists can validate, refine, or discard selections before
          grading.
        </p>
        <ul class="mt-6 space-y-3">
          {detectionPoints.map((point) => (
            <li class="flex items-start gap-3 text-gray-600">
              <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </div>
      <img src={aiStep2DetectImage.src} alt="Detection and selection screen with embryo bounding box and detected embryo list" class="w-full rounded-2xl border border-gray-200 md:order-1" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-gray-50">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Understand every grade with explainable insights</h2>
        <p class="mt-4 text-base text-gray-600">
          Each embryo includes predicted grade, quality assessment, and confidence scores. Your
          team can override, adjust, and annotate results ensuring clinical trust.
        </p>
        <p class="mt-4 text-base text-gray-600">
          The detailed review panel is built for clinical transparency. Every field is visible in
          one place so embryologists can quickly compare model output with expert judgment, document
          rationale, and finalize grading with confidence.
        </p>
        <ul class="mt-6 space-y-3">
          {detailedAnalysisPoints.map((point) => (
            <li class="flex items-start gap-3 text-gray-600">
              <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </div>
      <img src={aiDetailedModalImage.src} alt="Detailed results modal with predicted and actual grades, confidence, and remarks fields" class="w-full rounded-2xl border border-gray-200" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div class="md:order-2">
        <h2 class="heading-md text-tebra-teal-dark">Turn AI outputs into clinical decisions</h2>
        <p class="mt-4 text-base text-gray-600">
          View final graded embryos in a clean, structured format ready for reporting, selection,
          or integration into IVF workflows.
        </p>
        <ul class="mt-6 space-y-3">
          {decisionSupportPoints.map((point) => (
            <li class="flex items-start gap-3 text-gray-600">
              <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </div>
      <img src={aiStep3ResultsImage.src} alt="Final results card in step 3 with embryo grade and view details action" class="w-full rounded-2xl border border-gray-200 md:order-1" loading="lazy" />
    </div>
  </section>

  <section class="page-section bg-gray-50">
    <div class="page-container">
      <h2 class="heading-md text-center text-tebra-teal-dark">Built for consistency, speed, and clinical trust</h2>
      <div class="mx-auto mt-8 grid max-w-5xl gap-4 md:grid-cols-2">
        {differentiationCards.map((card) => (
          <div class="rounded-2xl border border-gray-200 bg-white p-5">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-tebra-teal/10 text-sm font-semibold text-tebra-teal-dark">
                {card.code}
              </span>
              <h3 class="text-lg font-semibold text-tebra-teal-dark">{card.title}</h3>
            </div>
            <p class="mt-3 text-sm text-gray-600">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container grid gap-6 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Works seamlessly with your lab workflow</h2>
        <p class="mt-4 text-base text-gray-600">
          AI Grading integrates directly with Embryo Capture, Cryo Tracker, and EHR systems
          creating a unified embryo data ecosystem.
        </p>
        <ul class="mt-6 space-y-3">
          {integrationPoints.map((point) => (
            <li class="flex items-start gap-3 text-gray-600">
              <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </div>
      <img src={aiLabWorkflowImage.src} alt="Patient embryo workflow view integrated with grading and lab modules" class="w-full rounded-2xl border border-gray-200" loading="lazy" />
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-tebra-teal-dark">
    <div class="page-container">
      <div class="mx-auto max-w-4xl">
        <p class="eyebrow !text-gray-200">AI Grading FAQ</p>
        <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">Frequently Asked Questions</h2>
        <p class="mt-4 text-base text-gray-200">
          Common questions about AI-assisted embryo grading, review control, and clinical workflow
          integration.
        </p>
        <div class="mt-8 space-y-3">
          {aiGradingFaqs.map((item, index) => (
            <details
              class="rounded-2xl border border-white/20 bg-white/5 px-5 py-4 text-white"
              open={index === 0}
            >
              <summary class="cursor-pointer list-none pr-7 text-base font-semibold marker:content-none">
                {item.question}
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-gray-200">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="page-container rounded-3xl bg-tebra-teal-dark px-6 py-10 sm:px-10">
      <h2 class="text-3xl font-semibold text-white sm:text-4xl">Bring consistency and intelligence to embryo grading</h2>
      <p class="mt-4 max-w-3xl text-base text-gray-100">
        Empower your embryologists with AI-assisted grading without compromising clinical control.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <Button href="/demo" label="Book a demo" variant="primary" size="md" />
        <Button href="/product-tour" label="Explore platform" variant="secondary" size="md" />
      </div>
    </div>
  </section>

  <style>
    .ai-stepper-item {
      opacity: 0;
      transform: translateY(16px);
      transition:
        opacity 900ms ease,
        transform 900ms ease;
    }

    .ai-stepper-item.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      .ai-stepper-item {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>

  <script>
    const stepperItems = Array.from(document.querySelectorAll(".ai-stepper-item"));
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduceMotion) {
      stepperItems.forEach((item) => item.classList.add("is-visible"));
    } else if (stepperItems.length) {
      let animationFrame = null;

      const playStepperAnimation = () => {
        stepperItems.forEach((item) => item.classList.remove("is-visible"));
        animationFrame = window.requestAnimationFrame(() => {
          stepperItems.forEach((item, index) => {
            window.setTimeout(() => {
              item.classList.add("is-visible");
            }, index * 520);
          });
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              playStepperAnimation();
            } else {
              stepperItems.forEach((item) => item.classList.remove("is-visible"));
              if (animationFrame) {
                window.cancelAnimationFrame(animationFrame);
                animationFrame = null;
              }
            }
          });
        },
        { threshold: 0.35 }
      );

      observer.observe(stepperItems[0]);
    }
  </script>
</BaseLayout>
