    opacity: 0;
    transform: translateY(10px);
    animation: heroCardFade 500ms ease forwards;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .hero-card:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 20px 30px -20px rgba(15, 23, 42, 0.45);
  }

  .hero-card-offset {
    margin-left: 0;
  }

  .hero-card-tag {
    display: inline-flex;
    border-radius: 9999px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .hero-card-teal .hero-card-tag {
    background: #e7f3f3;
    color: #0f4f4f;
  }

  .hero-card-green .hero-card-tag {
    background: #e6f6ef;
    color: #0f6b47;
  }

  .hero-card-orange .hero-card-tag {
    background: #fff1e7;
    color: #9a4b14;
  }

  .hero-card-blue .hero-card-tag {
    background: #e9f1ff;
    color: #1d4ea5;
  }

  @keyframes heroCardsScroll {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }

  @keyframes heroCardFade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
