</style>

<script>
  (() => {
    const root = document.querySelector("#consumption-procurement-tabs");
    if (!root) return;

    const tabs = Array.from(root.querySelectorAll(".proc-tab"));
    const panels = Array.from(root.querySelectorAll(".proc-panel"));

    const activate = (tabId) => {
      tabs.forEach((tab) => {
        const isActive = tab.getAttribute("data-proc-tab") === tabId;
        tab.classList.toggle("bg-[#EAF2F2]", isActive);
        tab.classList.toggle("border-[#D7E4E4]", isActive);
        tab.classList.toggle("text-tebra-teal-dark", isActive);
        tab.classList.toggle("bg-white", !isActive);
        tab.classList.toggle("border-gray-200", !isActive);
        tab.classList.toggle("text-gray-600", !isActive);
      });

      panels.forEach((panel) => {
        const isActive = panel.getAttribute("data-proc-panel") === tabId;
        panel.classList.toggle("hidden", !isActive);
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const tabId = tab.getAttribute("data-proc-tab");
        if (tabId) activate(tabId);
      });
    });

    activate("pr");
  })();
</script>
