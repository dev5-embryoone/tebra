<BaseLayout
  title={`${solution.title} Solutions | EmbryoOne`}
  description={`${solution.subtitle}. ${solution.heroBody}`}
>
  <section class={`${isShowcasePage ? "embryo-surface embryo-surface--white" : "bg-tebra-hero-bg"} py-14 sm:py-16 lg:py-20`}>
