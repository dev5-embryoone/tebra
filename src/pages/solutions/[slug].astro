      </div>
    </section>
  ) : null}

  <section class={`page-section ${isShowcasePage ? "embryo-surface embryo-surface--lavender" : "bg-[#F7FAFA]"}`}>
    <div class="page-container max-w-5xl">
      <h2 class="heading-md text-tebra-teal-dark">{pageExpansion.workflowTitle}</h2>
      <div class="workflow-steps mt-6 grid gap-4 md:grid-cols-3">
        {pageExpansion.workflowSteps.map((step, index) => (
          <article class="workflow-step-card group relative overflow-hidden rounded-2xl border border-[#D8E7E7] bg-white p-5">
            <span class="workflow-step-glow" aria-hidden="true"></span>
            <div class="flex items-center gap-2">
              <span class="workflow-step-badge">Step {index + 1}</span>
              {index < pageExpansion.workflowSteps.length - 1 ? (
                <span class="workflow-step-link hidden h-px flex-1 bg-[#CFE0E0] md:block"></span>
              ) : null}
            </div>
            <h3 class="mt-3 text-lg font-semibold text-tebra-teal-dark">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-700">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class={`page-section ${isShowcasePage ? "embryo-surface embryo-surface--gray" : "bg-[#F6FAFA]"}`}>
    <div class="page-container max-w-5xl">
      {isShowcasePage ? (
        <div class="outcomes-showcase">
          <p class="outcomes-showcase-kicker">{outcomesShowcaseContent[solution.slug]?.kicker}</p>
          <h2 class="mt-2 text-4xl font-semibold leading-tight text-[#42245E] sm:text-5xl">
            {outcomesShowcaseContent[solution.slug]?.title}
          </h2>
          <div class="mt-6 space-y-4 text-base leading-relaxed text-[#4F4760]">
            <p>{outcomesShowcaseContent[solution.slug]?.bodyOne}</p>
            <p>{outcomesShowcaseContent[solution.slug]?.bodyTwo}</p>
            <p>{outcomesShowcaseContent[solution.slug]?.bodyThree}</p>
          </div>
          <div class="mt-7 grid gap-3 md:grid-cols-3">
            {solution.outcomes.map((item) => (
              <article class="outcomes-showcase-card">
                <p class="text-lg font-semibold leading-snug text-[#3D245B]">{item}</p>
              </article>
            ))}
          </div>
        </div>
      ) : (
        <h2 class={`heading-md text-tebra-teal-dark ${solution.slug === "embryologists" ? "text-center" : ""}`}>
          {solution.outcomesHeading ?? "Outcomes"}
        </h2>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {solution.outcomes.map((item) => (
            <article class="rounded-2xl border border-[#D6E6E6] bg-white p-5">
              <p class={`text-base font-semibold text-tebra-teal-dark ${solution.slug === "embryologists" ? "text-center" : ""}`}>
                {item}
              </p>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class={`page-section ${isShowcasePage ? "embryo-surface embryo-surface--white" : "bg-white"}`}>
    <div class="page-container max-w-5xl">
      <div class="grid gap-8 md:grid-cols-2 md:items-center">
        <div>
          <h2 class="heading-md text-tebra-teal-dark">{relevantSectionContent[solution.slug]?.heading}</h2>
          <p class="mt-4 text-base leading-relaxed text-gray-700">
            {relevantSectionContent[solution.slug]?.body}
          </p>
          <ul class="mt-5 space-y-3">
            {(relevantSectionContent[solution.slug]?.points ?? []).map((item) => (
              <li class="flex items-start gap-3 text-gray-700">
                <span class="mt-2 h-2 w-2 rounded-full bg-tebra-teal"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <img
            src={relevantSectionContent[solution.slug]?.image.src}
            alt={relevantSectionContent[solution.slug]?.imageAlt}
