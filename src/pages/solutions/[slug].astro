  <style>
    .embryo-surface {
      position: relative;
      overflow: hidden;
    }

    .embryo-surface::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(130deg, rgba(126, 87, 160, 0.09), rgba(126, 87, 160, 0));
    }

    .embryo-surface > .page-container {
      position: relative;
      z-index: 1;
    }

    .embryo-surface--white {
      background: #ffffff;
    }

    .embryo-surface--lavender {
      background: #f6f2ff;
    }

    .embryo-surface--gray {
      background: #fbf9ff;
    }

    details[open] .faq-icon-plus {
      display: none;
    }

    details[open] .faq-icon-minus {
      display: inline;
    }

    .workflow-step-card {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 520ms ease,
        transform 520ms ease,
        box-shadow 260ms ease,
        border-color 260ms ease;
      box-shadow: 0 14px 30px -24px rgba(15, 23, 42, 0.38);
    }

    .workflow-step-card.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .workflow-step-card:hover {
      border-color: #b8d3d3;
      box-shadow: 0 24px 42px -28px rgba(15, 23, 42, 0.45);
    }

    .workflow-step-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 9999px;
      background: #e8f4f4;
      color: #1f5b75;
      padding: 0.25rem 0.75rem;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .workflow-step-glow {
      pointer-events: none;
      position: absolute;
      top: -3.5rem;
      right: -3rem;
      width: 8rem;
      height: 8rem;
      border-radius: 9999px;
      background: radial-gradient(circle, rgba(48, 119, 149, 0.17), rgba(48, 119, 149, 0));
      transform: scale(0.85);
      transition: transform 280ms ease;
    }

    .workflow-step-card:hover .workflow-step-glow {
      transform: scale(1);
    }

    @media (prefers-reduced-motion: reduce) {
      .workflow-step-card {
        opacity: 1;
        transform: none;
        transition: box-shadow 260ms ease, border-color 260ms ease;
      }
    }

    .feature-deep-dive-track {
      display: flex;
      gap: 0.9rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 0.25rem;
    }

    .feature-deep-dive-track::-webkit-scrollbar {
      display: none;
    }

    .feature-deep-dive-card {
      flex: 0 0 88%;
      border-radius: 1.2rem;
      padding: 1.3rem 1.15rem;
      min-height: 168px;
      border: 1px solid transparent;
      box-shadow: 0 14px 32px -26px rgba(43, 22, 61, 0.5);
      transition: transform 240ms ease, box-shadow 240ms ease;
      scroll-snap-align: start;
    }

    .feature-deep-dive-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 20px 34px -24px rgba(43, 22, 61, 0.55);
    }

    .feature-deep-dive-label {
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      opacity: 0.9;
    }

    .feature-deep-dive-copy {
      margin-top: 0.7rem;
      font-size: 1.02rem;
      line-height: 1.55;
      font-weight: 500;
    }

    .feature-tone-0 {
      background: linear-gradient(145deg, #4a2a73, #2f1a4a);
      border-color: #6d49a0;
      color: #f4ecff;
    }

    .feature-tone-1 {
      background: linear-gradient(145deg, #f2e9ff, #e9d9ff);
      border-color: #ddc7ff;
      color: #3b2459;
    }

    .feature-tone-2 {
      background: linear-gradient(145deg, #ede4ff, #dac3ff);
      border-color: #cfb0ff;
      color: #35204f;
    }

    .feature-tone-3 {
      background: linear-gradient(145deg, #efe6ff, #f6f1ff);
      border-color: #ddc9ff;
      color: #3a2457;
    }

    .feature-slider-btn {
      display: inline-flex;
      height: 2rem;
      width: 2rem;
      align-items: center;
      justify-content: center;
      border-radius: 9999px;
      border: 1px solid #d7c2f7;
      background: #f5ecff;
      color: #4a2a73;
      font-weight: 700;
      transition: all 180ms ease;
    }

    .feature-slider-btn:hover {
      background: #eadbff;
      border-color: #caa7f7;
    }

    .outcomes-showcase {
      border-radius: 1.4rem;
      border: 1px solid #e0d0f5;
      background: linear-gradient(145deg, #ece2fb, #e5d7f7);
      padding: 1.3rem 1.15rem;
    }

    .outcomes-showcase-kicker {
      display: inline-flex;
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #7f669d;
      font-weight: 700;
    }

    .outcomes-showcase-card {
      border-radius: 0.95rem;
      border: 1px solid #dfd5ee;
      background: #f8f4fc;
      padding: 1rem 0.95rem;
      box-shadow: 0 12px 24px -24px rgba(59, 36, 88, 0.45);
    }

    @media (min-width: 768px) {
      .feature-deep-dive-card {
        flex-basis: calc((100% - 1.8rem) / 3);
      }

      .outcomes-showcase {
        padding: 1.9rem 2rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .outcomes-showcase-card {
        transition: none;
      }
    }
  </style>

  <script>
    (() => {
      const cards = Array.from(document.querySelectorAll(".workflow-step-card"));
      if (!cards.length) return;

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduceMotion) {
        cards.forEach((card) => card.classList.add("is-visible"));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const card = entry.target;
            const index = cards.indexOf(card);
            window.setTimeout(() => {
              card.classList.add("is-visible");
            }, index * 140);
            observer.unobserve(card);
          });
        },
        { threshold: 0.24 }
      );

      cards.forEach((card) => observer.observe(card));
    })();

    (() => {
      const track = document.querySelector("#feature-deep-dive-track");
      const prevBtn = document.querySelector("#feature-prev-btn");
      const nextBtn = document.querySelector("#feature-next-btn");
      if (!(track instanceof HTMLElement) || !(prevBtn instanceof HTMLButtonElement) || !(nextBtn instanceof HTMLButtonElement)) return;

      const card = track.querySelector(".feature-deep-dive-card");
      if (!(card instanceof HTMLElement)) return;
      const step = () => card.getBoundingClientRect().width + 14;

      prevBtn.addEventListener("click", () => {
        track.scrollBy({ left: -step(), behavior: "smooth" });
      });

      nextBtn.addEventListener("click", () => {
        track.scrollBy({ left: step(), behavior: "smooth" });
      });
    })();

  </script>

  <section class="py-16 sm:py-20">
    <div class="page-container rounded-3xl bg-tebra-teal-dark px-6 py-10 sm:px-10">
      <h2 class="text-3xl font-semibold text-white sm:text-4xl">
        Ready to operationalize this workflow in your clinic?
      </h2>
      <p class="mt-4 max-w-3xl text-base text-gray-100">
        See how EmbryoOne can be configured for your team, SOPs, and reporting requirements.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <Button href="/demo" label="Book a demo" variant="primary" size="md" />
        <Button href="/product-tour" label="View product tour" variant="secondary" size="md" />
      </div>
    </div>
  </section>
</BaseLayout>
