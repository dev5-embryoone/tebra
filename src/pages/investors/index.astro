---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageSection from "../../components/Layout/PageSection.astro";
import CTASection from "../../components/Sections/CTASection.astro";

import commonfundRaw from "../../assets/testimonial_logo_commonfund.svg";
import golubRaw from "../../assets/testimonial_logo_golubcapital.svg";
import hlmRaw from "../../assets/testimonial_logo_hlm.svg";
import openviewRaw from "../../assets/testimonial_logo_openview.svg";
import transformationRaw from "../../assets/testimonial_logo_transformation.svg";
import tobaRaw from "../../assets/testimonial_logo_tobacapital.svg";
import stepstoneRaw from "../../assets/testimonial_logo_stepstone.svg";

import illoLeftRaw from "../../assets/investors_ilustration-01.svg";
import illoRightRaw from "../../assets/investors_ilustration-02.svg";
import bannerIlloRaw from "../../assets/Banner_Illo.svg";

type Img = { src: string } | string;
const src = (img: Img) => (typeof img === "string" ? img : img.src);

const investors = [
  {
    key: "commonfund",
    name: "Commonfund",
    logoSrc: src(commonfundRaw),
    description:
      "Commonfund is an asset management firm founded in 1971. As one of the pioneers of investing long-term portfolios for nonprofits and other institutions, we’ve been helping investors achieve their goals for five decades.",
    href: "https://www.commonfund.org/",
  },
  {
    key: "golub",
    name: "Golub Capital",
    logoSrc: src(golubRaw),
    description:
      "Golub Capital is a nationally recognized credit asset manager with over $20 billion of capital under management. For over 20 years, Golub Capital has provided credit to help medium-sized U.S. businesses grow.",
    href: "https://www.golubcapital.com/",
  },
  {
    key: "hlm",
    name: "HLM Venture Partners",
    logoSrc: src(hlmRaw),
    description:
      "HLM provides venture capital to early- to mid-stage healthcare information technology, healthcare services, and medical device companies. HLM has helped over 75 privately-held healthcare companies turn innovative ideas into market-leading businesses.",
    href: "https://www.hlmvp.com/",
  },
  {
    key: "openview",
    name: "OpenView Venture Partners",
    logoSrc: src(openviewRaw),
    description:
      "OpenView is a venture capital firm focused on helping technology companies turn their visions into reality. Everything we do is focused on finding, capitalizing, and assisting expansion stage technology companies.",
    href: "https://openviewpartners.com/",
  },
  {
    key: "stepstone",
    name: "StepStone Group",
    logoSrc: src(stepstoneRaw),
    description:
      "StepStone Group is a global private markets investment firm focused on providing customized investment solutions and advisory and data services to our clients across private equity, infrastructure, private debt, and real estate.",
    href: "https://www.stepstonegroup.com/",
  },
  {
    key: "toba",
    name: "Toba Capital",
    logoSrc: src(tobaRaw),
    description:
      "Toba Capital is an early-stage investment firm committed to helping create incredible technology companies. We look for long-term growth businesses and teams with the potential to fundamentally shift markets for the common good.",
    href: "https://tobacapital.com/",
  },
  {
    key: "transformation",
    name: "Transformation Capital",
    logoSrc: src(transformationRaw),
    description:
      "Transformation Capital invests in digital health companies across the ecosystem. The firm was founded on the premise that investing in healthcare requires sophisticated understanding of the healthcare system and deep connections with decision-makers.",
    href: "https://transformationcapital.com/",
  },
];

const illoLeft = src(illoLeftRaw);
const illoRight = src(illoRightRaw);
const bannerIllo = src(bannerIlloRaw);
---

<BaseLayout
  title="Investors | Tebra"
  description="The Tebra investment partners fuel our commitment to unlocking better healthcare."
>
  <PageSection variant="default" class="relative overflow-hidden">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="font-display text-4xl font-semibold tracking-tight text-tebra-teal-dark sm:text-5xl">
        Tebra investors
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg">
        The Tebra investment partners fuel our commitment to unlocking better healthcare by helping
        independent practices bring modernized care to patients everywhere.
      </p>
    </div>
  </PageSection>

  <PageSection variant="default" class="pt-0">
    <div class="relative">
      <!-- Side illustrations (desktop), aligned with the grid like the reference -->
      <img
        src={illoLeft}
        alt=""
        class="pointer-events-none absolute left-0 top-1/2 hidden w-[190px] -translate-x-[110%] -translate-y-1/2 select-none lg:block"
        loading="lazy"
      />
      <img
        src={illoRight}
        alt=""
        class="pointer-events-none absolute right-0 top-1/2 hidden w-[190px] translate-x-[110%] -translate-y-1/2 select-none lg:block"
        loading="lazy"
      />

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-2">
      {investors.map((inv) => (
        <article class="group rounded-2xl border border-gray-100 bg-[#FBF9F4] p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <img
                src={inv.logoSrc}
                alt={`${inv.name} logo`}
                class="h-12 w-auto max-w-[280px] object-contain sm:h-14 sm:max-w-[320px]"
                loading="lazy"
              />
            </div>
          </div>

          <p class="mt-4 text-sm leading-relaxed text-gray-600">{inv.description}</p>

          <div class="mt-5">
            <a
              href={inv.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-semibold text-tebra-teal hover:text-tebra-teal-dark transition-colors"
              aria-label={`Read more about ${inv.name} (opens in a new tab)`}
            >
              Read more
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M14 3h7v7"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <path
                  d="M10 14L21 3"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <path
                  d="M21 14v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h6"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </div>
        </article>
      ))}
      </div>
    </div>
  </PageSection>

  <PageSection variant="default" class="bg-[#c5d5d6] py-14 lg:py-20">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div class="max-w-xl">
        <h2 class="font-display text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl lg:text-5xl">
          Join the 20,000 independent practices who already trust Tebra
        </h2>
        <div class="mt-7">
          <a
            href="/demo"
            class="inline-flex items-center justify-center rounded-full bg-tebra-orange px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[#ff5a49]"
          >
            Get demo
          </a>
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <img src={bannerIllo} alt="" class="w-full max-w-xl" loading="lazy" />
      </div>
    </div>
  </PageSection>

  <CTASection
    title="Automate, optimize, and thrive with Tebra"
    description="The leading practice automation solution for independent practices."
    primaryCtaLabel="Get a demo"
    primaryCtaHref="/demo"
    secondaryCtaLabel="Explore for Free"
    secondaryCtaHref="/sign-up"
  />
</BaseLayout>

