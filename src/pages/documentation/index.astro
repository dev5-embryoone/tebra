---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button/Button.astro";
import visualImage from "../../assets/ehr-hero-connected-system.png";

const quickLinks = [
  "Getting started",
  "AI grading",
  "IVF cycle workflows",
  "Lab tracking",
  "Troubleshooting",
];

const gettingStartedCards = [
  {
    icon: "🧬",
    title: "Account & Clinic Setup",
    points: ["Create organization", "Add clinic locations", "Configure lab settings"],
  },
  {
    icon: "👥",
    title: "User Roles & Permissions",
    points: [
      "Add users (embryologists, doctors, admins)",
      "Assign roles and access levels",
      "Manage permissions",
    ],
  },
  {
    icon: "🏥",
    title: "First IVF Cycle Setup",
    points: ["Create patient profile", "Start new cycle", "Assign provider and lab"],
  },
];

const coreWorkflowModules = [
  {
    icon: "🧬",
    title: "Patient & Cycle Management",
    points: [
      "Patient intake & records",
      "Cycle tracking (baseline -> stimulation -> trigger -> transfer)",
      "Appointment scheduling",
    ],
  },
  {
    icon: "🔬",
    title: "AI Embryo Grading",
    points: [
      "Upload embryo images",
      "Automatic detection & classification",
      "Understanding confidence scores",
      "Manual override & validation",
    ],
  },
  {
    icon: "🧪",
    title: "Lab Traceability",
    points: [
      "Track embryo lifecycle",
      "Record fertilization, development, and transfer",
      "Audit trail for all actions",
    ],
  },
  {
    icon: "❄️",
    title: "Cryo Management",
    points: ["Storage tracking", "Sample movement logs", "Status monitoring"],
  },
  {
    icon: "📦",
    title: "Inventory & Lab Operations",
    points: ["Consumables tracking", "Equipment logs", "Lab maintenance workflows"],
  },
];

const featureDeepDives = [
  {
    icon: "🧠",
    title: "AI Grading System",
    copy: "Learn how AI analyzes embryo morphology and generates classifications.",
    topics: ["Grading logic", "Model accuracy & limitations", "Best practices for image capture"],
  },
  {
    icon: "📊",
    title: "Reporting & Insights",
    copy: "",
    topics: ["Cycle performance reports", "Lab activity dashboards", "Outcome tracking"],
  },
  {
    icon: "📅",
    title: "Scheduling & Coordination",
    copy: "",
    topics: ["Provider calendar", "Cycle board", "Task management"],
  },
  {
    icon: "📄",
    title: "Documentation & Encounters",
    copy: "",
    topics: ["Patient notes", "Orders & results", "Clinical documentation"],
  },
];

const quickTaskGuides = [
  "Start a new IVF cycle",
  "Grade an embryo using AI",
  "Track embryo transfer",
  "Update patient records",
  "Review lab results",
];

const faqs = [
  {
    question: "Why is my embryo not detected?",
    answer: "Ensure image clarity, proper framing, and lighting conditions.",
  },
  {
    question: "Can I edit AI grading results?",
    answer: "Yes, all results can be manually reviewed and overridden.",
  },
  {
    question: "How do I track embryo history?",
    answer: "Use the lab traceability module to view full lifecycle logs.",
  },
];

const roleGuides = [
  {
    role: "Embryologists",
    points: ["AI grading workflows", "Lab traceability", "Cryo tracking"],
  },
  {
    role: "Doctors",
    points: ["Patient cycles", "Decision insights", "Reporting"],
  },
  {
    role: "Lab Directors",
    points: ["Monitoring performance", "Standardizing workflows", "Compliance tracking"],
  },
  {
    role: "Admin Staff",
    points: ["Scheduling", "Intake", "Billing & operations"],
  },
];
---
<BaseLayout
  title="Documentation | EmbryoOne"
  description="Documentation built for IVF workflows across clinic, lab, and AI operations."
>
  <section class="page-section bg-tebra-hero-bg">
    <div class="page-container max-w-6xl">
      <h1 class="text-4xl font-semibold tracking-tight text-tebra-teal-dark sm:text-5xl">
        Documentation built for IVF workflows
      </h1>
      <p class="mt-4 max-w-4xl text-base leading-relaxed text-gray-700 sm:text-lg">
        Everything your team needs to get started, operate efficiently, and scale with EmbryoOne-from patient management to AI grading and lab traceability.
      </p>

      <div class="mt-6">
        <input
          type="text"
          placeholder='Search documentation (e.g., "AI grading", "cycle setup", "lab traceability")'
          class="w-full rounded-xl border border-[#D6E6E6] bg-white px-4 py-3 text-sm text-gray-800 shadow-sm outline-none focus:border-tebra-teal focus:ring-2 focus:ring-tebra-teal/20 sm:text-base"
        />
      </div>

      <div class="mt-5 flex flex-wrap gap-2.5">
        {quickLinks.map((link) => (
          <span class="inline-flex rounded-full border border-[#D7E6E6] bg-white px-4 py-2 text-xs font-semibold text-tebra-teal-dark sm:text-sm">
            {link}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Start using EmbryoOne in minutes</h2>
      <p class="mt-3 max-w-4xl text-gray-700">
        Follow step-by-step guides to set up your clinic, onboard your team, and begin managing IVF workflows.
      </p>
      <div class="mt-7 grid gap-4 md:grid-cols-3">
        {gettingStartedCards.map((card) => (
          <article class="rounded-2xl border border-[#D8E7E7] bg-[#FCFEFE] p-5">
            <p class="text-2xl">{card.icon}</p>
            <h3 class="mt-3 text-lg font-semibold text-tebra-teal-dark">{card.title}</h3>
            <ul class="mt-3 space-y-2 text-sm text-gray-700">
              {card.points.map((point) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-tebra-teal"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section bg-[#F7FAFA]">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">End-to-end IVF workflows</h2>
      <p class="mt-3 max-w-4xl text-gray-700">
        EmbryoOne connects clinical, lab, and AI workflows in one system. Learn how each step works together.
      </p>
      <div class="mt-7 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {coreWorkflowModules.map((module) => (
          <article class="rounded-2xl border border-[#D8E7E7] bg-white p-5">
            <p class="text-2xl">{module.icon}</p>
            <h3 class="mt-3 text-lg font-semibold text-tebra-teal-dark">{module.title}</h3>
            <ul class="mt-3 space-y-2 text-sm text-gray-700">
              {module.points.map((point) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-tebra-teal"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Understand each feature in detail</h2>
      <div class="mt-7 grid gap-4 md:grid-cols-2">
        {featureDeepDives.map((feature) => (
          <article class="rounded-2xl border border-[#D8E7E7] bg-white p-5">
            <p class="text-2xl">{feature.icon}</p>
            <h3 class="mt-3 text-lg font-semibold text-tebra-teal-dark">{feature.title}</h3>
            {feature.copy ? <p class="mt-2 text-sm leading-relaxed text-gray-700">{feature.copy}</p> : null}
            <ul class="mt-3 space-y-2 text-sm text-gray-700">
              {feature.topics.map((topic) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-tebra-teal"></span>
                  <span>{topic}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section bg-[#F6FAFA]">
    <div class="page-container max-w-6xl grid gap-8 md:grid-cols-2 md:items-center">
      <div>
        <h2 class="heading-md text-tebra-teal-dark">Unified interface for clinic and lab teams</h2>
        <p class="mt-3 text-gray-700">
          A unified interface designed for both clinic and lab workflows-simple to navigate, powerful to operate.
        </p>
      </div>
      <div>
        <img
          src={visualImage.src}
          alt="EmbryoOne unified clinic and lab interface"
          class="w-full rounded-2xl border border-gray-200 object-cover shadow-[0_20px_40px_-28px_rgba(15,23,42,0.45)]"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Common tasks, simplified</h2>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {quickTaskGuides.map((task) => (
          <article class="rounded-xl border border-[#D8E7E7] bg-[#FCFEFE] px-4 py-3">
            <p class="text-sm font-semibold text-tebra-teal-dark">{task}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section bg-[#F7FAFA]">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Resolve issues quickly</h2>
      <div class="mt-6 space-y-3">
        {faqs.map((faq) => (
          <details class="rounded-2xl border border-[#D8E7E7] bg-white px-5 py-4">
            <summary class="cursor-pointer list-none text-base font-semibold text-tebra-teal-dark marker:content-none">
              {faq.question}
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-gray-700">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Documentation tailored to your role</h2>
      <div class="mt-7 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {roleGuides.map((guide) => (
          <article class="rounded-2xl border border-[#D8E7E7] bg-[#FCFEFE] p-5">
            <h3 class="text-lg font-semibold text-tebra-teal-dark">{guide.role}</h3>
            <ul class="mt-3 space-y-2 text-sm text-gray-700">
              {guide.points.map((point) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-tebra-teal"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section bg-[#F6FAFA]">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Find answers instantly</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <article class="rounded-2xl border border-[#D8E7E7] bg-white p-5">
          <h3 class="text-base font-semibold text-tebra-teal-dark">Smart search</h3>
          <p class="mt-2 text-sm text-gray-700">Quickly find feature guides, setup steps, and troubleshooting content.</p>
        </article>
        <article class="rounded-2xl border border-[#D8E7E7] bg-white p-5">
          <h3 class="text-base font-semibold text-tebra-teal-dark">Suggested queries</h3>
          <p class="mt-2 text-sm text-gray-700">Use suggested topics to jump into common IVF workflows and tasks.</p>
        </article>
        <article class="rounded-2xl border border-[#D8E7E7] bg-white p-5">
          <h3 class="text-base font-semibold text-tebra-teal-dark">Category filters</h3>
          <p class="mt-2 text-sm text-gray-700">Filter content by module, role, and workflow stage to narrow answers faster.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section bg-white">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Need help beyond documentation?</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <article class="rounded-2xl border border-[#D8E7E7] bg-[#FCFEFE] p-5">
          <h3 class="text-base font-semibold text-tebra-teal-dark">Contact support</h3>
          <p class="mt-2 text-sm text-gray-700">Reach our support team for product questions and issue resolution.</p>
        </article>
        <article class="rounded-2xl border border-[#D8E7E7] bg-[#FCFEFE] p-5">
          <h3 class="text-base font-semibold text-tebra-teal-dark">Schedule onboarding session</h3>
          <p class="mt-2 text-sm text-gray-700">Get guided onboarding for your clinic, lab team, and workflows.</p>
        </article>
        <article class="rounded-2xl border border-[#D8E7E7] bg-[#FCFEFE] p-5">
          <h3 class="text-base font-semibold text-tebra-teal-dark">Request product walkthrough</h3>
          <p class="mt-2 text-sm text-gray-700">See module-specific workflows for your role and operational goals.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="page-container max-w-6xl rounded-3xl bg-tebra-teal-dark px-6 py-10 sm:px-10">
      <h2 class="text-3xl font-semibold text-white sm:text-4xl">Get your team up and running faster</h2>
      <p class="mt-4 max-w-3xl text-base text-gray-100">
        Use EmbryoOne documentation to streamline workflows and improve efficiency across your clinic and lab.
      </p>
      <div class="mt-7">
        <Button href="/documentation" label="Explore documentation" variant="primary" size="md" />
      </div>
    </div>
  </section>
</BaseLayout>
