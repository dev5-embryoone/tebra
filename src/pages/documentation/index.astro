---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/Cards/ContentCard.astro";
import { pageCards } from "../../data/pageCards";

const cards = pageCards.documentation ?? [];
---
<BaseLayout
  title="Documentation | Tebra"
  description="Technical documentation and guides for Tebra."
>
  <section class="page-section bg-white">
    <div class="page-container">
      <h1 class="text-3xl font-semibold text-gray-900">Documentation</h1>
      <p class="mt-3 max-w-2xl text-gray-600">
        Technical documentation, API reference, and guides to get the most out of Tebra.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {cards.map((card) => (
          <ContentCard title={card.title} description={card.description} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
