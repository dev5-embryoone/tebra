---
import BaseLayout from "../../layouts/BaseLayout.astro";

const heroQuickLinks = [
  "Getting started",
  "Lab workflows",
  "User management",
  "Troubleshooting",
];

const gettingStartedBlocks = [
  {
    title: "Set up your workspace",
    points: ["Create teams, roles, and initial structure"],
  },
  {
    title: "Add users & roles",
    points: ["Invite staff and assign responsibilities"],
  },
  {
    title: "Configure lab workflows",
    points: ["Customize processes for your clinic"],
  },
  {
    title: "Start tracking activity",
    points: ["Begin managing embryos, cycles, and tasks"],
  },
];

const coreModules = [
  {
    title: "Tasks & Workflow",
    description: "Track, assign, and manage lab tasks",
  },
  {
    title: "Embryo Tracking",
    description: "Monitor lifecycle from fertilization to cryo",
  },
  {
    title: "Cryo Management",
    description: "Track storage, movement, and status",
  },
  {
    title: "Users & Roles",
    description: "Manage team structure and permissions",
  },
  {
    title: "Reports & Insights",
    description: "View activity, performance, and trends",
  },
  {
    title: "Embryo Copilot",
    description: "Ask questions and retrieve lab data instantly",
  },
];

const featureGuides = [
  {
    title: "Task management",
    description: "How to create, assign, and track tasks",
  },
  {
    title: "Embryo lifecycle tracking",
    description: "From fertilization to storage",
  },
  {
    title: "Inventory tracking",
    description: "Managing lab consumables",
  },
  {
    title: "Audit & traceability",
    description: "Ensuring compliance and visibility",
  },
];

const workflowSteps = [
  {
    label: "Capture",
    description: "Record embryo and patient data",
  },
  {
    label: "Track",
    description: "Monitor progression and status",
  },
  {
    label: "Analyze",
    description: "Review insights and patterns",
  },
  {
    label: "Decide",
    description: "Make informed clinical decisions",
  },
];

const troubleshootingSections = [
  {
    title: "Common questions",
    items: ["Why is embryo status not updating?"],
  },
  {
    title: "System issues",
    items: ["Fix sync or data delays"],
  },
  {
    title: "Access problems",
    items: ["Resolve user permission issues"],
  },
];
---
<BaseLayout
  title="Documentation | EmbryoOne"
  description="Search-first documentation for EmbryoOne—structured around workflows, modules, and Embryo Copilot."
>
  <!-- 1️⃣ HERO — SEARCH-FIRST EXPERIENCE -->
  <section class="page-section bg-white">
    <div class="page-container max-w-4xl">
      <div class="text-center">
        <p class="eyebrow text-[#6C3CF0]">Documentation</p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl md:text-5xl">
          Documentation that works like your lab
        </h1>
        <p class="mt-4 text-base leading-relaxed text-gray-700 sm:text-lg">
          Find answers, explore workflows, and learn how to get the most out of EmbryoOne—fast.
        </p>
      </div>

      <div class="mt-8 space-y-3">
        <div class="relative mx-auto max-w-2xl">
          <div class="relative flex items-center rounded-2xl bg-white px-4 py-3 shadow-[0_18px_60px_rgba(15,23,42,0.08)] ring-1 ring-[#D6E6E6] focus-within:ring-2 focus-within:ring-tebra-teal">
            <span class="inline-flex shrink-0 items-center justify-center rounded-full bg-purple-50 px-3 py-1 text-xs font-medium text-purple-700">
              Search docs
            </span>
            <input
              type="text"
              placeholder="Search workflows, tasks, users, cryo tracking…"
              class="ml-3 w-full border-none bg-transparent text-sm text-gray-900 placeholder:text-gray-400 outline-none"
            />
            <span class="ml-3 hidden rounded-md border border-slate-200 bg-slate-50 px-2 py-1 text-[11px] font-medium tracking-wide text-slate-500 sm:inline-flex">
              ⌘K
            </span>
          </div>
        </div>

        <div class="flex flex-wrap justify-center gap-2 pt-1">
          {heroQuickLinks.map((item, index) => (
            <button
              type="button"
              class={`inline-flex items-center gap-1 rounded-full border border-[#D7E6E6] bg-white px-4 py-1.5 text-xs font-medium text-tebra-teal-dark shadow-sm transition-all hover:-translate-y-0.5 hover:border-tebra-teal hover:bg-white hover:shadow-md sm:text-sm ${
                index === 0 ? "bg-tebra-teal-dark text-white hover:bg-tebra-teal" : ""
              }`}
            >
              <span class="h-1.5 w-1.5 rounded-full bg-purple-400" />
              {item}
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 2️⃣ GETTING STARTED — ONBOARDING BLOCK -->
  <section class="page-section bg-white">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Getting started with EmbryoOne</h2>
      <p class="mt-3 max-w-3xl text-sm text-gray-700 sm:text-base">
        Move from zero to live in a few guided steps—focused on teams, roles, and the workflows that matter most in your lab.
      </p>
      <div class="mt-7 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {gettingStartedBlocks.map((block) => (
          <article class="group flex h-full flex-col justify-between rounded-2xl border border-[#D8E7E7] bg-[#FCFEFE] p-5 shadow-sm transition-all hover:-translate-y-1 hover:border-[#C0DBDB] hover:bg-white hover:shadow-lg">
            <div>
              <h3 class="text-sm font-semibold text-tebra-teal-dark sm:text-base">{block.title}</h3>
              <ul class="mt-3 space-y-1.5 text-xs text-gray-700 sm:text-sm">
                {block.points.map((point) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1 inline-block h-1.5 w-1.5 rounded-full bg-purple-400 group-hover:bg-purple-500" />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3️⃣ CORE MODULES — GRID NAVIGATION -->
  <section class="page-section bg-[#F7F1FF]">
    <div class="page-container max-w-6xl">
      <h2 class="heading-md text-tebra-teal-dark">Core modules</h2>
      <p class="mt-3 max-w-3xl text-sm text-gray-700 sm:text-base">
        Navigate documentation by the modules your team uses every day.
      </p>
      <div class="mt-7 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {coreModules.map((module, index) => (
          <button
            type="button"
            class="group flex h-full flex-col items-start rounded-2xl border border-[#EADDFD] bg-white p-5 text-left shadow-sm outline-none transition-all hover:-translate-y-1 hover:border-[#D3C4FA] hover:shadow-xl focus-visible:ring-2 focus-visible:ring-[#6C3CF0]"
          >
            <div class="inline-flex items-center gap-2 rounded-full bg-[#F1E9FF] px-3 py-1 text-[11px] font-medium text-[#6C3CF0]">
              <span class="h-1.5 w-1.5 rounded-full bg-purple-400 group-hover:bg-purple-500" />
              Module {index + 1}
            </div>
            <h3 class="mt-3 text-base font-semibold text-tebra-teal-dark sm:text-lg">{module.title}</h3>
            <p class="mt-2 text-sm text-gray-700">{module.description}</p>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- 4️⃣ FEATURE GUIDES — EXPANDABLE LIST -->
  <section class="page-section bg-white">
    <div class="page-container max-w-4xl">
      <h2 class="heading-md text-tebra-teal-dark">Feature guides</h2>
      <p class="mt-3 text-sm text-gray-700 sm:text-base">
        Deep dives into the most important features, structured for real IVF workflows.
      </p>
      <div class="mt-6 space-y-3">
        {featureGuides.map((guide) => (
          <details class="group rounded-2xl border border-[#D8E7E7] bg-[#FCFEFE] px-4 py-3 shadow-sm transition-all open:bg-white open:shadow-md sm:px-5 sm:py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-semibold text-tebra-teal-dark marker:content-none sm:text-base">
              <span>{guide.title}</span>
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-slate-200 bg-white text-xs text-slate-500 transition-transform group-open:rotate-180">
                ˅
              </span>
            </summary>
            <p class="mt-2 text-sm text-gray-700">{guide.description}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 5️⃣ WORKFLOW WALKTHROUGH — VISUAL STEP FLOW -->
  <section class="page-section bg-[#F6FAFA]">
    <div class="page-container max-w-5xl">
      <h2 class="heading-md text-tebra-teal-dark">End-to-end embryo workflow</h2>
      <p class="mt-3 max-w-3xl text-sm text-gray-700 sm:text-base">
        See how EmbryoOne supports your decisions from capture to outcome.
      </p>
      <div class="mt-8 overflow-x-auto pb-3">
        <ol class="relative flex min-w-[640px] items-stretch justify-between gap-4 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-[#D8E7E7] sm:gap-6 sm:p-6">
          <div class="pointer-events-none absolute left-5 right-5 top-1/2 h-px -translate-y-1/2 bg-gradient-to-r from-[#6C3CF0]/10 via-[#6C3CF0]/30 to-[#0F766E]/30" />
          {workflowSteps.map((step, index) => (
            <li class="relative z-10 flex-1">
              <div class="flex flex-col items-start text-left">
                <div class="inline-flex items-center gap-2 rounded-full bg-[#F1E9FF] px-3 py-1 text-[11px] font-medium text-[#6C3CF0]">
                  <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[#6C3CF0] text-[11px] font-semibold text-white shadow-sm">
                    {index + 1}
                  </span>
                  {step.label}
                </div>
                <p class="mt-2 text-xs text-gray-700 sm:text-sm">{step.description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- 6️⃣ TROUBLESHOOTING — QUICK HELP -->
  <section class="page-section bg-white">
    <div class="page-container max-w-5xl">
      <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
        <div class="md:w-[55%]">
          <h2 class="heading-md text-tebra-teal-dark">Troubleshooting</h2>
          <p class="mt-3 text-sm text-gray-700 sm:text-base">
            Go straight to practical fixes for the most common issues in your lab.
          </p>
          <div class="mt-4">
            <input
              type="text"
              placeholder="Search issues (embryo status, sync, access…)"
              class="w-full rounded-xl border border-[#D8E7E7] bg-[#FCFEFE] px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 outline-none focus:border-tebra-teal focus:bg-white focus:ring-2 focus:ring-tebra-teal/20"
            />
          </div>
        </div>
        <div class="grid flex-1 gap-3 sm:grid-cols-2">
          {troubleshootingSections.map((section) => (
            <article class="rounded-2xl border border-[#D8E7E7] bg-[#FCFEFE] p-4 text-sm text-gray-800 shadow-sm">
              <h3 class="text-sm font-semibold text-tebra-teal-dark">{section.title}</h3>
              <ul class="mt-2 space-y-1.5 text-xs text-gray-700 sm:text-sm">
                {section.items.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1 inline-block h-1.5 w-1.5 rounded-full bg-purple-400" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 7️⃣ EMBRYO COPILOT DOC SECTION -->
  <section class="page-section bg-[#51285f]">
    <div class="page-container max-w-5xl text-white">
      <div class="grid gap-8 md:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)] md:items-center">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">Using Embryo Copilot</h2>
          <p class="mt-3 text-sm text-gray-200 sm:text-base">
            Ask questions about your lab and get instant answers—grounded in your EmbryoOne data.
          </p>
          <ul class="mt-4 space-y-1.5 text-sm text-gray-200">
            <li>• How many embryos are frozen?</li>
            <li>• Show activity by patient</li>
            <li>• What tasks are pending today?</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/5 p-4 shadow-[0_24px_80px_rgba(0,0,0,0.55)]">
          <div class="text-[11px] font-medium uppercase tracking-[0.15em] text-gray-300">
            Copilot example
          </div>
          <div class="mt-3 space-y-3 text-sm">
            <div class="flex gap-2">
              <div class="mt-0.5 h-6 w-6 rounded-full bg-[#6C3CF0]" />
              <div class="flex-1 rounded-2xl bg-[#6C3CF0]/10 px-3 py-2">
                <p class="text-gray-100">“What tasks are pending today in the lab?”</p>
              </div>
            </div>
            <div class="flex gap-2">
              <div class="mt-0.5 h-6 w-6 rounded-full bg-slate-800" />
              <div class="flex-1 rounded-2xl bg-black/20 px-3 py-2">
                <p class="text-gray-100">
                  You have <span class="font-semibold">12 tasks</span> pending today across 3 workflows:
                </p>
                <ul class="mt-2 space-y-1 text-xs text-gray-200">
                  <li>• 5 embryo grading reviews</li>
                  <li>• 4 cryo storage checks</li>
                  <li>• 3 consent form follow-ups</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8️⃣ FINAL CTA — SUPPORT -->
  <section class="page-section bg-white">
    <div class="page-container max-w-5xl">
      <div class="rounded-3xl bg-tebra-teal-dark px-6 py-8 text-center text-white shadow-[0_22px_80px_rgba(15,23,42,0.55)] sm:px-10 sm:py-10">
        <h2 class="text-2xl font-semibold sm:text-3xl">Still need help?</h2>
        <p class="mt-3 text-sm text-tebra-teal-light sm:text-base">
          Reach our support team or explore more detailed product guides tailored to your lab.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a
            href="/help"
            class="inline-flex items-center justify-center rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-tebra-teal-dark shadow-sm transition-all hover:-translate-y-0.5 hover:bg-slate-100"
          >
            Visit Help Center →
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full border border-white/60 bg-transparent px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:-translate-y-0.5 hover:bg-white/10"
          >
            Contact Support →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
