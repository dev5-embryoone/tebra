---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/Cards/ContentCard.astro";
import { pageCards } from "../../data/pageCards";

const cards = pageCards.pricing ?? [];
---
<BaseLayout
  title="Pricing | Tebra"
  description="Plans and pricing for Tebra EHR+ platform."
>
  <section class="page-section bg-white">
    <div class="page-container">
      <h1 class="text-3xl font-semibold text-gray-900">Pricing</h1>
      <p class="mt-3 max-w-2xl text-gray-600">
        Clear, transparent plans for the Tebra EHR+ platform. See what’s included and get a demo.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {cards.map((card) => (
          <ContentCard title={card.title} description={card.description} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
