---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Sign Up | EmbryoOne"
  description="Create your EmbryoOne account and get started with IVF lab and clinical workflows."
>
  <section class="bg-white py-12 sm:py-14">
    <div class="page-container">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2 lg:gap-10">
        <div class="rounded-2xl border border-gray-100 bg-gray-50 p-6 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-tebra-teal">EmbryoOne</p>
          <h1 class="mt-3 text-3xl font-semibold tracking-tight text-tebra-teal-dark sm:text-4xl">
            Create your account
          </h1>
          <p class="mt-3 text-sm leading-relaxed text-gray-700 sm:text-base">
            Set up your EmbryoOne account to access IVF lab workflow, embryo tracking, and clinical coordination tools.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-gray-700">
            <li class="flex items-start gap-2.5">
              <span class="mt-1 inline-block h-2 w-2 rounded-full bg-tebra-teal" aria-hidden="true"></span>
              <span>Unified visibility across lab and clinical teams</span>
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1 inline-block h-2 w-2 rounded-full bg-tebra-teal" aria-hidden="true"></span>
              <span>Structured workflow support from cycle setup to reporting</span>
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1 inline-block h-2 w-2 rounded-full bg-tebra-teal" aria-hidden="true"></span>
              <span>Onboarding guidance tailored to your clinic</span>
            </li>
          </ul>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm sm:p-8">
          <h2 class="text-xl font-semibold text-gray-900">Sign up details</h2>
          <p class="mt-2 text-sm text-gray-600">Complete this form to create your EmbryoOne account.</p>

          <form id="sign-up-form" class="mt-6 space-y-4" novalidate>
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="block text-left">
                <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">First name</span>
                <input
                  name="firstName"
                  type="text"
                  autocomplete="given-name"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 outline-none ring-tebra-teal/20 focus:border-tebra-teal focus:ring-2"
                />
              </label>
              <label class="block text-left">
                <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Last name</span>
                <input
                  name="lastName"
                  type="text"
                  autocomplete="family-name"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 outline-none ring-tebra-teal/20 focus:border-tebra-teal focus:ring-2"
                />
              </label>
            </div>
            <label class="block text-left">
              <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Clinic name</span>
              <input
                name="clinic"
                type="text"
                autocomplete="organization"
                class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 outline-none ring-tebra-teal/20 focus:border-tebra-teal focus:ring-2"
              />
            </label>
            <label class="block text-left">
              <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Work email</span>
              <input
                name="email"
                type="email"
                autocomplete="email"
                class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 outline-none ring-tebra-teal/20 focus:border-tebra-teal focus:ring-2"
              />
            </label>
            <label class="block text-left">
              <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Password</span>
              <input
                name="password"
                type="password"
                autocomplete="new-password"
                class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 outline-none ring-tebra-teal/20 focus:border-tebra-teal focus:ring-2"
              />
            </label>

            <button
              type="button"
              class="inline-flex min-h-[44px] w-full items-center justify-center rounded-full bg-btn-primary px-6 text-sm font-semibold text-white shadow-sm transition hover:bg-btn-primary-hover"
            >
              Create EmbryoOne account
            </button>
          </form>

          <p class="mt-4 text-sm text-gray-600">
            Already have an account?
            <a href="/sign-in/login" class="font-semibold text-tebra-teal hover:underline">Sign in</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
