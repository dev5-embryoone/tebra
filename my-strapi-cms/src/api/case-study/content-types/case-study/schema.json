{
  "kind": "collectionType",
  "collectionName": "case_studies",
  "info": {
    "singularName": "case-study",
    "pluralName": "case-studies",
    "displayName": "Case Study"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "company": {
      "type": "string",
      "required": true
    },
    "author": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string",
      "required": true
    },
    "quote": {
      "type": "text",
      "required": true
    },
    "metric": {
      "type": "string",
      "required": true
    },
    "metricLabel": {
      "type": "string"
    },
    "product": {
      "type": "enumeration",
      "enum": [
        "EHR",
        "Billing & Payments",
        "Patient Experience",
        "RPA",
        "Practice Growth"
      ]
    },
    "challenges": {
      "type": "json"
    },
    "roles": {
      "type": "json"
    },
    "hasVideo": {
      "type": "boolean",
      "default": false
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "realStory": {
      "type": "boolean",
      "default": false
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "audios",
        "videos"
      ]
    }
  }
}
